h+='<div class="chart-svg-wrap"><svg viewBox="0 0 280 150">';
for(var gi=0;gi<5;gi++){var gy=20+gi*26;h+='<line x1="40" y1="'+gy+'" x2="260" y2="'+gy+'" stroke="#334155" stroke-dasharray="4,4" stroke-width="1"/>';}
h+='<text x="38" y="24" text-anchor="end" fill="#64748b" font-size="10">'+maxLam.toFixed(1)+'</text>';
h+='<text x="38" y="50" text-anchor="end" fill="#64748b" font-size="10">'+(maxLam*3/4).toFixed(1)+'</text>';
h+='<text x="38" y="76" text-anchor="end" fill="#64748b" font-size="10">'+(maxLam/2).toFixed(1)+'</text>';
h+='<text x="38" y="102" text-anchor="end" fill="#64748b" font-size="10">'+(maxLam/4).toFixed(1)+'</text>';
h+='<text x="38" y="128" text-anchor="end" fill="#64748b" font-size="10">0.0</text>';
var lhH=Math.max(3,lambda_h/maxLam*104);var laH=Math.max(3,lambda_a/maxLam*104);
h+='<rect x="70" y="'+(124-lhH)+'" width="44" height="'+lhH+'" rx="3" fill="#10b981" opacity=".85"/>';
h+='<text x="92" y="'+(118-lhH)+'" text-anchor="middle" fill="#10b981" font-size="11" font-weight="600">'+lambda_h.toFixed(3)+'</text>';
h+='<rect x="160" y="'+(124-laH)+'" width="44" height="'+laH+'" rx="3" fill="#ef4444" opacity=".85"/>';
h+='<text x="182" y="'+(118-laH)+'" text-anchor="middle" fill="#ef4444" font-size="11" font-weight="600">'+lambda_a.toFixed(3)+'</text>';
h+='<text x="92" y="144" text-anchor="middle" fill="#94a3b8" font-size="11">е…Ҙдё»</text><text x="182" y="144" text-anchor="middle" fill="#94a3b8" font-size="11">е…Ҙе®ў</text></svg></div></div></div>';
// B: Physical vs Market chart
h+='<div class="exp-b"><div class="chart-box"><div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:4px;"><div class="ch-title" style="margin-bottom:0;">зү©зҗҶ vs еёӮеңә</div>';
h+='<div class="legend-wrap" style="margin-bottom:0;"><div class="legend-item"><span class="dot" style="background:#64748b"></span>зү©зҗҶ</div><div class="legend-item"><span class="dot" style="background:#ef4444"></span>еёӮеңә</div></div></div>';
var probHome=(hcp.home_win!==undefined?hcp.home_win:(phys.home_win||0))*100;
var probDraw=(hcp.draw_win!==undefined?hcp.draw_win:(phys.draw_win||0))*100;
var probAway=(hcp.away_win!==undefined?hcp.away_win:(phys.away_win||0))*100;
var probTotal=probHome+probDraw+probAway;
if(probTotal>0){probHome=(probHome/probTotal*100).toFixed(0);probDraw=(probDraw/probTotal*100).toFixed(0);probAway=(probAway/probTotal*100).toFixed(0);}else{probHome=33;probDraw=34;probAway=33;}
var physHome=(phys.home_win||0)*100;var mktHome=pMarket.home_win!==undefined?(pMarket.home_win*100):physHome;
var physDraw=Math.max(0,100-physHome-(phys.away_win||0)*100);var mktDraw=pMarket.draw_win!==undefined?(pMarket.draw_win*100):Math.max(0,100-mktHome-(pMarket.away_win||0)*100);
var physAway=(phys.away_win||0)*100;var mktAway=pMarket.away_win!==undefined?(pMarket.away_win*100):physAway;
var pmax=Math.max(physHome,mktHome,physDraw,mktDraw,physAway,mktAway,10);
var pmaxR=Math.ceil(pmax/20)*20+20;
var bh=function(v){return Math.max(3,v/pmaxR*104);};
h+='<div class="chart-svg-wrap"><svg viewBox="0 0 280 150">';
for(var gi=0;gi<5;gi++){var gy=20+gi*26;h+='<line x1="40" y1="'+gy+'" x2="280" y2="'+gy+'" stroke="#334155" stroke-dasharray="4,4" stroke-width="1"/>';}
h+='<text x="38" y="24" text-anchor="end" fill="#64748b" font-size="10">'+pmaxR+'%</text>';
h+='<text x="38" y="50" text-anchor="end" fill="#64748b" font-size="10">'+(pmaxR*3/4).toFixed(0)+'%</text>';
h+='<text x="38" y="76" text-anchor="end" fill="#64748b" font-size="10">'+(pmaxR/2).toFixed(0)+'%</text>';
h+='<text x="38" y="102" text-anchor="end" fill="#64748b" font-size="10">'+(pmaxR/4).toFixed(0)+'%</text>';
h+='<text x="38" y="128" text-anchor="end" fill="#64748b" font-size="10">0</text>';
function ba(v,h,col,x){return '<rect x="'+x+'" y="'+(124-h)+'" width="18" height="'+h+'" rx="2" fill="'+col+'" opacity=".7"/><text x="'+(x+9)+'" y="'+(118-h)+'" text-anchor="middle" fill="#94a3b8" font-size="9">'+v+'%</text>';}
var x=70;h+=ba(physHome.toFixed(0),bh(physHome),"#64748b",x);x=92;h+=ba(mktHome.toFixed(0),bh(mktHome),"#ef4444",x);
x=130;h+=ba(physDraw.toFixed(0),bh(physDraw),"#64748b",x);x=152;h+=ba(mktDraw.toFixed(0),bh(mktDraw),"#ef4444",x);
x=190;h+=ba(physAway.toFixed(0),bh(physAway),"#64748b",x);x=212;h+=ba(mktAway.toFixed(0),bh(mktAway),"#ef4444",x);
h+='<text x="90" y="144" text-anchor="middle" fill="#94a3b8" font-size="11">иғң</text>';
h+='<text x="150" y="144" text-anchor="middle" fill="#94a3b8" font-size="11">е№і</text>';
h+='<text x="210" y="144" text-anchor="middle" fill="#94a3b8" font-size="11">иҙҹ</text>';
h+='</svg></div></div></div>';
// C: Vertical analysis column
h+='<div class="exp-c">';
h+='<div class="analysis-item"><div class="ai-head"><span class="ai-icon">вҢ•</span><span class="ai-label">О»е·®еҖј</span></div><div class="ai-body">'+(ld>=0?"+":"")+ld.toFixed(4)+'</div></div>';
h+='<div class="analysis-item"><div class="ai-head"><span class="ai-icon" style="color:var(--cyan)">в„№пёҸ</span><span class="ai-label">S7иҜҙжҳҺ</span></div><div class="ai-body-muted">'+(s7Reason||(s7Score>0?"S7иҜ„еҲҶ: "+s7Score.toFixed(2):"ж— зү№ж®ҠеңәжҷҜ"))+'</div></div>';
h+='<div class="analysis-item"><div class="ai-head"><span class="ai-icon" style="color:#fbbf24">&#128161;</span><span class="ai-label">иҜұзӣҳеҲҶжһҗ</span></div><div class="ai-body-muted">'+(trapTxt||"ж— ејӮеёёдҝЎеҸ·")+'</div></div>';
h+='<div class="analysis-item"><div class="ai-head"><span class="ai-icon" style="color:#f59e0b">&#9888;&#65039;</span><span class="ai-label">йЈҺйҷ©жҸҗзӨә</span></div><div class="ai-body-muted">'+(riskTxt||"жЁЎеһӢдҝЎеҸ·жӯЈеёё")+'</div></div>';
h+='</div></div></div></div>';
return h;
}

function toggleCard(el){
  el.classList.toggle('expanded');
}
var __todayRawData = [];
var __todaySortBy = 'id';
var __todayFilterLevels = null;


function renderToday(data){
if(data){__todayRawData=data;}
var filtered=__todayRawData;
if(__todayFilterLevels&&__todayFilterLevels.length>0){
filtered=__todayRawData.filter(function(m){var lv=(m.level||m.rating_level||'').toLowerCase();return __todayFilterLevels.indexOf(lv)>=0;});
}
var sorted=filtered.slice();
if(__todaySortBy==='rating'){
sorted.sort(function(a,b){var ra=parseFloat(a.rating||a.fit_score||0);var rb=parseFloat(b.rating||b.fit_score||0);return rb-ra;});
}else{
sorted.sort(function(a,b){var ia=parseInt(a.match_id||a.id||0);var ib=parseInt(b.match_id||b.id||0);return ia-ib;});
}
var h='';
if(!sorted||sorted.length===0){h='<div class="empty-state">\u6ca1\u6709\u7b26\u5408\u6761\u4ef6\u7684\u9009\u9879</div>';}
else{
var mcById={},ddiById={},aiById={};
}

if(typeof __DATA!=='undefined'&&__DATA){
if(__DATA.mc)__DATA.mc.forEach(function(x){if(x.id)mcById[x.id]=x;});
if(__DATA.ddi)__DATA.ddi.forEach(function(x){if(x.id)ddiById[x.id]=x;});
if(__DATA.ai)__DATA.ai.forEach(function(x){if(x.id)aiById[x.id]=x;});
}
h+='<div class="match-table-header grid-layout-row"><div class="grid-col-id">&#36187;&#20107;&#32534;&#21495;</div><div class="grid-col-league">&#36187;&#20107;</div><div class="grid-col-time">&#24320;&#36187;&#26102;&#38388;</div><div class="grid-col-match">&#20027;&#38431; VS &#23458;&#38431;</div><div class="grid-col-dir">&#39044;&#27979;&#26041;&#21521;</div><div class="grid-col-score">&#32508;&#21512;&#35780;&#20998;</div><div class="grid-col-expand"></div></div>';
sorted.forEach(function(m,i){var mid=m.match_id||m.id||i;h+=renderMatchCard(m,i,mcById[mid],ddiById[mid],aiById[mid]);});;

}

// ====== зі»з»ҹйҰ–йЎөпјҲеҖ’и®Ўж—¶ / дёӢдёҖеңәжҜ”иөӣпјү======
function getFlagSrc(team){
  var p = TEAM_FLAGS[team];
  return p || '';
}
function renderHomePage(){
  var el = document.getElementById("homeInner");
  var now = new Date();
  var upcoming = null;
  for(var i = 0; i < WC_MATCHES.length; i++){
    var m = WC_MATCHES[i];
    var dp = m.d.replace('жңҲ','/').replace('ж—Ҙ','');
    var tp = m.t.split(':');
    var md = new Date(2026, parseInt(dp.split('/')[0])-1, parseInt(dp.split('/')[1]), parseInt(tp[0]), parseInt(tp[1]));
    if(md > now && (!upcoming || md < upcoming.date)){
      upcoming = {match: m, date: md};
    }
  }
  if(!upcoming){
    el.innerHTML = 
      '<div class="hcc-container">' +
        '<div class="hcc-bg-canvas"><div class="hcc-glow-orb o1"></div><div class="hcc-glow-orb o2"></div><div class="hcc-grid-lines"></div></div>' +
        '<div class="hcc-empty"><div class="hcc-empty-icon">рҹҸҶ</div><div class="hcc-empty-text">2026дё–з•ҢжқҜе·ІиҗҪе№•</div></div>' +
      '</div>';
    return;
  }
  window.__NEXT_MATCH = upcoming;
  var m = upcoming.match;
  var fh = getFlagSrc(m.h), fa = getFlagSrc(m.a);
  el.innerHTML =
    '<div class="hcc-container">' +
      '<div class="hcc-bg-canvas">' +
        '<div class="hcc-glow-orb o1"></div>' +
        '<div class="hcc-glow-orb o2"></div>' +
        '<div class="hcc-radar-sweep"></div>' +
        '<div class="hcc-radar-ring"></div>' +
        '<div class="hcc-radar-ring"></div>' +
        '<div class="hcc-radar-ring"></div>' +
        '<div class="hcc-grid-lines"></div>' +
      '</div>' +
      '<canvas id="hccParticles" class="hcc-particles"></canvas>' +
      '<div class="hcc-corner-bracket tl"></div>' +
      '<div class="hcc-corner-bracket tr"></div>' +
      '<div class="hcc-corner-bracket bl"></div>' +
      '<div class="hcc-corner-bracket br"></div>' +
      '<div class="hcc-center">' +
        '<div class="hcc-sysbar">' +
          '<span class="hsb-dot"></span>' +
          '<span class="hsb-item">' + m.g + 'з»„ В· <span class="hsb-val">' + m.v + '</span></span>' +
          '<span class="hsb-item">ејҖзҗғ: <span class="hsb-val">' + m.d + ' ' + m.t.slice(0,5) + '</span></span>' +
        '</div>' +
        '<div class="hcc-countdown">' +
          '<div class="hcc-countdown-title">и·қзҰ»дёӢдёҖеңәжҜ”иөӣ</div>' +
          '<div class="hcc-clock" id="hccClock">' +
            '<div class="hcc-clock-unit" id="hccDU"><div class="hcc-clock-digits cyan" id="hccDays">00</div><div class="hcc-clock-label">DAYS</div></div>' +
            '<div class="hcc-clock-sep" id="hccDS">:</div>' +
            '<div class="hcc-clock-unit"><div class="hcc-clock-digits" id="hccHours">00</div><div class="hcc-clock-label">HOURS</div></div>' +
            '<div class="hcc-clock-sep">:</div>' +
            '<div class="hcc-clock-unit"><div class="hcc-clock-digits gold" id="hccMins">00</div><div class="hcc-clock-label">MINUTES</div></div>' +
            '<div class="hcc-clock-sep">:</div>' +
            '<div class="hcc-clock-unit"><div class="hcc-clock-digits green" id="hccSecs">00</div><div class="hcc-clock-label">SECONDS</div></div>' +
          '</div>' +
        '</div>' +
        '<div class="hcc-match-card" onclick="openMatchAnalysis(\'' + m.h + '\',\'' + m.a + '\')">' +
          '<div class="hcc-mc-label">' + m.g + 'з»„ В· ' + m.v + '</div>' +
          '<div class="hcc-mc-teams">' +
            '<div class="hcc-mc-team">' +
              (fh ? '<img class="hcc-mc-flag" src="' + fh + '" loading="lazy" onerror="this.style.display=\'none\'">' : '') +
              '<div class="hcc-mc-team-name">' + m.h + '</div>' +
            '</div>' +
            '<div class="hcc-mc-vs">VS</div>' +
            '<div class="hcc-mc-team">' +
              (fa ? '<img class="hcc-mc-flag" src="' + fa + '" loading="lazy" onerror="this.style.display=\'none\'">' : '') +
              '<div class="hcc-mc-team-name">' + m.a + '</div>' +
            '</div>' +
          '</div>' +
          '<div class="hcc-mc-info"><span class="hcc-mc-venue-icon">рҹҢҚ</span> ' + m.d + ' В· ' + m.t.slice(0,5) + ' В· ' + m.v + '</div>' +
        '</div>' +
      '</div>' +
    '</div>';
  updateNextMatchCD();
  if(window.__CD_INTERVAL) clearInterval(window.__CD_INTERVAL);
  window.__CD_INTERVAL = setInterval(updateNextMatchCD, 1000);
  initParticles();
}
function updateNextMatchCD(){
  var nm = window.__NEXT_MATCH;
  if(!nm) return;
  var now = new Date();
  var diff = nm.date - now;
  if(diff <= 0){
    if(window.__CD_INTERVAL) clearInterval(window.__CD_INTERVAL);
    renderHomePage();
    return;
  }
  var totalSec = Math.floor(diff / 1000);
  var d = Math.floor(totalSec / 86400);
  var h = Math.floor((totalSec % 86400) / 3600);
  var m = Math.floor((totalSec % 3600) / 60);
  var s = totalSec % 60;
  var pad = function(v){return v<10?"0"+v:""+v;};
  var elD = document.getElementById("hccDays"); if(elD) elD.textContent = pad(d);
  var elH = document.getElementById("hccHours"); if(elH) elH.textContent = pad(h);
  var elM = document.getElementById("hccMins"); if(elM) elM.textContent = pad(m);
  var elS = document.getElementById("hccSecs"); if(elS) elS.textContent = pad(s);
  var elDU = document.getElementById("hccDU");
  var elDS = document.getElementById("hccDS");
  if(elDU) elDU.style.display = d > 0 ? '' : 'none';
  if(elDS) elDS.style.display = d > 0 ? '' : 'none';
}
function openMatchAnalysis(home, away){
  window.__TARGET_MATCH = {h:home, a:away};
  switchNav("analysis");
}
function initParticles(){
  var c = document.getElementById("hccParticles");
  if(!c) return;
  var ctx = c.getContext("2d");
  var W, H;
  function resize(){W=c.width=c.offsetWidth;H=c.height=c.offsetHeight;}
  resize();
  window.addEventListener("resize", resize);
  var pts = [];
  var count = 80;
  for(var i=0;i<count;i++){
    pts.push({
      x:Math.random()*W, y:Math.random()*H,
      vx:(Math.random()-0.5)*0.3, vy:-(0.2+Math.random()*0.4),
      r:Math.random()*2+0.5,
      a:0.2+Math.random()*0.5,
      hue:Math.random()<0.3?190:Math.random()<0.5?45:255
    });
  }
  function draw(){
    ctx.clearRect(0,0,W,H);
    for(var i=0;i<pts.length;i++){
      var p=pts[i];
      p.x+=p.vx; p.y+=p.vy;
      if(p.y<-10){p.y=H+10;p.x=Math.random()*W;}
      if(p.x<-10)p.x=W+10;
      if(p.x>W+10)p.x=-10;
      ctx.beginPath();
      ctx.arc(p.x,p.y,p.r,0,Math.PI*2);
      ctx.fillStyle="hsla("+p.hue+",80%,60%,"+p.a+")";
      ctx.fill();
      if(p.r>1.5){
        ctx.beginPath();
        ctx.arc(p.x,p.y,p.r*3,0,Math.PI*2);
        ctx.fillStyle="hsla("+p.hue+",80%,60%,"+(p.a*0.12)+")";
        ctx.fill();
      }
    }
    requestAnimationFrame(draw);
  }
  draw();
}

