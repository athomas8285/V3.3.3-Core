  NM['G']=['жҜ”еҲ©ж—¶','дјҠжң—','ж–°иҘҝе…°','еҹғеҸҠ'];
  NM['H']=['иҘҝзҸӯзүҷ','д№ҢжӢүеңӯ','жІҷзү№','дҪӣеҫ—и§’'];
  NM['I']=['жі•еӣҪ','еЎһеҶ…еҠ е°”','жҢӘеЁҒ','дјҠжӢүе…Ӣ'];
  NM['J']=['йҳҝж №е»·','йҳҝе°”еҸҠеҲ©дәҡ','еҘҘең°еҲ©','зәҰж—Ұ'];
  NM['K']=['и‘Ўиҗ„зүҷ','е“ҘдјҰжҜ”дәҡ','д№Ңе…№еҲ«е…Ӣж–ҜеқҰ','еҲҡжһң(йҮ‘)'];
  NM['L']=['иӢұж је…°','е…ӢзҪ—ең°дәҡ','еҠ зәі','е·ҙжӢҝй©¬'];
  var FL={};
  FL['A']=['mexico','czech','korea','south_africa'];
  FL['B']=['canada','switzerland','qatar','bosnia'];
  FL['C']=['brazil','morocco','scotland','haiti'];
  FL['D']=['usa','paraguay','australia','turkey'];
  FL['E']=['germany','cote_d_ivoire','ecuador','curacao'];
  FL['F']=['netherlands','sweden','japan','tunisia'];
  FL['G']=['belgium','iran','new_zealand','egypt'];
  FL['H']=['spain','uruguay','saudi_arabia','cape_verde'];
