            <span class="wsi-icon">рҹ”Қ</span>
            <span class="wsi-label">жҜ”иөӣеҲҶжһҗ</span>
          </div>
          <div class="wc-sub-item" onclick="switchNav('standings')" data-nav="standings">
            <span class="wsi-icon">рҹ“Ҡ</span>
