  for(var gi=0;gi<GS.length;gi++){
    var gk=GS[gi],nms=NM[gk]||[],fls=FL[gk]||[];
    h+='<div class="gs-card"><div class="gs-card-title"><span class="gs-tag">GROUP '+gk+'</span><span class="gs-count">'+nms.length+' TEAMS</span></div>';
