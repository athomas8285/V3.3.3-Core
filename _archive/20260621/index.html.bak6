  var h='<div class="gs-wrap"><div class="gs-header"><button class="sec-back-btn" onclick="switchNav(\'home\')">вҶҗ иҝ”еӣһйҰ–йЎө</button><h2>е°Ҹз»„з§ҜеҲҶжҰң</h2><div class="gs-bar"></div></div><div class="gs-grid">';
