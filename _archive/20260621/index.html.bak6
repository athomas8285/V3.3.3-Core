<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>V3.3.3-Core еҲҶжһҗзі»з»ҹ</title></head>

<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{--bg:#080b14;--surface:#0c1021;--surface-2:#111629;--surface-h:#171d35;--t1:#e8edf5;--t2:#8b95a9;--t3:#5a6577;--green:#00e676;--red:#ef5350;--gold:#fbbf24;--amber:#fbbf24;--blue:#60a5fa;--cyan:#00e5ff;--purple:#7c3aed;--bd:rgba(0,229,255,.06);--bd-h:rgba(0,229,255,.14);--glow-cyan:0 0 12px rgba(0,229,255,.12);--glow-green:0 0 12px rgba(0,230,118,.12);--glow-amber:0 0 12px rgba(251,191,36,.12);--glow-gold:0 0 12px rgba(251,191,36,.15);--glow-purple:0 0 12px rgba(124,58,237,.12);--mono:"SF Mono","Cascadia Code","JetBrains Mono","Consolas",monospace;--sans:"Inter","SF Pro","Microsoft YaHei","PingFang SC","Noto Sans SC",sans-serif}
body{font-family:var(--sans);background:linear-gradient(rgba(26,26,32,0.12),rgba(26,26,32,0.12)),url('../static/bg1.png') center/cover no-repeat fixed;color:var(--t1);height:100vh;width:100vw;overflow:hidden;overflow-x:hidden;display:flex;-webkit-font-smoothing:antialiased;text-rendering:optimizeLegibility}
::-webkit-scrollbar{width:3px}
::-webkit-scrollbar-track{background:transparent}
::-webkit-scrollbar-thumb{background:rgba(0,229,255,.08);border-radius:2px}
.sd-wrap{width:250px;flex-shrink:0;position:relative;z-index:100;background:linear-gradient(180deg,rgba(12,16,33,.35) 0%,rgba(16,22,42,.30) 100%);border-right:1px solid rgba(0,229,255,.03);display:flex;flex-direction:column;overflow:hidden;overscroll-behavior:contain}
.sd-top{padding:20px 18px 16px;border-bottom:1px solid transparent;border-image:linear-gradient(90deg,rgba(0,229,255,.1),transparent 70%) 1;flex-shrink:0}
.sd-logo-row{display:flex;align-items:center;gap:10px}
.sd-title-group{display:flex;align-items:baseline;gap:8px;flex-wrap:nowrap;min-width:0}

.sd-title{font-size:22px;font-weight:700;color:var(--cyan);letter-spacing:1px;line-height:1.2;display:inline;white-space:nowrap}
.sd-sub{font-size:10px;font-weight:300;color:rgba(148,163,184,.4);letter-spacing:.3px;display:inline;white-space:nowrap;vertical-align:baseline;position:relative;top:-0px}
.sd-status{display:flex;align-items:center;gap:8px;margin-top:10px;font-size:12px;color:rgba(255,255,255,.7);padding:4px 0;-webkit-font-smoothing:antialiased;text-shadow:0 0 1px rgba(0,0,0,.5)}
.sd-status-dot{width:8px;height:8px;border-radius:50%;background:var(--green);flex-shrink:0;animation:pulse 2s infinite;box-shadow:0 0 6px rgba(0,230,118,.4)}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.4}}.sd-nav-item{display:flex;align-items:center;gap:10px;padding:10px 12px;margin:4px 8px;border-radius:6px;cursor:pointer;transition:all .15s;font-size:13px;color:var(--t2)}
.sd-nav-item:hover{background:rgba(0,229,255,.06);color:var(--t1)}
.sd-nav-item .sni-icon{font-size:16px;flex-shrink:0}
.sd-nav-item .sni-label{flex:1}
.sd-nav-item.active{background:rgba(0,229,255,.1);color:var(--cyan);border-left:3px solid var(--cyan);padding-left:9px}
.sd-nav-divider{height:1px;margin:4px 12px;background:linear-gradient(90deg,transparent,rgba(0,229,255,.08),transparent)}

@keyframes pulse-glow{0%{box-shadow:0 0 0 0 rgba(0,229,255,.4);border-color:rgba(0,229,255,.4)}70%{box-shadow:0 0 14px 4px rgba(0,229,255,.08);border-color:rgba(0,229,255,.8)}100%{box-shadow:0 0 0 0 rgba(0,229,255,.0);border-color:rgba(0,229,255,.4)}}
.sd-body{flex:1;min-height:0;overflow-y:scroll;overflow-x:hidden;padding:0 0 16px}

/* дҫ§иҫ№ж ҸиҮӘе®ҡд№үж»ҡеҠЁжқЎ - еёёй©»жҳҫзӨәгҖҒжһҒз»ҶйЈҺж ј */
.sd-body::-webkit-scrollbar {
  width: 4px;
}
.sd-body::-webkit-scrollbar-track {
  background: rgba(255,255,255,0.04);
}
.sd-body::-webkit-scrollbar-thumb {
  background: rgba(255, 255, 255, 0.15);
  border-radius: 10px;
  transition: background 0.2s ease;
}
.sd-body::-webkit-scrollbar-thumb:hover {
  background: rgba(255, 255, 255, 0.45);
}
.sd-wrap:hover .sd-body::-webkit-scrollbar-thumb {
  background: rgba(255, 255, 255, 0.25);
}
.sd-wrap:hover .sd-body::-webkit-scrollbar-thumb:hover {
  background: rgba(255, 255, 255, 0.55);
}
/* Firefox е…је®№ */
.sd-body {
  scrollbar-width: thin;
  scrollbar-color: rgba(255, 255, 255, 0.15) transparent;
}
/* WC sidebar */
#accWCMain .acc-head{border-radius:6px;margin:4px 8px;white-space:nowrap}
#accWCMain.open>.acc-head .acc-label{color:var(--gold);text-shadow:0 0 12px rgba(251,191,36,.15)}
.wc-sub-item{display:flex;align-items:center;gap:10px;padding:9px 12px;margin:3px 8px;border-radius:6px;cursor:pointer;transition:all .15s;font-size:13px;color:var(--t2)}
.wc-sub-item:hover{background:rgba(251,191,36,.06);color:var(--t1)}
.wc-sub-item .wsi-icon{font-size:15px;flex-shrink:0}
.bt-stat-item{padding:10px 12px;margin:3px 8px;border-radius:6px;background:rgba(255,255,255,.02);border:1px solid rgba(66,165,245,.08);cursor:default;transition:all .15s}
.bt-stat-item:hover{background:rgba(66,165,245,.04);border-color:rgba(66,165,245,.15)}
.bt-stat-item .bt-month{font-size:12px;font-weight:600;color:var(--blue);margin-bottom:5px}
.bt-stat-item .bt-row{display:flex;align-items:center;gap:6px;font-size:11px;color:var(--t2)}
.bt-stat-item .bt-stat{display:inline-flex;align-items:center;gap:3px;padding:2px 6px;border-radius:4px;font-size:10px;font-weight:600}
.bt-stat .bt-num{font-size:11px;font-weight:700}
.bt-stat.green{background:rgba(0,230,118,.1);color:var(--green)}
.bt-stat.blue{background:rgba(96,165,250,.1);color:var(--blue)}
.bt-stat.amber{background:rgba(251,191,36,.1);color:var(--gold)}
.wc-sub-item .wsi-label{flex:1}
.wc-sub-item.active{background:rgba(251,191,36,.12);color:var(--gold);border-left:3px solid var(--gold);padding-left:9px}

.doc-sub-item{display:flex;align-items:center;gap:10px;padding:9px 12px;margin:3px 8px;border-radius:6px;cursor:pointer;transition:all .15s;font-size:13px;color:var(--t2)}
.doc-sub-item:hover{background:rgba(0,229,255,.06);color:var(--t1)}
.doc-sub-item .dsi-icon{font-size:15px;flex-shrink:0}
.doc-sub-item .dsi-label{flex:1}
.doc-sub-item.active{background:rgba(0,229,255,.12);color:var(--cyan);border-left:3px solid var(--cyan);padding-left:9px}
/* View content containers for nav switching */

/* ====== Documentation inline view ====== */
#docContent{display:flex;flex-direction:column;height:100%}
#docInner{padding:0;overflow-y:auto;height:100%}
.doc-back-bar{display:flex;align-items:center;gap:12px;padding:14px 24px;border-bottom:1px solid var(--bd);margin-bottom:20px;flex-shrink:0}
.doc-back-btn{font-size:12px;color:var(--cyan);background:rgba(0,229,255,.08);border:1px solid rgba(0,229,255,.2);padding:6px 14px;border-radius:6px;cursor:pointer;font-family:var(--sans);transition:all .15s}
.doc-back-btn:hover{background:rgba(0,229,255,.16);color:#fff}
.sec-back-btn{font-size:12px;color:var(--cyan);background:rgba(0,229,255,.08);border:1px solid rgba(0,229,255,.2);padding:5px 12px;border-radius:6px;cursor:pointer;font-family:var(--sans);transition:all .15s;flex-shrink:0;margin-right:8px}

.sec-back-btn:hover{background:rgba(0,229,255,.16);color:#fff}

.doc-current-title{font-size:16px;font-weight:600;color:var(--t1);letter-spacing:.3px}
.doc-body{padding:0 24px 40px;font-size:14px;line-height:1.8;color:var(--t2)}
.doc-body p{margin:8px 0;font-size:14px;line-height:1.8;color:var(--t2)}
.doc-loading{color:var(--t3);font-size:13px;text-align:center;padding:60px 0}
.doc-error{color:var(--red);font-size:13px;text-align:center;padding:60px 0}
.view-content{display:block}
#standingsContent{min-height:100%;height:auto}
#scheduleContent{min-height:100%;height:auto}
.sd-wc-badge{font-size:9px;color:var(--gold);background:rgba(251,191,36,.14);padding:1px 7px;border-radius:8px;letter-spacing:.3px;white-space:nowrap}
#accHistory,#accBacktest,#accDoc{opacity:.7;transition:opacity .2s}
#accHistory:hover,#accBacktest:hover,#accDoc:hover{opacity:1}

.tf{width:20px;height:20px;border-radius:50%;vertical-align:middle;margin-right:4px;object-fit:cover;flex-shrink:0}
/* WC group schedule */
.wc-date-group{margin-bottom:12px}
.wc-date-head{font-size:15px;font-weight:700;color:var(--gold);padding:12px 0 6px;border-bottom:1px solid rgba(251,191,36,.12);margin-bottom:8px;letter-spacing:.5px;text-shadow:0 0 8px rgba(251,191,36,.1)}
.wc-match-card{display:flex;align-items:center;gap:10px;padding:9px 14px;margin:4px 0;background:rgba(255,255,255,.02);border:1px solid rgba(255,255,255,.04);border-radius:6px;cursor:pointer;transition:all .15s;font-size:13px}
.wc-match-card:hover{background:rgba(251,191,36,.04);border-color:rgba(251,191,36,.1)}
.wc-m-time{font-family:var(--mono);font-size:12px;color:var(--t3);width:44px;flex-shrink:0;text-align:center}
.wc-m-group{font-size:10px;color:var(--gold);background:rgba(251,191,36,.1);padding:1px 5px;border-radius:3px;flex-shrink:0}
.wc-m-home{flex:1;text-align:right;font-weight:600;color:var(--t1)}
.wc-m-vs{color:var(--t3);font-size:11px;flex-shrink:0;width:20px;text-align:center}
.wc-m-away{flex:1;font-weight:600;color:var(--t1)}
.wc-m-venue{font-size:10px;color:var(--t3);flex-shrink:0;max-width:70px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}

.sd-footer{padding:10px 16px;font-size:9px;color:rgba(255,255,255,.6);text-align:center;letter-spacing:.5px;font-family:var(--mono);text-shadow:0 0 4px rgba(255,255,255,.05);flex-shrink:0}
.acc{border-bottom:1px solid transparent;border-image:linear-gradient(90deg,rgba(0,229,255,.07),transparent 70%) 1}
.acc-head{display:flex;align-items:center;gap:10px;padding:13px 16px;min-height:48px;cursor:pointer;user-select:none;transition:background .15s}
.acc-head:hover{background:rgba(0,229,255,.03)}
.acc-head .acc-arrow{font-size:11px;color:var(--t3);transition:transform .3s ease;flex-shrink:0;width:12px;text-align:center}
.acc.open .acc-arrow{transform:rotate(90deg)}
.acc-head .acc-icon{font-size:17px}
.acc-head .acc-label{font-size:15px;font-weight:600;color:var(--t2);letter-spacing:.5px;flex:1;min-width:0}
.acc-head .acc-badge{font-size:10px;color:var(--green);background:rgba(0,230,118,.1);padding:2px 8px;border-radius:8px;white-space:nowrap}
.acc-head .acc-count{font-size:12px;color:var(--t3);background:rgba(255,255,255,.06);padding:1px 5px;border-radius:4px;white-space:nowrap}
.acc.open .acc-head .acc-label{color:var(--t1)}
.acc-body{overflow:hidden;max-height:0;transition:max-height .35s ease}
.acc.open>.acc-body{max-height:900px}
.acc-body-inner{padding:4px 16px 12px}
.today-stats{display:flex;flex-direction:column;gap:6px;padding:4px 0}
.today-stat-row{display:flex;justify-content:space-between;align-items:center;padding:5px 8px;background:rgba(0,229,255,.02);border-radius:5px;font-size:11px;border:1px solid rgba(0,229,255,.03)}
.today-stat-row .tsl{color:var(--t3)}
.today-stat-row .tsv{color:var(--t1);font-weight:600;font-family:var(--mono);letter-spacing:.3px}
.today-stat-row .tsv.high{color:var(--green)}
.today-stat-row .tsv.med{color:var(--amber)}
.today-stat-row .tsv.low{color:var(--red)}
.today-divider{height:1px;background:var(--bd);margin:6px 0}
.today-date{font-size:14px;color:var(--green);font-weight:600;padding:2px 0;text-align:center;font-family:var(--mono);text-shadow:0 0 8px rgba(0,230,118,.2)}
.hist-date-item{display:flex;align-items:center;gap:6px;padding:10px 16px;min-height:40px;cursor:pointer;transition:all .2s;border-left:1px solid transparent;border-radius:0;margin:2px 0}
.hist-date-item:hover{background:rgba(0,229,255,.03)}
.hist-date-item.active{border-left-color:var(--green);background:rgba(0,230,118,.07)}
.hist-date-item .hd-date{font-size:14px;font-weight:600;color:var(--t1);flex:1;min-width:0}
.hist-date-item .hd-stats{font-size:11px;color:var(--t3);white-space:nowrap}
.hist-date-item.active .hd-date{color:#fff}
.hist-date-item .hd-arrow{font-size:10px;color:var(--t3);transition:transform .3s ease}
.hist-date-item.open .hd-arrow{transform:rotate(90deg)}
.hist-action{padding:4px 16px 8px 28px;display:none}
.hist-date-item.open+.hist-action{display:block}
.hist-action button{width:100%;padding:5px 10px;font-size:10px;color:var(--t2);background:rgba(0,230,118,.08);border:1px solid rgba(0,230,118,.15);border-radius:4px;cursor:pointer;transition:all .15s;font-family:var(--sans)}
.hist-action button:hover{background:rgba(0,230,118,.18);color:var(--green)}
.hist-empty{padding:0 12px;font-size:12px;color:var(--t3);text-align:center}
.bt-item{padding:9px 12px;margin:5px 0;background:rgba(255,255,255,.02);border-radius:5px;cursor:pointer;transition:background .15s;border:1px solid transparent}
.bt-item:hover{background:rgba(255,255,255,.09);border-color:rgba(255,255,255,.12)}
.bt-item .bt-title{font-size:13px;font-weight:600;color:var(--t1);margin-bottom:2px}
.bt-item .bt-meta{font-size:11px;color:var(--t3);display:flex;gap:8px;flex-wrap:wrap}
.bt-item .bt-meta span{background:rgba(255,255,255,.04);padding:1px 5px;border-radius:3px}
.bt-detail{padding:10px;margin:3px 0 8px;background:var(--surface);border-radius:6px;font-size:11px;color:var(--t2);line-height:1.6;display:none;border:1px solid var(--bd)}
.bt-detail.show{display:block}
.bt-detail .bt-summ{color:var(--t1);margin-bottom:4px}
.bt-detail .bt-link{padding:5px 10px;font-size:11px;background:rgba(66,165,245,.12);color:var(--blue);border:none;border-radius:4px;cursor:pointer;font-family:var(--sans);transition:background .15s}
.doc-item{padding:9px 12px;margin:5px 0;background:rgba(255,255,255,.02);border-radius:5px;cursor:pointer;transition:background .15s}
.doc-item:hover{background:rgba(255,255,255,.09)}
.doc-item .doc-title{font-size:13px;font-weight:600;color:var(--t1)}
.doc-content{padding:10px;margin:3px 0 8px;background:var(--surface);border-radius:5px;display:none;border:1px solid var(--bd)}
.doc-content.show{display:block}
.doc-entry{padding:5px 0;font-size:12px;line-height:1.7}
.doc-entry .de-label{color:var(--green);font-weight:600;white-space:nowrap}
.doc-entry .de-value{color:var(--t2)}
.sd-loading{color:var(--t3);font-size:12px;padding:12px;text-align:center}
.sd-error{color:var(--red);font-size:12px;padding:12px;text-align:center}
.main{flex:1;min-width:0;padding:0 24px 60px;overflow-y:auto;overflow-x:hidden}
.sec-header{display:flex;align-items:baseline;gap:12px;padding:18px 0 10px}
.sec-header h2{font-size:16px;font-weight:700;color:var(--t1)}
.sec-header .sec-sub{font-size:12px;color:var(--t2);font-weight:500}
.sec-header .sec-bar{flex:1;height:1px;background:var(--bd)}
.sec-actions{display:flex;align-items:center;gap:8px;flex-shrink:0;margin-left:auto}
.sec-dropdown{position:relative;display:inline-block}
.sec-dropdown-btn{font-size:11px;color:var(--t2);background:rgba(12,16,33,.6);border:1px solid var(--bd);border-radius:5px;padding:4px 10px;cursor:pointer;font-family:var(--sans);white-space:nowrap;transition:all .15s;letter-spacing:.3px}
.sec-dropdown-btn:hover{background:rgba(30,38,70,.7);border-color:var(--bd-h);color:var(--t1)}
.sec-dropdown-menu{display:none;position:absolute;top:calc(100% + 6px);right:0;min-width:130px;background:rgba(12,16,33,.92);border:1px solid var(--bd-h);border-radius:8px;padding:4px;z-index:200;-webkit-backdrop-filter:blur(12px);backdrop-filter:blur(12px);box-shadow:0 4px 20px rgba(0,0,0,.4)}
.sec-dropdown-menu.show{display:block}
.sec-dropdown-item{padding:7px 12px;font-size:12px;color:var(--t2);cursor:pointer;border-radius:5px;transition:all .12s;white-space:nowrap}
.sec-dropdown-item:hover{background:rgba(0,229,255,.08);color:var(--t1)}
.sec-dropdown-item.active{color:var(--cyan);background:rgba(0,229,255,.06)}
.sec-dropdown-label{display:flex;align-items:center;gap:8px;padding:7px 12px;font-size:12px;color:var(--t2);cursor:pointer;border-radius:5px;transition:all .12s;white-space:nowrap}
.sec-dropdown-label:hover{background:rgba(0,229,255,.08);color:var(--t1)}
.sec-dropdown-label input[type=checkbox]{accent-color:var(--cyan);width:14px;height:14px;cursor:pointer}
@media(max-width:768px){
  .sec-actions{gap:4px}
  .sec-dropdown-btn{font-size:10px;padding:3px 7px}
}


.card:hover{background:rgba(35,44,76,.88);border-color:rgba(0,229,255,.12);box-shadow:0 2px 0 rgba(0,229,255,.1),0 6px 20px rgba(0,0,0,.3)}

.card.active{border-color:rgba(0,230,118,.25);box-shadow:0 0 0 1px rgba(0,230,118,.12),0 0 20px rgba(0,230,118,.04)}

.card.active 

.card.active 
.chart-wrap{position:relative;height:80px;display:flex;align-items:flex-end;padding:0 4px}
.chart-y-axis{position:absolute;left:0;top:0;bottom:0;width:100%;pointer-events:none}
.chart-y-axis line{stroke:rgba(255,255,255,.06);stroke-width:1;stroke-dasharray:3 3}
.chart-y-axis text{fill:var(--t3);font-size:8px;font-family:var(--mono)}
.chart-bar-group{display:flex;flex-direction:column;align-items:center;gap:4px;flex:1;max-width:60px}
.chart-bar{width:100%;max-width:36px;border-radius:4px 4px 0 0;min-height:4px;position:relative;transition:height .5s ease}
.chart-bar-label{font-size:9px;color:var(--t3);font-family:var(--mono);white-space:nowrap}
.chart-bar-val{font-size:9px;font-weight:600;font-family:var(--mono);position:absolute;top:-14px;left:50%;transform:translateX(-50%);white-space:nowrap}
.chart-bar.val-green .chart-bar-val{color:var(--green)}
.chart-bar.val-red .chart-bar-val{color:var(--red)}
.chart-bar.val-amber .chart-bar-val{color:var(--amber)}
.detail-grid-4{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:10px}
.detail-cell{background:var(--surface);border-radius:6px;padding:8px 10px;display:flex;flex-direction:column;gap:2px}
.detail-cell .dc-label{font-size:10px;color:var(--t3);font-weight:500;display:flex;align-items:center;gap:4px}
.detail-cell .dc-value{font-size:12px;color:var(--t1);line-height:1.4;overflow:hidden;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;word-break:break-word}
.detail-cell .dc-value strong{font-family:var(--mono);font-weight:800;color:#fff;font-size:14px}
.detail-cell.risk{background:rgba(239,83,80,.1);border:1px solid rgba(239,83,80,.15)}
.detail-cell.risk .dc-value{color:var(--red)}

.detail-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-top:12px}
.chart-box{background:var(--surface);border-radius:8px;padding:12px 12px 8px}
.chart-box .ch-title{font-size:11px;color:var(--t2);margin-bottom:6px;font-weight:600}

.table-wrap{background:var(--surface-2);border:1px solid var(--bd);border-radius:8px;overflow:hidden;margin-top:6px}
.table-top{display:flex;align-items:center;gap:14px;padding:10px 14px;background:var(--surface);border-bottom:1px solid var(--bd);flex-wrap:wrap}
.table-top .tt-item{font-size:11px;color:var(--t2)}
.table-top .tt-item b{color:var(--t1);font-weight:600}
.table-top .tt-item .hl{color:var(--green)}
.table-top .tt-item .hl2{color:var(--amber)}
.tt-spacer{flex:1}
table.y-table{width:100%;border-collapse:collapse;font-size:12px}
table.y-table thead th{padding:8px 10px;text-align:left;font-weight:600;color:#A0AEC0;background:rgba(255,255,255,.04);border-bottom:1px solid var(--bd);white-space:nowrap;font-size:11px}
table.y-table tbody td{padding:8px 10px;border-bottom:1px solid rgba(255,255,255,.015);color:var(--t2);white-space:nowrap}
table.y-table tbody tr:hover{background:rgba(255,255,255,.03)}
table.y-table tbody tr:last-child td{border-bottom:none}
td.c-result{font-weight:600}
td.c-result.win{color:var(--red)}
td.c-result.lose{color:var(--green)}
td.c-result.draw{color:var(--blue)}
td.c-status .tag{padding:2px 8px;border-radius:3px;font-size:10px;font-weight:600}
td.c-status .tag.hit{background:var(--red);color:#fff}
td.c-status .tag.miss{background:var(--t3);color:#fff}
td.c-rating .r-num{font-weight:700;color:var(--t1);font-family:var(--mono);text-shadow:0 0 6px rgba(160,200,255,.25)}
td.c-rating .r-lvl{font-size:10px;padding:1px 5px;border-radius:3px;font-weight:600;margin-left:4px}
td.c-rating .r-lvl.s{background:var(--green);color:#fff}
td.c-rating .r-lvl.a{background:var(--amber);color:#222}
td.c-rating .r-lvl.b{background:var(--t3);color:#fff}
.empty-state{text-align:center;padding:40px 20px;color:var(--t3);font-size:13px}

/* === Contact & Divider === */
.sd-divider{height:1px;margin:0 18px;flex-shrink:0;background:linear-gradient(90deg,rgba(0,229,255,.08),transparent 60%);}
.sd-contact{padding:0 16px 6px;display:flex;flex-direction:column;gap:6px;flex-shrink:0}
.sd-contact-btn{display:flex;align-items:center;justify-content:center;gap:8px;width:100%;padding:10px 16px;border-radius:8px;border:1px solid rgba(0,229,255,.25);background:rgba(0,229,255,.04);color:var(--cyan);font-size:13px;font-family:var(--sans);cursor:pointer;transition:all .3s;animation:pulse-glow 2s ease-in-out infinite}
.sd-contact-btn:hover{background:rgba(0,229,255,.12);border-color:rgba(0,229,255,.6);color:#fff;box-shadow:0 0 20px rgba(0,229,255,.25),inset 0 0 20px rgba(0,229,255,.05);animation:none}
.sd-contact-btn .cb-icon{font-size:16px}
.sd-contact-btn .cb-text{font-weight:500}
/* Contact modal */
.wc-modal-overlay{display:none;position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,.7);z-index:9999;justify-content:center;align-items:center}
.wc-modal-overlay.active{display:flex}
.wc-modal{background:#1a1d2e;border:1px solid rgba(0,229,255,.15);border-radius:12px;padding:32px;text-align:center;max-width:320px;width:90%;box-shadow:0 8px 40px rgba(0,0,0,.5)}
.wc-modal img{max-width:100%;height:auto;border-radius:8px;margin:0 auto 16px;display:block}
.wc-modal p{font-size:13px;color:var(--t2);line-height:1.6;margin:0;white-space:nowrap}
.wc-modal .close-btn{position:absolute;top:12px;right:16px;font-size:22px;color:var(--t3);cursor:pointer;background:none;border:none;font-family:var(--sans)}
.wc-modal-wrap{position:relative}


/* Today module highlight */



/* Active date stronger highlight */
.hist-date-item.active{border-left:3px solid var(--cyan);background:rgba(0,229,255,.02);box-shadow:inset 0 0 16px rgba(0,229,255,.06),3px 0 10px rgba(0,229,255,.04)}
.hist-date-item.active .hd-date{color:var(--green)}

/* Stronger active state for nav items */
.acc.open>.acc-head{background:linear-gradient(90deg,rgba(0,229,255,.04),transparent 50%)}

/* === Plan Items === */
.plan-item{display:flex;align-items:center;gap:10px;padding:11px 12px;cursor:pointer;transition:all .15s;border-radius:6px;margin:4px 0;text-decoration:none;border:1px solid transparent}
.plan-item:hover{background:rgba(0,229,255,.03);border-color:rgba(0,229,255,.08)}
.plan-item .plan-icon{font-size:15px;flex-shrink:0}
.plan-item .plan-name{font-size:13px;color:var(--t1);flex:1;font-weight:500}
.plan-item .plan-arrow{font-size:12px;color:var(--t3);transition:transform .2s}
.plan-item:hover .plan-arrow{transform:translateX(4px);color:var(--green)}

@media(max-width:768px){
  .sd-wrap{width:60px}
  .sd-title,.sd-sub,.sd-status,.plan-item,.acc .acc-label,.acc .acc-badge,.acc .acc-count,.hist-date-item .hd-date,.hist-date-item .hd-stats,.today-stat-row,.bt-item .bt-title,.bt-item .bt-meta,.doc-item .doc-title,.sd-contact,.sd-footer{display:none}
  .sd-wrap .acc-body{max-height:0!important}
  .sd-wrap:hover{width:250px;position:fixed;z-index:100;box-shadow:4px 0 20px rgba(0,0,0,.4)}
  .sd-wrap:hover .sd-title,.sd-wrap:hover .sd-sub,.sd-wrap:hover .sd-status,.sd-wrap:hover .acc .acc-label,.sd-wrap:hover .acc .acc-badge,.sd-wrap:hover .acc .acc-count,.sd-wrap:hover .plan-item,.sd-wrap:hover .hist-date-item .hd-date,.sd-wrap:hover .hist-date-item .hd-stats,.sd-wrap:hover .today-stat-row,.sd-wrap:hover .bt-item .bt-title,.sd-wrap:hover .bt-item .bt-meta,.sd-wrap:hover .doc-item .doc-title,.sd-wrap:hover .sd-footer{display:flex;display:block}
  .sd-wrap:hover .acc-body{max-height:900px!important}
  .main{padding:0 10px 40px}
  

  
  .detail-grid{grid-template-columns:1fr}
.detail-grid-4{grid-template-columns:1fr}
  table.y-table{font-size:11px}
  table.y-table thead th,table.y-table tbody td{padding:6px 6px}
}

/* === V4.0 Card Redesign === */
.card{background:rgba(16,22,42,.78);border:1px solid rgba(255,255,255,.06);border-radius:10px;margin-bottom:10px;cursor:pointer;transition:all .2s ease;user-select:none;box-shadow:0 2px 8px rgba(0,0,0,.35);overflow:hidden}
.card.rt-hit{background:rgba(28,20,26,.78);border-color:rgba(239,83,80,.12)}
.card.rt-miss{background:rgba(18,20,28,.78)}
.card.expanded{background:rgba(22,30,55,.82);border-color:rgba(0,229,255,.15);box-shadow:0 2px 0 rgba(0,229,255,.12),0 6px 20px rgba(0,0,0,.3)}
.card:hover{background:rgba(35,44,76,.88);border-color:rgba(0,229,255,.12);box-shadow:0 2px 0 rgba(0,229,255,.1),0 6px 20px rgba(0,0,0,.3)}

/* Collapsed state - unified grid layout */
.grid-layout-row{display:grid;grid-template-columns:80px 130px 1.8fr 2.5fr 1.5fr 100px 100px 28px;align-items:center;padding:0 14px;gap:8px;min-width:0}
.match-row{height:62px}
.match-table-header{padding:5px 18px 7px;font-size:14px;color:#A0AEC0;font-weight:700;text-transform:uppercase;letter-spacing:.5px;font-family:var(--mono);background:rgba(255,255,255,.04);border-bottom:1px solid var(--bd)}

/* Grid column classes (shared by header and cards) */
.grid-col-id{font-family:var(--mono);color:#CBD5E0;font-weight:500;text-align:center;letter-spacing:.5px;font-size:15px}
.grid-col-time{font-family:var(--mono);color:#CBD5E0;font-weight:500;white-space:nowrap;letter-spacing:.3px;font-size:16px;text-align:center;padding:0 10px}

/* Matchup container: centered flex for teams around VS */
.matchup-container{display:flex;align-items:center;justify-content:center;gap:8px;width:100%;min-width:0}
.grid-col-match .tname{flex:1;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;font-size:17px;font-weight:700;color:var(--t1);text-shadow:0 0 12px rgba(232,237,245,.05);letter-spacing:.3px}
.grid-col-match .tname.home{text-align:right;flex:1;min-width:40px}
.grid-col-match .tname.away{text-align:left;flex:1;min-width:40px}
.league-tag{background:transparent;color:#CBD5E0;font-size:12px;padding:2px 8px;border-radius:4px;white-space:nowrap;font-weight:500;flex-shrink:0;border:1px solid rgba(203,213,224,.15);font-family:var(--mono)}
.grid-col-match{display:flex;align-items:center;justify-content:center;min-width:0}
.grid-col-league{display:flex;align-items:center;justify-content:center;min-width:0}
.grid-col-dir{text-align:center}
.grid-col-score{width:80px;flex-shrink:0;display:flex;align-items:center;justify-content:center;gap:0}
#todayMatches .grid-col-score{margin-left:auto;margin-right:-6px}
.grid-col-hit{text-align:center;display:flex;align-items:center;justify-content:center;min-width:0}
.grid-col-hit .tag{display:inline-block;font-size:13px;font-weight:700;padding:3px 12px;border-radius:5px;letter-spacing:.5px}
.grid-col-hit .tag.hit{background:rgba(0,230,118,.14);border:1px solid rgba(0,230,118,.22);color:#00e676;text-shadow:0 0 10px rgba(0,230,118,.4)}
.grid-col-hit .tag.miss{background:rgba(229,62,62,.14);border:1px solid rgba(229,62,62,.22);color:#ff5252;text-shadow:0 0 10px rgba(229,62,62,.3)}

/* Score wrapper: center num + grade */
.score-wrapper{display:flex;align-items:center;justify-content:center;gap:5px}
.score-wrapper .num{font-size:20px;font-weight:800;color:var(--t1);font-family:var(--mono);line-height:1;text-shadow:0 0 6px rgba(160,200,255,.35),0 0 16px rgba(160,200,255,.12)}
.score-wrapper .grade{font-size:13px;font-weight:700;padding:2px 7px;border-radius:4px;line-height:1.4}
.score-wrapper .grade.s{color:#4ade80;background:rgba(0,230,118,.08);border:1px solid rgba(0,230,118,.15);text-shadow:0 0 10px rgba(0,230,118,.35)}
.score-wrapper .grade.a{color:#60a5fa;background:rgba(96,165,250,.06);border:1px solid rgba(96,165,250,.12);text-shadow:0 0 10px rgba(96,165,250,.35)}
.score-wrapper .grade.b{color:#fbbf24;background:rgba(251,191,36,.06);border:1px solid rgba(251,191,36,.12);text-shadow:0 0 10px rgba(251,191,36,.35)}
.score-wrapper .grade.c{color:rgba(100,116,139,.6);background:transparent;border:1px solid rgba(100,116,139,.1)}
.grid-col-expand{width:28px;flex-shrink:0;text-align:center;font-size:12px;color:#64748b;cursor:pointer;transition:transform .3s}
.card.expanded .grid-col-expand{transform:rotate(180deg)}

/* Team names inside grid-col-match */


/* VS badge (capsule style) */
.vs-badge{font-weight:700;color:#64748b;font-size:0.85em;display:inline-flex;align-items:center;justify-content:center;width:60px;flex-shrink:0;line-height:1}



/* dir-badge (prediction) */
.grid-col-dir .dir-badge{display:inline-block;font-size:14px;font-weight:700;padding:4px 12px;border-radius:6px;background:rgba(0,229,255,.04);border:1px solid rgba(0,229,255,.1);color:rgba(0,229,255,.8);letter-spacing:.5px}
.grid-col-dir .dir-badge.win{background:rgba(229,62,62,.18);border-color:rgba(229,62,62,.3);color:#ef5350;text-shadow:0 0 8px rgba(239,83,80,.25)}
.grid-col-dir .dir-badge.lose{background:rgba(56,161,105,.18);border-color:rgba(56,161,105,.3);color:#00e676;text-shadow:0 0 8px rgba(0,230,118,.25)}
.grid-col-dir .dir-badge.draw{background:rgba(96,165,250,.15);border-color:rgba(96,165,250,.25);color:#60a5fa;text-shadow:0 0 8px rgba(96,165,250,.25)}

/* Score + grade */







/* Expanded content base */
.expanded-content{display:none;border-top:1px solid rgba(0,229,255,.06);padding:12px 18px 14px;animation:fadeIn .3s ease}
.card.expanded .expanded-content{display:block}

/* Row 1: Prediction pills */
.exp-pill-row{display:flex;gap:10px;margin-bottom:14px}
.exp-pill{flex:1;background:rgba(12,16,33,.5);border:1px solid rgba(0,229,255,.06);border-radius:999px;padding:8px 14px;display:flex;align-items:center;gap:6px;font-size:13px;color:var(--t1);font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.exp-pill .pill-icon{font-size:15px;flex-shrink:0}
.exp-pill .pill-label{color:#94a3b8;font-weight:500;flex-shrink:0}
.exp-pill .pill-value{font-family:var(--mono);color:var(--t1);overflow:hidden;text-overflow:ellipsis}

/* Row 2: Three-column grid */
.exp-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px}
.exp-a,.exp-b{min-width:0}
.exp-c{min-width:0;display:flex;flex-direction:column;gap:6px}

/* Chart boxes inside expanded */
.exp-a .chart-box,.exp-b .chart-box{background:rgba(12,16,33,.4);border:1px solid rgba(0,229,255,.05);border-radius:8px;padding:8px 10px 10px;width:100%}
.exp-a .chart-box .ch-title,.exp-b .chart-box .ch-title{font-size:11px;font-weight:600;color:rgba(0,229,255,.65);margin-bottom:4px;letter-spacing:.3px;font-family:var(--mono);text-transform:uppercase}
.exp-a .chart-box .ch-sub,.exp-b .chart-box .ch-sub{display:flex;gap:12px;font-size:11px;margin-bottom:4px}
.exp-a .chart-box .ch-sub .delta{color:#fbbf24;font-weight:600;font-family:var(--mono)}
.exp-a .chart-box .ch-sub .doi{color:#10b981;font-weight:600;font-family:var(--mono)}
.chart-svg-wrap{width:100%}
.chart-svg-wrap svg{display:block;width:100%;max-width:300px;height:auto}
.legend-wrap{display:flex;gap:10px;justify-content:flex-end;margin-bottom:2px}
.legend-item{display:flex;align-items:center;gap:3px;font-size:10px;color:#94a3b8}
.legend-item .dot{width:7px;height:7px;border-radius:2px}

/* C column: Vertical analysis items */
.exp-c .analysis-item{background:rgba(12,16,33,.35);border:1px solid rgba(0,229,255,.04);border-radius:8px;padding:7px 10px;display:flex;flex-direction:column;justify-content:center}
.exp-c .analysis-item .ai-head{display:flex;align-items:center;gap:5px;margin-bottom:2px}
.exp-c .analysis-item .ai-head .ai-icon{font-size:14px;flex-shrink:0}
.exp-c .analysis-item .ai-head .ai-label{font-size:11px;font-weight:600;color:rgba(0,229,255,.75);letter-spacing:.2px}
.exp-c .analysis-item .ai-body{font-size:13px;font-weight:600;color:#f1f5f9;font-family:var(--mono)}
.exp-c .analysis-item .ai-body-muted{font-size:11px;color:#94a3b8;line-height:1.4;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}

/* Entrance animation */
@keyframes fadeIn{from{opacity:0;transform:translateY(-4px)}to{opacity:1;transform:translateY(0)}}
@keyframes cardIn{from{opacity:0;transform:translateY(4px)}to{opacity:1;transform:translateY(0)}}
.card{animation:cardIn .2s ease both}
.card:nth-child(2){animation-delay:.03s}
.card:nth-child(3){animation-delay:.06s}
.card:nth-child(4){animation-delay:.09s}
.card:nth-child(5){animation-delay:.12s}
.card:nth-child(6){animation-delay:.15s}

/* Responsive: < 768px */
@media(max-width:768px){
  .grid-layout-row{grid-template-columns:36px 60px 1.2fr 2fr 70px 50px 50px 24px;padding:0 8px}
  .match-row{height:52px}
  .match-table-header{padding:4px 10px 6px;font-size:9px}
  .grid-col-id{font-size:11px}
  .grid-col-time{font-size:12px}
  .vs-badge{font-size:0.8em;width:40px}
  .grid-col-match .tname{font-size:14px}
  .grid-col-dir .dir-badge{font-size:11px;padding:2px 8px}
  .score-wrapper .num{font-size:16px}
  .score-wrapper .grade{font-size:10px}
  .league-tag{font-size:10px;padding:1px 5px}
  .exp-pill-row{flex-direction:column;gap:6px}
  .exp-pill{font-size:12px;padding:6px 12px}
  .exp-grid{grid-template-columns:1fr;gap:8px}
  .exp-c .analysis-item{padding:7px 10px}
  .expanded-content{padding:10px 12px 12px}
}
@media(max-width:640px){
  .grid-layout-row{grid-template-columns:30px 45px 1fr 2fr 50px 40px 40px 20px;padding:0 6px}
  .match-row{height:48px}
  .match-table-header{font-size:8px;padding:3px 8px 5px}
  .grid-col-id{font-size:10px}
  .grid-col-time{font-size:11px}
  .vs-badge{font-size:0.7em;width:30px}
  .grid-col-match .tname{font-size:13px}
  .grid-col-dir .dir-badge{font-size:10px;padding:1px 6px}
  .score-wrapper .num{font-size:14px}
  .score-wrapper .grade{font-size:9px}
  .exp-pill-row{gap:4px}
}
/* === End V4.0 Card CSS === */
/* === Futuristic data terminal accents === */
.sd-title{text-shadow:0 0 18px rgba(0,229,255,.12)}
.today-date{text-shadow:0 0 10px rgba(0,230,118,.15)}
.status-dot{box-shadow:0 0 6px rgba(0,230,118,.3)}
.chart-box .ch-sub .doi{color:var(--cyan);text-shadow:0 0 6px rgba(0,229,255,.2)}
.chart-box .ch-sub .delta{color:var(--amber);text-shadow:0 0 6px rgba(251,191,36,.15)}
.analysis-item .ai-head .ai-icon{color:var(--cyan)}
/* Card row divider - fade effect */

.card:hover .match-row{box-shadow:0 1px 0 rgba(0,229,255,.04)}
/* Subtle entrance */
@keyframes cardIn{from{opacity:0;transform:translateY(4px)}to{opacity:1;transform:translateY(0)}}
.card{animation:cardIn .2s ease both}
.card:nth-child(2){animation-delay:.03s}
.card:nth-child(3){animation-delay:.06s}
.card:nth-child(4){animation-delay:.09s}
.card:nth-child(5){animation-delay:.12s}
.card:nth-child(6){animation-delay:.15s}
/* Selection highlight */
::selection{background:rgba(0,229,255,.15);color:var(--t1)}

/* ============================================
   WC Calendar Grid Layout (йҮҚжһ„)
   ============================================ */
.wc-calendar-wrap{width:100%;max-width:100%;overflow:hidden}
.wc-cal-toolbar{display:flex;align-items:center;justify-content:space-between;padding:8px 14px;margin-bottom:8px;flex-wrap:wrap;gap:8px}
.calt-left{display:flex;align-items:center;gap:12px}
.calt-month-nav{display:flex;align-items:center;gap:6px;background:rgba(255,255,255,.03);border:1px solid var(--bd);border-radius:6px;padding:2px}
.calt-nav-prev,.calt-nav-next{background:none;border:none;color:var(--t2);font-size:16px;cursor:pointer;padding:4px 10px;border-radius:4px;transition:all .15s;line-height:1}
.calt-nav-prev:hover,.calt-nav-next:hover{background:rgba(251,191,36,.1);color:var(--gold)}
.calt-month-label{font-size:15px;font-weight:700;color:var(--t1);padding:0 8px;min-width:80px;text-align:center}
.calendar-header{display:flex;align-items:center;gap:12px;flex-wrap:wrap;flex:1}

/* 7-column grid */
.wc-cal-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:8px;padding:4px}

/* Day-of-week header */
.wc-cal-day-head{text-align:center;font-size:11px;font-weight:700;color:var(--t3);padding:6px 2px;letter-spacing:.5px;border-bottom:1px solid var(--bd);margin-bottom:2px}

/* Day cell (card) */
.wc-cal-day{background:rgba(255,255,255,.04);border:1px solid var(--bd);border-radius:8px;padding:6px 6px 4px;min-height:140px;max-height:320px;cursor:pointer;transition:all .15s;display:flex;flex-direction:column;gap:2px;overflow-y:auto}
.wc-cal-day:hover{border-color:rgba(251,191,36,.25);background:rgba(251,191,36,.04)}
.wc-cal-day.other-month{background:transparent;border-color:transparent;cursor:default;min-height:0}
.wc-cal-day.today{border-color:rgba(251,191,36,.35);background:rgba(251,191,36,.06);box-shadow:0 0 0 1px rgba(251,191,36,.15)}
.wc-cal-day.has-matches{background:rgba(255,255,255,.05)}
.wc-cal-day.has-matches:hover{background:rgba(251,191,36,.06)}

/* Day number */
.cday-num{font-size:13px;font-weight:700;color:var(--t2);line-height:1;margin-bottom:2px}
.wc-cal-day.today .cday-num{color:var(--gold)}
.today-badge{display:inline-block;font-size:9px;font-weight:700;color:#080b14;background:var(--gold);padding:0 6px;border-radius:4px;margin-left:5px;line-height:16px;vertical-align:middle;letter-spacing:.3px}

/* Group badges row */
.cday-badges{display:flex;flex-wrap:wrap;gap:2px;margin-bottom:2px}
.cday-badge{font-size:9px;color:var(--gold);background:rgba(251,191,36,.1);padding:0 5px;border-radius:3px;line-height:16px;font-weight:600;letter-spacing:.3px}

/* Match line inside card */
.cday-match{font-size:10px;color:var(--t2);line-height:1.3;padding:1px 0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.cday-match .cdm-time{color:var(--t3);margin-right:3px;font-family:var(--mono);font-size:9px}

/* More indicator */
.cday-more{font-size:9px;color:var(--t3);padding:1px 0;font-weight:600}

/* Modal: full-screen overlay for day detail */
.modal-overlay{position:fixed;z-index:9000;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,.65);backdrop-filter:blur(6px);-webkit-backdrop-filter:blur(6px);display:flex;align-items:center;justify-content:center;animation:fadeIn .2s ease}
@keyframes fadeIn{from{opacity:0}to{opacity:1}}
.modal-box{background:var(--surface);border:1px solid var(--bd);border-radius:12px;width:90%;max-width:520px;max-height:85vh;display:flex;flex-direction:column;box-shadow:0 12px 48px rgba(0,0,0,.5);animation:slideUp .25s ease}
@keyframes slideUp{from{opacity:0;transform:translateY(24px)}to{opacity:1;transform:translateY(0)}}
.modal-head{display:flex;align-items:center;justify-content:space-between;padding:16px 20px;border-bottom:1px solid var(--bd)}
.modal-title{font-size:16px;font-weight:700;color:var(--t1)}
.modal-close{background:none;border:none;color:var(--t3);font-size:18px;cursor:pointer;width:32px;height:32px;border-radius:6px;display:flex;align-items:center;justify-content:center;transition:all .15s}
.modal-close:hover{background:rgba(255,255,255,.08);color:var(--t1)}
.modal-body{padding:12px 20px 20px;overflow-y:auto;flex:1}
.modal-match{background:rgba(255,255,255,.03);border:1px solid var(--bd);border-radius:8px;padding:10px 14px;margin-bottom:8px;transition:all .15s}
.modal-match:hover{background:rgba(255,255,255,.06);border-color:rgba(251,191,36,.15)}
.modal-match:last-child{margin-bottom:0}
.mm-row1{display:flex;align-items:center;gap:8px;margin-bottom:4px}
.mm-time{font-family:var(--mono);font-size:12px;color:var(--t3);font-weight:600}
.mm-group{font-size:10px;color:var(--gold);background:rgba(251,191,36,.1);padding:1px 7px;border-radius:4px;font-weight:600}
.mm-row2{display:flex;align-items:center;gap:8px;margin-bottom:4px}
.mm-home{font-size:14px;font-weight:600;color:var(--t1);flex:1;text-align:right}
.mm-vs{font-size:11px;color:var(--t3);font-weight:700;padding:0 4px}
.mm-away{font-size:14px;font-weight:600;color:var(--t1);flex:1}
.mm-row3{font-size:11px;color:var(--t3)}
.mm-venue{padding:0 2px}
.cday-empty-hint{font-size:10px;color:var(--t3);padding:4px 0;text-align:center}

/* Responsive */
@media(max-width:768px){
  .wc-cal-grid{gap:4px;padding:2px}
  .wc-cal-day{min-height:160px;padding:4px;border-radius:6px}
  .cday-num{font-size:11px}
  .cday-match{font-size:9px}
  .cday-badge{font-size:8px;padding:0 4px;line-height:14px}
  .wc-cal-day-head{font-size:10px;padding:4px 1px}
  .calt-month-label{font-size:13px;min-width:60px}
  
}
@media(max-width:480px){
  .wc-cal-grid{gap:3px}
  .wc-cal-day{min-height:120px;padding:3px;border-radius:4px}
  .cday-num{font-size:10px}
  .cday-match{font-size:8px;white-space:normal;line-height:1.2}
  .cday-badge{font-size:7px}
  .wc-cal-day-head{font-size:9px}
}

/* ========= HOME - COMMAND CENTER ========= */
.hcc-container{position:relative;width:100%;min-height:calc(100vh - 0px);display:flex;align-items:center;justify-content:center;overflow:hidden;padding:20px;background:radial-gradient(ellipse at 50% 40%,rgba(0,229,255,.03) 0%,transparent 70%)}
.hcc-bg-canvas{position:absolute;inset:0;overflow:hidden;pointer-events:none;z-index:0}
.hcc-particles{position:absolute;inset:0;z-index:1;pointer-events:none}
.hcc-glow-orb{position:absolute;width:600px;height:600px;border-radius:50%;filter:blur(120px);opacity:.12;animation:hcc-float 10s ease-in-out infinite}
.hcc-glow-orb.o1{background:var(--cyan);top:-150px;right:-80px;animation-delay:0s}
.hcc-glow-orb.o2{background:var(--gold);bottom:-200px;left:-120px;animation-delay:-5s;width:500px;height:500px;opacity:.08}
@keyframes hcc-float{0%,100%{transform:translateY(0) scale(1)}50%{transform:translateY(-40px) scale(1.08)}}
.hcc-radar-sweep{position:absolute;width:800px;height:800px;top:50%;left:50%;transform:translate(-50%,-50%);border-radius:50%;background:conic-gradient(from 0deg,transparent 60%,rgba(0,229,255,.02) 80%,rgba(0,229,255,.06) 95%,rgba(0,229,255,.08) 100%);animation:hcc-sweep 8s linear infinite;z-index:1}
@keyframes hcc-sweep{0%{transform:translate(-50%,-50%) rotate(0deg)}100%{transform:translate(-50%,-50%) rotate(360deg)}}
.hcc-radar-ring{position:absolute;width:600px;height:600px;border:1px solid rgba(0,229,255,.05);border-radius:50%;top:50%;left:50%;transform:translate(-50%,-50%);animation:hcc-ring-pulse 4s ease-in-out infinite;z-index:1}
.hcc-radar-ring:nth-child(2){width:400px;height:400px;animation-delay:-1s}
.hcc-radar-ring:nth-child(3){width:200px;height:200px;animation-delay:-2s}
@keyframes hcc-ring-pulse{0%,100%{border-color:rgba(0,229,255,.05);transform:translate(-50%,-50%) scale(1)}50%{border-color:rgba(0,229,255,.12);transform:translate(-50%,-50%) scale(1.05)}}
.hcc-grid-lines{position:absolute;inset:0;background-image:linear-gradient(rgba(0,229,255,.015) 1px,transparent 1px),linear-gradient(90deg,rgba(0,229,255,.015) 1px,transparent 1px);background-size:50px 50px;mask-image:radial-gradient(ellipse at center,black 35%,transparent 72%)}
.hcc-corner-bracket{position:absolute;z-index:2;width:60px;height:60px;border-color:rgba(0,229,255,.12);border-style:solid;border-width:0;opacity:.6;pointer-events:none}
.hcc-corner-bracket.tl{top:30px;left:30px;border-top-width:1px;border-left-width:1px}
.hcc-corner-bracket.tr{top:30px;right:30px;border-top-width:1px;border-right-width:1px}
.hcc-corner-bracket.bl{bottom:30px;left:30px;border-bottom-width:1px;border-left-width:1px}
.hcc-corner-bracket.br{bottom:30px;right:30px;border-bottom-width:1px;border-right-width:1px}
.hcc-center{position:relative;z-index:3;display:flex;flex-direction:column;align-items:center;gap:40px;max-width:900px;width:100%}
.hcc-sysbar{display:flex;align-items:center;gap:24px;padding:8px 20px;background:rgba(0,229,255,.03);border:1px solid rgba(0,229,255,.06);border-radius:20px;font-size:10px;font-family:var(--mono);color:var(--t3);letter-spacing:.5px;text-transform:uppercase;backdrop-filter:blur(8px)}
.hcc-sysbar .hsb-dot{width:5px;height:5px;border-radius:50%;background:var(--green);flex-shrink:0;box-shadow:0 0 6px rgba(0,230,118,.4);animation:pulse 2s infinite}
.hcc-sysbar .hsb-item{display:flex;align-items:center;gap:6px}
.hcc-sysbar .hsb-val{color:var(--cyan);font-weight:600}
.hcc-countdown{text-align:center}
.hcc-countdown-title{font-size:12px;color:var(--t3);letter-spacing:5px;text-transform:uppercase;font-weight:500;margin-bottom:28px;font-family:var(--mono)}
.hcc-countdown-title span{color:var(--gold);background:rgba(251,191,36,.08);padding:3px 14px;border-radius:20px;border:1px solid rgba(251,191,36,.12)}
.hcc-clock{display:flex;align-items:center;justify-content:center;gap:8px}
.hcc-clock-unit{display:flex;flex-direction:column;align-items:center;min-width:110px}
.hcc-clock-digits{font-size:120px;font-weight:700;font-family:var(--mono);color:#fff;line-height:1;letter-spacing:4px;text-shadow:0 0 20px rgba(0,229,255,.2),0 0 60px rgba(0,229,255,.1),0 0 120px rgba(0,229,255,.05)}
.hcc-clock-digits.cyan{color:var(--cyan);text-shadow:0 0 30px rgba(0,229,255,.3),0 0 80px rgba(0,229,255,.12),0 0 160px rgba(0,229,255,.06)}
.hcc-clock-digits.gold{color:var(--gold);text-shadow:0 0 30px rgba(251,191,36,.3),0 0 80px rgba(251,191,36,.12),0 0 160px rgba(251,191,36,.06)}
.hcc-clock-digits.green{color:var(--green);text-shadow:0 0 30px rgba(0,230,118,.3),0 0 80px rgba(0,230,118,.12),0 0 160px rgba(0,230,118,.06)}
.hcc-clock-label{font-size:10px;color:#475569;letter-spacing:3px;text-transform:uppercase;margin-top:8px;font-weight:600;font-family:var(--mono)}
.hcc-clock-sep{font-size:80px;font-weight:200;color:rgba(148,163,184,.15);font-family:var(--mono);line-height:1;padding:0 6px;margin-top:-16px}
.hcc-match-card{width:100%;max-width:580px;background:rgba(12,18,34,.65);border:1px solid rgba(0,229,255,.08);border-radius:20px;padding:24px 28px;backdrop-filter:blur(20px);box-shadow:0 8px 40px rgba(0,0,0,.4),inset 0 1px 0 rgba(255,255,255,.04);position:relative;cursor:pointer;overflow:hidden;transition:all .4s ease}
.hcc-match-card::before{content:"";position:absolute;inset:-1px;border-radius:20px;padding:1px;background:linear-gradient(135deg,rgba(0,229,255,.2),transparent 40%,transparent 60%,rgba(251,191,36,.15));-webkit-mask:linear-gradient(#fff 0 0) content-box,linear-gradient(#fff 0 0);-webkit-mask-composite:xor;mask-composite:exclude;opacity:0;transition:opacity .6s ease}
.hcc-match-card:hover::before{opacity:1}
.hcc-match-card:hover{border-color:rgba(0,229,255,.15);box-shadow:0 12px 56px rgba(0,0,0,.5),0 0 32px rgba(0,229,255,.06)}
.hcc-mc-label{text-align:center;font-size:9px;color:var(--t3);letter-spacing:4px;text-transform:uppercase;font-weight:600;margin-bottom:18px;font-family:var(--mono)}
.hcc-mc-teams{display:flex;align-items:center;justify-content:center;gap:20px}
.hcc-mc-team{display:flex;flex-direction:column;align-items:center;gap:10px;flex:1}
.hcc-mc-flag{width:64px;height:44px;border-radius:6px;object-fit:contain;box-shadow:0 4px 12px rgba(0,0,0,.5);border:1px solid rgba(255,255,255,.1);transition:transform .3s ease}
.hcc-mc-team:hover .hcc-mc-flag{transform:scale(1.05)}
.hcc-mc-team-name{font-size:20px;font-weight:700;color:var(--t1);letter-spacing:1px}
.hcc-mc-vs{display:flex;align-items:center;justify-content:center;flex-shrink:0;width:52px;height:52px;border-radius:50%;background:rgba(0,229,255,.06);border:1px solid rgba(0,229,255,.15);font-size:14px;font-weight:800;color:var(--cyan);letter-spacing:1px;font-family:var(--mono);text-shadow:0 0 16px rgba(0,229,255,.25);position:relative}
.hcc-mc-vs::after{content:"";position:absolute;width:1px;height:40px;background:rgba(0,229,255,.08);top:50%;left:50%;transform:translate(-50%,-50%)}
.hcc-mc-info{text-align:center;margin-top:16px;font-size:11px;color:var(--t3);letter-spacing:.5px;padding-top:14px;border-top:1px solid rgba(255,255,255,.04);display:flex;align-items:center;justify-content:center;gap:8px}
.hcc-mc-info .hcc-mc-venue-icon{font-size:13px}
.hcc-empty{position:relative;z-index:1;display:flex;flex-direction:column;align-items:center;gap:24px;padding:60px 20px;text-align:center}
.hcc-empty-icon{font-size:64px}
.hcc-empty-text{font-size:18px;color:var(--t3)}
@media(max-width:768px){
  .hcc-clock{gap:4px}
  .hcc-clock-unit{min-width:55px}
  .hcc-clock-digits{font-size:48px;letter-spacing:1px}
  .hcc-clock-sep{font-size:32px;padding:0 2px;margin-top:-10px}
  .hcc-clock-label{font-size:8px;letter-spacing:1px}
  .hcc-match-card{padding:16px;max-width:100%}
  .hcc-mc-flag{width:44px;height:30px}
  .hcc-mc-team-name{font-size:16px}
  .hcc-countdown-title{font-size:10px;letter-spacing:3px}
  .hcc-center{gap:28px}
  .hcc-sysbar{font-size:8px;padding:5px 12px;gap:12px;flex-wrap:wrap;justify-content:center}
  .hcc-corner-bracket{width:30px;height:30px}
  .hcc-corner-bracket.tl{top:12px;left:12px}
  .hcc-corner-bracket.tr{top:12px;right:12px}
  .hcc-corner-bracket.bl{bottom:12px;left:12px}
  .hcc-corner-bracket.br{bottom:12px;right:12px}
  .hcc-mc-vs{width:40px;height:40px;font-size:12px}
  .hcc-mc-vs::after{height:28px}
}
/* ========= GROUP STANDINGS (REWRITTEN) ========= */

/* main content scrollbar */
.main::-webkit-scrollbar{width:10px}
.main::-webkit-scrollbar-track{background:rgba(0,229,255,.05)}
.main::-webkit-scrollbar-thumb{background:rgba(0,229,255,.5);border-radius:5px;border:2px solid transparent;background-clip:content-box}
.main::-webkit-scrollbar-thumb:hover{background:rgba(0,229,255,.25)}

.gs-wrap{width:100%;padding:20px 24px 40px}
.gs-header{display:flex;align-items:center;gap:12px;margin-bottom:20px}
.gs-header h2{font-size:22px;font-weight:700;color:var(--t1);letter-spacing:1px;text-shadow:0 0 20px rgba(0,229,255,.08)}
.gs-header .gs-bar{flex:1;height:1px;background:linear-gradient(90deg,rgba(0,229,255,.12),transparent)}
.gs-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:20px;align-content:start}
@media(max-width:900px){.gs-grid{grid-template-columns:1fr;gap:16px}}
.gs-card{background:rgba(12,16,33,.5);border:1px solid rgba(0,229,255,.06);border-radius:10px;overflow:hidden;backdrop-filter:blur(8px);transition:border-color .25s}
.gs-card:hover{border-color:rgba(0,229,255,.12)}
.gs-card-title{display:flex;align-items:center;padding:12px 16px;background:linear-gradient(90deg,rgba(0,229,255,.04),transparent);border-bottom:1px solid rgba(0,229,255,.04)}
.gs-card-title .gs-tag{font-size:13px;font-weight:700;color:var(--cyan);letter-spacing:.5px}
.gs-card-title .gs-count{font-size:10px;color:var(--t3);margin-left:auto;font-family:var(--mono);opacity:.4}
.gs-table{width:100%;border-collapse:collapse;table-layout:fixed}
.gs-table thead th{font-size:10px;color:#64748b;font-weight:600;padding:8px 4px;text-align:center;border-bottom:1px solid rgba(255,255,255,.03);background:rgba(0,0,0,.08);letter-spacing:.5px}
.gs-table thead th:first-child{width:28px;padding-left:8px}
.gs-table thead th:nth-child(2){text-align:left;padding-left:12px}
.gs-table thead th:last-child{color:var(--gold);width:36px}
.gs-table tbody td{font-size:12px;color:var(--t1);padding:7px 4px;text-align:center;border-bottom:1px solid rgba(255,255,255,.01);white-space:nowrap}
.gs-table tbody tr:last-child td{border-bottom:none}
.gs-table tbody tr:hover td{background:rgba(0,229,255,.025)}
.gs-td-team{text-align:left!important;padding-left:12px!important;font-weight:600;font-size:13px!important}
.gs-team-inner{display:flex;align-items:center;gap:8px}
.gs-flag{width:20px;height:14px;border-radius:2px;object-fit:contain;flex-shrink:0;box-shadow:0 1px 2px rgba(0,0,0,.3);border:1px solid rgba(255,255,255,.04)}
.gs-rank{display:inline-flex;align-items:center;gap:5px;font-weight:700;font-family:var(--mono);font-size:12px;color:rgba(100,116,139,.5)}
.gs-rank-bar{width:3px;height:14px;border-radius:2px;flex-shrink:0}
.gs-rank-bar.top2{background:#22c55e;box-shadow:0 0 5px rgba(34,197,94,.3)}
.gs-rank-bar.out{background:#ef4444;box-shadow:0 0 5px rgba(239,68,68,.15)}
.gs-rank-bar.other{background:rgba(100,116,139,.08)}
.gs-td-mp,.gs-td-w,.gs-td-d,.gs-td-l,.gs-td-gf,.gs-td-ga{font-family:var(--mono);font-size:11px;color:rgba(148,163,184,.4)}
.gs-td-gd{font-family:var(--mono);font-size:12px;font-weight:600;color:rgba(148,163,184,.3)}
.gs-td-pts{font-weight:800;font-size:17px;font-family:var(--mono);color:var(--gold);text-shadow:0 0 10px rgba(251,191,36,.12)}

/* ========= KNOCKOUT BRACKET ========= */
.br-wrap{position:relative;padding:24px 0;overflow-x:auto;min-height:700px;width:100%}
.br-tree{display:flex;flex-direction:row;justify-content:center;align-items:stretch;position:relative;min-width:1100px;padding:0 20px}
.br-half{display:flex;flex-direction:row;align-items:stretch;position:relative;flex:1}
.br-half.left{flex-direction:row-reverse}
.br-half.right{flex-direction:row}
.br-col{display:flex;flex-direction:column;justify-content:space-around;align-items:center;position:relative;padding:0 8px;flex:1;min-width:100px}
.br-round-label{font-size:9px;color:rgba(0,229,255,.5);letter-spacing:2px;text-transform:uppercase;font-weight:700;text-align:center;margin-bottom:10px;padding:4px 10px;background:rgba(0,0,0,.3);border-radius:4px;border:1px solid rgba(0,229,255,.08);white-space:nowrap;font-family:var(--mono)}
.br-round-label.gold{color:var(--gold);border-color:rgba(251,191,36,.15);background:rgba(251,191,36,.04)}
.br-card{position:relative;background:rgba(10,20,40,.8);border:1px solid rgba(0,255,255,.18);border-radius:8px;padding:8px 14px;margin:5px 0;min-width:130px;max-width:150px;cursor:default;transition:all .25s ease;backdrop-filter:blur(4px);z-index:1}
.br-card:hover{background:rgba(10,20,40,.95);border-color:rgba(0,255,255,.5);box-shadow:0 0 20px rgba(0,229,255,.12)}
.br-card.final{min-width:200px;max-width:220px;padding:16px 20px;border-color:rgba(251,191,36,.35);background:linear-gradient(135deg,rgba(251,191,36,.04),rgba(10,20,40,.85));box-shadow:0 0 30px rgba(251,191,36,.06);animation:brGoldPulse 3s ease-in-out infinite;z-index:2}
.br-card.final:hover{border-color:var(--gold);box-shadow:0 0 50px rgba(251,191,36,.18);transform:scale(1.04)}
@keyframes brGoldPulse{0%,100%{box-shadow:0 0 20px rgba(251,191,36,.04)}50%{box-shadow:0 0 40px rgba(251,191,36,.1)}}
.br-team{display:flex;align-items:center;justify-content:center;gap:8px;font-size:12px;color:var(--t3);font-weight:400;white-space:nowrap;padding:3px 0;letter-spacing:1.5px;font-family:var(--mono);text-transform:uppercase}
.br-team.tbd{animation:brTbdFlash 2s ease-in-out infinite}
@keyframes brTbdFlash{0%,100%{opacity:.4}50%{opacity:.8}}
.br-team.tbd span{font-size:10px;color:rgba(148,163,184,.5)}
.br-vs{font-size:8px;color:rgba(148,163,184,.2);text-align:center;padding:1px 0;font-weight:600;letter-spacing:2px;font-family:var(--mono)}
.br-final-label{font-size:10px;color:var(--gold);letter-spacing:3px;text-transform:uppercase;font-weight:700;text-align:center;margin-bottom:10px;font-family:var(--mono);text-shadow:0 0 10px rgba(251,191,36,.15)}
.br-svg-wrap{position:absolute;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:0}
.br-conn{fill:none;stroke:rgba(0,229,255,.1);stroke-width:1.5;stroke-linejoin:round}
.br-conn.gold{stroke:rgba(251,191,36,.12)}
@media(max-width:768px){
  .br-wrap{padding:12px 0}
  .br-tree{min-width:900px;padding:0 10px}
  .br-col{padding:0 5px;min-width:80px}
  .br-card{min-width:105px;max-width:120px;padding:6px 10px}
  .br-card.final{min-width:160px;max-width:175px;padding:12px 16px}
  .br-team{font-size:11px;letter-spacing:1px}
  .br-round-label{font-size:8px;margin-bottom:6px}
}
/* ====== жҜ”иөӣеҲҶжһҗеҚЎзүҮ ====== */
.ana-wrap{padding:8px 24px}
.ana-date-group{margin-bottom:16px}
.ana-date-label{font-size:13px;font-weight:600;color:var(--gold);padding:6px 10px;margin-bottom:8px;background:rgba(251,191,36,.06);border-radius:6px;display:flex;align-items:center;gap:8px}
.ana-date-label .adl-count{font-size:11px;color:var(--t3);font-weight:400;margin-left:auto}
.ana-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:10px}
.ana-card{background:rgba(16,22,42,.78);border:1px solid rgba(255,255,255,.06);border-radius:10px;padding:12px 14px;cursor:pointer;transition:all .2s ease}
.ana-card:hover{border-color:rgba(0,229,255,.18);background:rgba(20,28,52,.82)}
.ana-card-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:6px}
.ana-num{font-size:11px;font-weight:700;color:var(--cyan);background:rgba(0,229,255,.1);padding:2px 8px;border-radius:4px;font-family:var(--mono)}
.ana-group{font-size:10px;color:var(--t3);background:rgba(255,255,255,.05);padding:2px 7px;border-radius:4px}
.ana-time{font-size:10px;color:var(--t3);font-family:var(--mono)}
.ana-teams{display:flex;align-items:center;justify-content:center;gap:10px;padding:8px 0;border-bottom:1px solid rgba(255,255,255,.04);margin-bottom:8px}
.ana-team{font-size:14px;font-weight:600;color:var(--t1);flex:1;text-align:center;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.ana-vs{font-size:11px;color:var(--t3);flex-shrink:0;padding:0 2px}
.ana-odds{display:grid;grid-template-columns:1fr 1fr;gap:6px;font-size:11px}
.ana-odds-col{background:rgba(12,16,33,.4);border-radius:5px;padding:5px 8px}
.ana-odds-title{font-size:9px;color:var(--t3);margin-bottom:3px;letter-spacing:.5px}
.ana-odds-row{display:flex;gap:6px;justify-content:center}
.ana-odds-item{text-align:center}
.ana-odds-val{color:var(--t1);font-weight:600;font-family:var(--mono);font-size:12px}
.ana-odds-label{font-size:8px;color:var(--t3)}
.ana-odds-handicap{font-size:9px;color:var(--gold);text-align:center;margin-bottom:2px}
.ana-empty{color:var(--t3);font-size:11px;text-align:center;padding:20px}
@media(max-width:600px){.ana-grid{grid-template-columns:1fr}.ana-team{font-size:13px}}

/* ===== Analysis Cards (long format, expandable) ===== */
.ana-card {
  background: rgba(16,22,42,.78);
  border: 1px solid rgba(255,255,255,.06);
  border-radius: 10px;
  margin-bottom: 10px;
  cursor: pointer;
  user-select: none;
  transition: all .2s ease;
  box-shadow: 0 2px 8px rgba(0,0,0,.35);
  overflow: hidden;
}
.ana-card:hover {
  background: rgba(35,44,76,.88);
  border-color: rgba(0,229,255,.12);
  box-shadow: 0 2px 0 rgba(0,229,255,.1), 0 6px 20px rgba(0,0,0,.3);
}
.ana-card.expanded {
  background: rgba(22,30,55,.82);
  border-color: rgba(0,229,255,.15);
  box-shadow: 0 2px 0 rgba(0,229,255,.12), 0 6px 20px rgba(0,0,0,.3);
}
@keyframes anaHigh{0%{box-shadow:0 0 0 0 rgba(251,191,36,.6),0 2px 0 rgba(0,229,255,.12),0 6px 20px rgba(0,0,0,.3)}50%{box-shadow:0 0 24px 8px rgba(251,191,36,.2),0 2px 0 rgba(0,229,255,.12),0 6px 20px rgba(0,0,0,.3)}to{box-shadow:0 2px 0 rgba(0,229,255,.12),0 6px 20px rgba(0,0,0,.3)}}.ana-card.highlight{animation:anaHigh 1.4s ease-out}

.ana-card-top-row {
  display: grid;
  grid-template-columns: 70px 80px 70px 1fr 1.6fr 0.5fr 0.8fr 28px;
  align-items: center;
  padding: 0 14px;
  gap: 8px;
  min-height: 58px;
}


.ana-card-num {
  font-family: var(--mono);
  color: #CBD5E0;
  font-weight: 500;
  text-align: center;
  font-size: 14px;
  letter-spacing: .3px;
}
.ana-card-time {
  font-family: var(--mono);
  color: #CBD5E0;
  font-weight: 500;
  text-align: center;
  font-size: 14px;
  letter-spacing: .3px;
}
.ana-card-group {
  font-size: 12px;
  color: #94a3b8;
  text-align: center;
  font-weight: 500;
  border: 1px solid rgba(203,213,224,.15);
  border-radius: 4px;
  padding: 2px 6px;
  white-space: nowrap;
}

.ana-card-teams {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  min-width: 0;
}
.ana-card-teams .tname {
  font-size: 16px;
  font-weight: 700;
  color: var(--t1);
  text-shadow: 0 0 12px rgba(232,237,245,.05);
  letter-spacing: .3px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.ana-card-teams .tname.home { text-align: right; }
.ana-card-teams .tname.away { text-align: left; }
.ana-card-teams .vs { 
  font-weight: 700; 
  color: #64748b; 
  font-size: .85em;
  flex-shrink: 0;
  width: 36px;
  text-align: center;
}

.ana-card-odds {
  display: flex;
  gap: 6px;
  align-items: center;
  justify-content: center;
  min-width: 0;
}
.ana-card-odds .odds-group {
  display: flex;
  align-items: center;
  gap: 4px;
  background: rgba(12,16,33,.5);
  border-radius: 6px;
  padding: 3px 8px;
  white-space: nowrap;
}
.ana-card-odds .odds-group .og-label {
  font-size: 10px;
  color: #94a3b8;
  font-weight: 500;
  margin-right: 2px;
}
.ana-card-odds .odds-group .og-item {
  font-size: 12px;
  font-weight: 600;
  color: var(--t1);
  font-family: var(--mono);
  padding: 0 3px;
}
.ana-card-odds .odds-group .og-item.og-sp-h { color: #ef5350; }
.ana-card-odds .odds-group .og-item.og-sp-d { color: #60a5fa; }
.ana-card-odds .odds-group .og-item.og-sp-a { color: #4ade80; }
.ana-card-odds .odds-group .og-item:first-child {
  min-width: 20px;
  text-align: center;
}
.ana-card-waiting {
  font-size: 12px;
  color: var(--t3);
  text-align: center;
  grid-column: span 2;
  padding: 4px 8px;
  white-space: nowrap;
}
@media (max-width: 900px) {
  .ana-card-waiting { font-size: 11px; }
}
@media (max-width: 640px) {
  .ana-card-waiting { font-size: 10px; }
}


.ana-card-odds .odds-group .hcp-line {
  font-size: 11px;
  color: #fbbf24;
  font-weight: 600;
  font-family: var(--mono);
  margin-right: 3px;
}
.ana-card-odds .odds-empty {
  font-size: 11px;
  color: #64748b;
  font-style: italic;
}

.ana-card-expand {
  width: 28px;
  text-align: center;
  font-size: 12px;
  color: #64748b;
  transition: transform .3s;
}
.ana-card.expanded .ana-card-expand {
  transform: rotate(180deg);
}

/* Expanded content */
.ana-expanded {
  display: none;
  border-top: 1px solid rgba(0,229,255,.06);
  padding: 14px 18px;
  animation: fadeIn .3s ease;
}
.ana-card.expanded .ana-expanded { display: block; }

.ana-exp-detail-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8px;
}
.ana-exp-detail-cell {
  background: rgba(12,16,33,.4);
  border: 1px solid rgba(0,229,255,.05);
  border-radius: 8px;
  padding: 10px 12px;
}
.ana-exp-detail-cell .dc-label {
  font-size: 11px;
  font-weight: 600;
  color: rgba(0,229,255,.65);
  margin-bottom: 4px;
  letter-spacing: .3px;
  display: flex;
  align-items: center;
  gap: 5px;
}
.ana-exp-detail-cell .dc-value {
  font-size: 14px;
  font-weight: 600;
  color: var(--t1);
  line-height: 1.4;
  font-family: var(--mono);
}
.ana-exp-detail-cell .dc-desc {
  font-size: 12px;
  color: #94a3b8;
  line-height: 1.5;
  margin-top: 2px;
}
.ana-exp-detail-cell.risk {
  background: rgba(239,83,80,.08);
  border-color: rgba(239,83,80,.12);
}
.ana-exp-detail-cell.risk .dc-label { color: #ef5350; }
.ana-exp-detail-cell.risk .dc-desc { color: rgba(255,82,82,.8); }

.ana-exp-odds-detail {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
  margin-bottom: 10px;
}
.ana-exp-odds-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 12px;
}
.ana-exp-odds-table th {
  padding: 5px 8px;
  text-align: center;
  font-weight: 600;
  color: #A0AEC0;
  background: rgba(255,255,255,.04);
  border-bottom: 1px solid rgba(255,255,255,.06);
  font-size: 11px;
}
.ana-exp-odds-table td {
  padding: 6px 8px;
  text-align: center;
  color: var(--t2);
  border-bottom: 1px solid rgba(255,255,255,.015);
  font-family: var(--mono);
  font-weight: 600;
  font-size: 13px;
}
.ana-exp-odds-table td.val-h { color: #ef5350; }
.ana-exp-odds-table td.val-d { color: #60a5fa; }
.ana-exp-odds-table td.val-a { color: #4ade80; }
.ana-exp-odds-table .hcp-label {
  color: #fbbf24;
  font-weight: 600;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(-4px); }
  to { opacity: 1; transform: translateY(0); }
}

/* Animation entrance */
.ana-card {
  animation: cardIn .2s ease both;
}
.ana-card:nth-child(2) { animation-delay: .03s; }
.ana-card:nth-child(3) { animation-delay: .06s; }
.ana-card:nth-child(4) { animation-delay: .09s; }
.ana-card:nth-child(5) { animation-delay: .12s; }
.ana-card:nth-child(6) { animation-delay: .15s; }
.ana-card:nth-child(7) { animation-delay: .18s; }
.ana-card:nth-child(8) { animation-delay: .21s; }

@keyframes cardIn {
  from { opacity: 0; transform: translateY(4px); }
  to { opacity: 1; transform: translateY(0); }
}

/* Date group labels */
.ana-date-group { margin-bottom: 16px; }
.ana-date-label.clickable { cursor: pointer; }
.ana-date-label.clickable:hover { background: rgba(251,191,36,.12); }
.ana-date-arrow { display: inline-block; width: 16px; font-size: 11px; transition: transform .2s; }
.hist-date-nav { display: flex; align-items: center; justify-content: space-between; padding: 8px 10px; margin: 4px 0; border-radius: 6px; cursor: pointer; background: rgba(251,191,36,.06); border-left: 3px solid #fbbf24; transition: background .15s; }
.hist-date-nav:hover { background: rgba(251,191,36,.12); }
.hist-date-label { font-size: 12px; font-weight: 600; color: var(--gold); }
.hist-date-arrow { font-size: 12px; color: var(--gold); opacity: .6; }
.ana-date-label {
  font-size: 14px;
  font-weight: 600;
  color: var(--t2);
  margin-bottom: 10px;
  padding: 0 4px;
  display: flex;
  align-items: center;
  gap: 8px;
}
.ana-date-label .adl-count {
  font-size: 11px;
  color: #64748b;
  font-weight: 400;
}

/* ===== Responsive ===== */
@media (max-width: 900px) {
  .ana-card-top-row {
    grid-template-columns: 50px 60px 55px 1fr 1.3fr 0.4fr 0.6fr 24px;
    padding: 0 10px;
    gap: 6px;
    min-height: 52px;
  }
  .ana-card-num { font-size: 12px; }
  .ana-card-time { font-size: 12px; }
  .ana-card-teams .tname { font-size: 14px; }
  .ana-card-odds .odds-group { padding: 2px 5px; }
  .ana-card-odds .odds-group .og-item { font-size: 11px; }
}
@media (max-width: 640px) {
  .ana-card-top-row {
    grid-template-columns: 36px 50px 45px 1fr 0.9fr 0.3fr 0.5fr 20px;
    padding: 0 8px;
    gap: 4px;
    min-height: 48px;
  }
  .ana-card-num { font-size: 11px; }
  .ana-card-time { font-size: 11px; }
  .ana-card-group { font-size: 10px; padding: 1px 4px; }
  .ana-card-teams .tname { font-size: 13px; }
  .ana-card-teams .vs { width: 24px; font-size: .75em; }
  .ana-card-odds { gap: 4px; }
  .ana-card-odds .odds-group { padding: 2px 4px; }
  .ana-card-odds .odds-group .og-item { font-size: 10px; }
  .ana-exp-detail-grid { grid-template-columns: 1fr; }
  .ana-exp-odds-detail { grid-template-columns: 1fr; }
  .ana-expanded { padding: 10px 12px; }
}


/* ====== Footer / Disclaimer ====== */
.page-footer {
    width: 100%;
    margin-top: 50px;
    padding: 20px;
    text-align: center;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
}
.disclaimer-box p {
    color: #888;
    font-size: 12px;
    text-align: center;
    line-height: 1.6;
    margin: 5px 0;
}
.disclaimer-box .icon {
    color: #ffcc00;
}


/* Reasoning summary */
.exp-reasoning {
    margin-top: 12px;
    padding: 12px 14px;
    background: rgba(12, 16, 33, 0.4);
    border: 1px solid rgba(0, 229, 255, 0.08);
    border-radius: 8px;
}
.exp-reasoning .reasoning-head {
    font-size: 12px;
    font-weight: 600;
    color: var(--cyan);
    margin-bottom: 8px;
}
.exp-reasoning .reasoning-body p {
    font-size: 12px;
    color: var(--t2);
    display: inline;
    margin: 0;
    line-height: 1.7;
}
.exp-reasoning .reasoning-body p:not(:last-child)::after {
    content: " В· ";
    color: var(--t3);
    margin: 0 4px;
}


/* Odds trend chart */
.ana-exp-trend-wrap{margin:10px 14px 8px;background:rgba(0,229,255,.03);border:1px solid rgba(0,229,255,.08);border-radius:6px;padding:10px 12px;}
.aet-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:6px;}
.aet-title{font-size:13px;color:var(--gold);font-weight:600;}
.aet-refresh{background:none;border:1px solid rgba(0,229,255,.12);color:var(--cyan);border-radius:4px;cursor:pointer;font-size:14px;padding:2px 8px;transition:.15s;}
.aet-refresh:hover{background:rgba(0,229,255,.1);border-color:var(--cyan);}
.aet-chart-area{min-height:80px;}
.aet-loading,.aet-empty{text-align:center;color:var(--t3);font-size:12px;padding:20px 0;}
.aet-svg{width:100%;max-width:640px;height:auto;display:block;margin:0 auto;background:rgba(0,0,0,.15);border-radius:4px;}
.aet-chart-title{text-align:center;font-size:11px;color:var(--t2);margin-bottom:6px;}
.aet-legend{display:flex;gap:14px;justify-content:center;margin-top:6px;font-size:11px;color:var(--t2);flex-wrap:wrap;}
.aet-leg-item{display:inline-flex;align-items:center;gap:4px;cursor:default;}
.aet-leg-dot{width:14px;height:2px;border-radius:1.5px;display:inline-block;}

</style>
<body>
<div class="sd-wrap">
    <div class="sd-top">
