          </div>
          <div class="wc-sub-item" onclick="switchNav('bracket')" data-nav="bracket">
            <span class="wsi-icon">рҹҸҹпёҸ</span>
            <span class="wsi-label">ж·ҳжұ°иөӣеҜ№йҳөеӣҫ</span>
          </div>
          <div class="wc-sub-item" onclick="switchNav('odds')" data-nav="odds">
            <span class="wsi-icon">рҹ’°</span>
            <span class="wsi-label">еҶ еҶӣиө”зҺҮиҝҪиёӘ</span>
          </div>
          <div class="wc-sub-item" onclick="switchNav('top')" data-nav="top">
            <span class="wsi-icon">вӯҗ</span>
            <span class="wsi-label">д»Ҡж—ҘзІҫйҖүжҺЁиҚҗ</span>
          </div>
        </div>
      </div>
    </div><div class="acc" id="accHistory">
      <div class="acc-head" onclick="toggleAccordion('accHistory')">
        <span class="acc-arrow">в–¶</span>
        <span class="acc-icon">рҹ“…</span>
        <span class="acc-label">еҺҶеҸІйў„жөӢж•°жҚ®</span>
        <span class="acc-badge" style="background:rgba(0,230,118,.15);color:var(--green)">е®һжҲҳ</span>
      </div>
      <div class="acc-body">
        <div class="acc-body-inner" style="padding:8px 16px 12px">
          <div style="margin-bottom:10px">
            <input type="text" id="historySearch" placeholder="жҗңзҙўж—Ҙжңҹ (YYYY-MM-DD)" style="width:100%;padding:7px 10px;font-size:11px;font-family:var(--sans);background:var(--bg);border:1px solid var(--bd);border-radius:5px;color:var(--t1);outline:none;transition:border-color .15s" oninput="filterHistoryDates(this.value)">
          </div>
          <div id="historyListContainer">
          <div id="historyCompletedMatches"></div>
          <div class="hist-empty" id="historyRestMessage" style="display:none;padding:8px 0;font-size:11px;color:var(--t3);text-align:center;">жҡӮж— жӣҙеӨҡеҺҶеҸІж•°жҚ®</div>
        </div>
          <div id="historyLoadMore" style="display:none;text-align:center;padding:8px 0">
            <button onclick="loadMoreHistory()" style="width:100%;padding:6px 10px;font-size:11px;color:var(--t2);background:rgba(255,255,255,.04);border:1px solid var(--bd);border-radius:5px;cursor:pointer;font-family:var(--sans);transition:all .15s">еҠ иҪҪжӣҙеӨҡ вҶ“</button>
          </div>
        </div>
