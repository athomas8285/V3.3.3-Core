// ====== Populate history sidebar with 06-12 completed matches ======
function renderCompletedHistory(){
  var container = document.getElementById('historyCompletedMatches');
  if(!container) return;
  var h = '<div class="hist-date-nav" onclick="goToHistoryDate()">';
  h += '<span class="hist-date-label">6жңҲ12ж—Ҙ е‘Ёеӣӣ</span>';
  h += '<span class="hist-date-arrow">вҶ’</span>';
  h += '</div>';
  container.innerHTML = h;
  var msg = document.getElementById('historyRestMessage');
  if(msg) msg.style.display = 'none';
}

function goToHistoryDate(){
  switchNav('analysis');
  setTimeout(function(){
    var body = document.querySelector('.ana-date-body');
    if(body){
      body.style.display = '';
      var arrow = document.querySelector('.ana-date-arrow');
      if(arrow) arrow.textContent = 'в–ј';
      body.parentElement.scrollIntoView({behavior:'smooth', block:'start'});
    }
  }, 300);
}
  var ratingIdx = {}, mcIdx = {};
  (__DATA.rating || []).forEach(function(m){ if(m.id) ratingIdx[m.id]=m; });
  (__DATA.mc || []).forEach(function(m){ if(m.id) mcIdx[m.id]=m; });
  var completedScores = {"е‘Ёеӣӣ001":"2-0","е‘Ёеӣӣ002":"2-1"};
  var completedHit = {"е‘Ёеӣӣ001":true,"е‘Ёеӣӣ002":true};
  var matches = [];
  for(var i = 0; i < __DATA.info.length; i++){
    var info = __DATA.info[i];
    var t = info.time || '';
    var dp = t.length >= 10 ? t.slice(0,10) : '';
    if(dp === '2026-06-12') matches.push(info);
  }
  if(matches.length === 0){
    container.innerHTML = '<div class="hist-empty" style="padding:12px;font-size:12px;color:var(--t3);text-align:center;">жҡӮж— е·Із»“жқҹзҡ„жҜ”иөӣ</div>';
    return;
  }
  var h = '';
  for(var i = 0; i < matches.length; i++){
    var info = matches[i];
    var mid = info.id || i;
    var rat = ratingIdx[mid] || {};
    var dir = rat.direction || '';
    var fit = rat.fit_score;
    var rt = rat.rating || '';
    var score = completedScores[mid] || '--';
    var hit = completedHit[mid] || false;
    var home = info.home || '';
    var away = info.away || '';
    var fh = typeof TEAM_FLAGS !== 'undefined' ? (TEAM_FLAGS[home] || '') : '';
    var fa = typeof TEAM_FLAGS !== 'undefined' ? (TEAM_FLAGS[away] || '') : '';
    function flagImg(f){ return f ? '<img class="tf" src="' + f + '" loading="lazy">' : ''; }
    h += '<div class="hist-date-item" style="cursor:default;border-left-color:rgba(0,230,118,.3);background:rgba(0,230,118,.04);">';
    h += '<div style="display:flex;align-items:center;gap:6px;flex:1;min-width:0;">';
    h += flagImg(fh);
    h += '<span style="font-size:12px;font-weight:600;color:var(--t1);white-space:nowrap;">' + home + '</span>';
    h += '<span style="font-size:11px;color:var(--t3);">VS</span>';
    h += flagImg(fa);
    h += '<span style="font-size:12px;font-weight:600;color:var(--t1);white-space:nowrap;">' + away + '</span>';
    h += '</div>';
    h += '<div style="display:flex;align-items:center;gap:5px;flex-shrink:0;">';
    h += '<span style="font-size:13px;font-weight:800;font-family:var(--mono);color:#4ade80;letter-spacing:1px;">' + score + '</span>';
    if(dir){
      var dc = '#60a5fa';
      if(dir.indexOf('и®©')>=0) dc='#ef5350'; else if(dir==='иғң') dc='#4ade80'; else if(dir==='иҙҹ') dc='#ef4444';
      h += '<span style="font-size:10px;color:'+dc+';background:'+dc+'22;border:1px solid '+dc+'44;padding:1px 5px;border-radius:3px;">'+dir+'</span>';
    }
    if(fit !== undefined && fit !== null){
      h += '<span style="font-size:10px;color:var(--t2);font-family:var(--mono);">'+fit.toFixed(1)+'</span>';
    }
    if(rt) h += '<span style="font-size:10px;font-weight:700;color:var(--gold);">'+rt+'</span>';
    if(hit){
      h += '<span style="font-size:9px;padding:2px 6px;border-radius:3px;background:rgba(0,230,118,.15);color:#4ade80;border:1px solid rgba(0,230,118,.25);">е‘Ҫдёӯ</span>';
    } else {
      h += '<span style="font-size:9px;padding:2px 6px;border-radius:3px;background:rgba(239,83,80,.12);color:#ef5350;border:1px solid rgba(239,83,80,.2);">жңӘдёӯ</span>';
    }
    h += '</div></div>';
  }
  container.innerHTML = h;
  // Hide the search results message
  var msg = document.getElementById('historyRestMessage');
  if(msg) msg.style.display = 'none';
}
document.addEventListener('DOMContentLoaded', function(){
  setTimeout(renderCompletedHistory, 200);
});

// жёІжҹ“жҜ”иөӣеҲҶжһҗйЎөйқў

// ???????????? + ?????
function renderAnalysisView(){
  var el = document.getElementById('analysisInner');
  if(!el) return;
  if(typeof __DATA !== 'undefined' && __DATA && __DATA.info && __DATA.info.length > 0){
    renderFromData();
  } else {
    renderFromWC();
  }
  __expandTargetMatch();
}

function renderFromData(){
  var el = document.getElementById('analysisInner');
  if(!el) return;
  var infoList = __DATA.info || [];
  var ratingIdx = {}, mcIdx = {}, ddiIdx = {}, aiIdx = {}, fitIdx = {}, trendIdx = {};
  (__DATA.rating || []).forEach(function(m){ if(m.id) ratingIdx[m.id]=m; });
  (__DATA.mc || []).forEach(function(m){ if(m.id) mcIdx[m.id]=m; });
  (__DATA.ddi || []).forEach(function(m){ if(m.id) ddiIdx[m.id]=m; });
  (__DATA.fit || []).forEach(function(m){ if(m.id && m.fit_score) fitIdx[m.id]=m.fit_score; });
  (__DATA.trend || []).forEach(function(m){ if(m.id) trendIdx[m.id]=m; });
  (__DATA.ai || []).forEach(function(m){ if(m.id) aiIdx[m.id]=m; });

  var h = '<div class="ana-intro" style="padding:8px 4px 12px;color:var(--t2);font-size:13px;border-bottom:1px solid rgba(255,255,255,.04);margin-bottom:12px;">рҹ“Ҡ ' + infoList.length + ' еңәеҲҶжһҗз»“жһң &mdash; зӮ№еҮ»еҚЎзүҮеұ•ејҖиҜҰжғ…</div>';

  var groups = {};
  for(var i = 0; i < infoList.length; i++){
    var info = infoList[i];
    var timeStr = info.time || '';
    var datePart = timeStr.length >= 10 ? timeStr.slice(0,10) : '';
    var parts = datePart.split('-');
    var dateLabel = parts.length === 3 ? parseInt(parts[1],10) + 'жңҲ' + parseInt(parts[2],10) + 'ж—Ҙ' : datePart;
    if(!groups[dateLabel]) groups[dateLabel] = [];
    groups[dateLabel].push(info);
  }
  var dateKeys = Object.keys(groups);
  dateKeys.sort(function(a,b){
    function toNum(s){ var m=s.match(/(\d+)жңҲ(\d+)ж—Ҙ/); return m?parseInt(m[1],10)*100+parseInt(m[2],10):0; }
    return toNum(a)-toNum(b);
  });

  for(var di = 0; di < dateKeys.length; di++){
    var dk = dateKeys[di];
    var ml = groups[dk];
    var is06_12 = (dk === '6жңҲ12ж—Ҙ');
    h += '<div class="ana-date-group">';
    h += '<div class="ana-date-label' + (is06_12 ? ' clickable' : '') + '" onclick="' + (is06_12 ? 'toggleDateGroup(this)' : '') + '">';
    h += (is06_12 ? '<span class="ana-date-arrow">в–¶</span>' : 'рҹ“…') + ' ' + dk + '<span class="adl-count">' + ml.length + ' еңә</span></div>';
    h += '<div class="ana-date-body"' + (is06_12 ? ' style="display:none"' : '') + '>';
    for(var mi = 0; mi < ml.length; mi++){
      var info = ml[mi];
      var infoDatePart = (info.time||'').length >= 10 ? (info.time||'').slice(0,10) : '';
      // 06-12 completed matches

      var mid = info.id || mi;
      var rat = ratingIdx[mid] || {};
      var mc = mcIdx[mid] || {};
      var ddi = ddiIdx[mid] || {};
      var ai = aiIdx[mid] || {};
      var fit = fitIdx[mid] || {};
      var trend = trendIdx[mid] || {};

      var home = info.home || '';
      var away = info.away || '';
      var evt = info.event || '';
      var tm = info.time || '';
      var timeDisplay = tm.length >= 16 ? tm.slice(5,16) : (tm.length >= 5 ? tm : tm);
      var datePart = tm.length >= 10 ? tm.slice(0,10) : '';
      var isPredictable = datePart === '2026-06-13' || datePart === '2026-06-12';
      var dir = rat.direction || '';
      var fit = rat.fit_score;
      var rting = rat.rating || '';
      var ld = mc.lambda_diff !== undefined ? mc.lambda_diff : 0;
      var lambda_h = mc.lambda_h_final || 0;
      var lambda_a = mc.lambda_a_final || 0;
      var phys = mc.physical || {};
      var ddiVals = ddi.ddi || {};
      var s7 = ai.s7_score || 0;
      var s7Reason = ai.s7_reason || '';
      var trapTxt = ai.trap_analysis || '';
      var riskTxt = ai.key_risk || '';
      var tgList = mc.top2_total_goals || [];
      var hfList = mc.top2_half_full || [];
      var scList = mc.top3_scores || [];
      var tgText = tgList.length ? tgList.join(' / ') : '--';
      var hfText = hfList.length ? hfList.join(' / ') : '--';
      var scText = scList.length ? scList.join(' / ') : '--';
      var sp_h = info.sp_home;
      var sp_d = info.sp_draw;
      var sp_a = info.sp_away;
      var hh_w = info.jc_hhad_win;
      var hh_d = info.jc_hhad_draw;
      var hh_l = info.jc_hhad_lose;
      var hcp = info.jc_handicap;
      var hasSp = (sp_h !== null && sp_h !== undefined && sp_h !== '');
      var hcpStr = hcp !== null && hcp !== undefined ? (hcp > 0 ? '+' + hcp : '' + hcp) : '0';

      var dirColor = '#60a5fa';
      if(dir.indexOf('и®©') >= 0) dirColor = '#ef5350';
      else if(dir === 'иғң') dirColor = '#4ade80';
      else if(dir === 'иҙҹ') dirColor = '#ef4444';

      var rtColor = '#60a5fa';
      if(rting === 'S' || rting === 'A') rtColor = '#4ade80';
      else if(rting === 'B') rtColor = '#fbbf24';
      else if(rting === 'C') rtColor = '#ef4444';

      h += '<div class="ana-card" onclick="toggleAnaCard(this)" data-mid="' + mid + '">';
      h += '<div class="ana-card-top-row">';
      h += '<div class="ana-card-num">' + mid + '</div>';
      h += '<div class="ana-card-time" style="font-size:12px;">' + timeDisplay + '</div>';
      h += '<div class="ana-card-group" style="font-size:10px;">' + evt.slice(0,4) + '</div>';
      h += '<div class="ana-card-teams"><span class="tname home">' + home + '</span><span class="vs">VS</span><span class="tname away">' + away + '</span></div>';
      h += '<div class="ana-card-odds" style="flex-direction:column;align-items:flex-start;gap:4px;">';
      if(hasSp){
        h += '<div class="odds-group">';
        h += '<span class="og-item og-sp-h" style="color:var(--t3);font-size:11px;">0</span>';
        h += '<span class="og-item og-sp-h">' + sp_h + '</span>';
        h += '<span class="og-item og-sp-d">' + sp_d + '</span>';
        h += '<span class="og-item og-sp-a">' + sp_a + '</span></div>';
      } else {
        h += '<span class="odds-empty">вҡ жңӘејҖе”®</span>';
      }
      h += '<div class="odds-group">';
      h += '<span class="og-item og-sp-h" style="color:var(--t3);font-size:11px;">' + hcpStr + '</span>';
      h += '<span class="og-item og-sp-h">' + hh_w + '</span>';
      h += '<span class="og-item og-sp-d">' + hh_d + '</span>';
      h += '<span class="og-item og-sp-a">' + hh_l + '</span></div>';
      h += '</div>';
      if(isPredictable){
        h += '<div class="ana-card-odds">';
        if(dir){
          h += '<div class="odds-group" style="background:' + dirColor + '22;border:1px solid ' + dirColor + '44;">';
          h += '<span class="og-item" style="color:' + dirColor + ';font-size:13px;font-weight:700;">' + dir + '</span></div>';
        }
        h += '</div>';
        h += '<div class="ana-card-odds"><div class="odds-group">';
        if(fit !== undefined && fit !== null){
          h += '<span class="og-item" style="font-size:13px;">' + fit.toFixed(1) + '</span>';
        } else {
          h += '<span class="og-item" style="color:#64748b;">--</span>';
        }
        if(rting){
          h += '<span class="og-item" style="color:' + rtColor + ';font-weight:700;font-size:14px;margin-left:4px;">' + rting + '</span>';
        }
        h += '</div></div>';
      } else {
        h += '<div class="ana-card-waiting">зӯүеҫ…йў„жөӢж•°жҚ®</div>';
      }
      h += '<div class="ana-card-expand">в–ј</div>';
      h += '</div>';



            if(isPredictable){
      h += '<div class="ana-expanded">';
      // Pill row
      h += '<div class="exp-pill-row">';
      h += '<div class="exp-pill"><span class="pill-icon">&#9917;</span><span class="pill-label">жҖ»иҝӣзҗғ:</span><span class="pill-value">'+tgText+'</span></div>';
      h += '<div class="exp-pill"><span class="pill-icon">&#128260;</span><span class="pill-label">еҚҠе…Ёеңә:</span><span class="pill-value">'+hfText+'</span></div>';
      h += '<div class="exp-pill"><span class="pill-icon">&#127919;</span><span class="pill-label">жҜ”еҲҶ:</span><span class="pill-value">'+scText+'</span></div>';
      h += '</div>';
      // Three-column grid
      h += '<div class="exp-grid">';
      // A: Lambda chart
      var doi = (ddi.doi !== undefined ? ddi.doi : 0);
      var maxLam = Math.max(lambda_h, lambda_a, 0.5);
      var pMarket = {};
      if(ddi.p_market) pMarket = ddi.p_market;
      else if(ddi.market) pMarket = ddi.market;
      var hcpProb = mc.jc_handicap_prob || {};
      h += '<div class="exp-a"><div class="chart-box"><div class="ch-title">&#955; еҜ№жҜ”</div>';
      h += '<div class="ch-sub"><span class="delta">&#916; '+(ld>=0?'+':'')+ld.toFixed(4)+'</span><span class="doi">DOI '+(doi?doi.toFixed(4):'--')+'</span></div>';
      h += '<div class="chart-svg-wrap"><svg viewBox="0 0 280 150">';
      for(var gi=0;gi<5;gi++){var gy=20+gi*26;h+='<line x1="40" y1="'+gy+'" x2="260" y2="'+gy+'" stroke="#334155" stroke-dasharray="4,4" stroke-width="1"/>';}
      h+='<text x="38" y="24" text-anchor="end" fill="#64748b" font-size="10">'+maxLam.toFixed(1)+'</text>';
      h+='<text x="38" y="50" text-anchor="end" fill="#64748b" font-size="10">'+(maxLam*3/4).toFixed(1)+'</text>';
      h+='<text x="38" y="76" text-anchor="end" fill="#64748b" font-size="10">'+(maxLam/2).toFixed(1)+'</text>';
      h+='<text x="38" y="102" text-anchor="end" fill="#64748b" font-size="10">'+(maxLam/4).toFixed(1)+'</text>';
      h+='<text x="38" y="128" text-anchor="end" fill="#64748b" font-size="10">0.0</text>';
      var lhH=Math.max(3,lambda_h/maxLam*104);var laH=Math.max(3,lambda_a/maxLam*104);
      h+='<rect x="70" y="'+(124-lhH)+'" width="44" height="'+lhH+'" rx="3" fill="#10b981" opacity=".85"/>';
      h+='<text x="92" y="'+(118-lhH)+'" text-anchor="middle" fill="#10b981" font-size="11" font-weight="600">'+lambda_h.toFixed(3)+'</text>';
      h+='<rect x="160" y="'+(124-laH)+'" width="44" height="'+laH+'" rx="3" fill="#ef4444" opacity=".85"/>';
      h+='<text x="182" y="'+(118-laH)+'" text-anchor="middle" fill="#ef4444" font-size="11" font-weight="600">'+lambda_a.toFixed(3)+'</text>';
      h+='<text x="92" y="144" text-anchor="middle" fill="#94a3b8" font-size="11">е…Ҙдё»</text><text x="182" y="144" text-anchor="middle" fill="#94a3b8" font-size="11">е…Ҙе®ў</text></svg></div></div></div>';
      // B: Physical vs Market chart
      var probHome=(hcpProb.home_win!==undefined?hcpProb.home_win:(phys.home_win||0))*100;
      var probDraw=(hcpProb.draw_win!==undefined?hcpProb.draw_win:(phys.draw_win||0))*100;
      var probAway=(hcpProb.away_win!==undefined?hcpProb.away_win:(phys.away_win||0))*100;
      var probTotal=probHome+probDraw+probAway;
      if(probTotal>0){probHome=(probHome/probTotal*100).toFixed(0);probDraw=(probDraw/probTotal*100).toFixed(0);probAway=(probAway/probTotal*100).toFixed(0);}else{probHome=33;probDraw=34;probAway=33;}
      var physHome=(phys.home_win||0)*100;var mktHome=pMarket.home_win!==undefined?(pMarket.home_win*100):physHome;
      var physDraw=Math.max(0,100-physHome-(phys.away_win||0)*100);var mktDraw=pMarket.draw_win!==undefined?(pMarket.draw_win*100):Math.max(0,100-mktHome-(pMarket.away_win||0)*100);
      var physAway=(phys.away_win||0)*100;var mktAway=pMarket.away_win!==undefined?(pMarket.away_win*100):physAway;
      var pmax=Math.max(physHome,mktHome,physDraw,mktDraw,physAway,mktAway,10);
      var pmaxR=Math.ceil(pmax/20)*20+20;
      var bh=function(v){return Math.max(3,v/pmaxR*104);};
      h+='<div class="exp-b"><div class="chart-box"><div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:4px;"><div class="ch-title" style="margin-bottom:0;">зү©зҗҶ vs еёӮеңә</div>';
      h+='<div class="legend-wrap" style="margin-bottom:0;"><div class="legend-item"><span class="dot" style="background:#64748b"></span>зү©зҗҶ</div><div class="legend-item"><span class="dot" style="background:#ef4444"></span>еёӮеңә</div></div></div>';
      h+='<div class="chart-svg-wrap"><svg viewBox="0 0 280 150">';
      for(var gi=0;gi<5;gi++){var gy=20+gi*26;h+='<line x1="40" y1="'+gy+'" x2="280" y2="'+gy+'" stroke="#334155" stroke-dasharray="4,4" stroke-width="1"/>';}
      h+='<text x="38" y="24" text-anchor="end" fill="#64748b" font-size="10">'+pmaxR+'%</text>';
      h+='<text x="38" y="50" text-anchor="end" fill="#64748b" font-size="10">'+(pmaxR*3/4).toFixed(0)+'%</text>';
      h+='<text x="38" y="76" text-anchor="end" fill="#64748b" font-size="10">'+(pmaxR/2).toFixed(0)+'%</text>';
      h+='<text x="38" y="102" text-anchor="end" fill="#64748b" font-size="10">'+(pmaxR/4).toFixed(0)+'%</text>';
      h+='<text x="38" y="128" text-anchor="end" fill="#64748b" font-size="10">0</text>';
      function ba(v,h,col,x){return '<rect x="'+x+'" y="'+(124-h)+'" width="18" height="'+h+'" rx="2" fill="'+col+'" opacity=".7"/><text x="'+(x+9)+'" y="'+(118-h)+'" text-anchor="middle" fill="#94a3b8" font-size="9">'+v+'%</text>';}
      var x=70;h+=ba(physHome.toFixed(0),bh(physHome),"#64748b",x);x=92;h+=ba(mktHome.toFixed(0),bh(mktHome),"#ef4444",x);
      x=130;h+=ba(physDraw.toFixed(0),bh(physDraw),"#64748b",x);x=152;h+=ba(mktDraw.toFixed(0),bh(mktDraw),"#ef4444",x);
      x=190;h+=ba(physAway.toFixed(0),bh(physAway),"#64748b",x);x=212;h+=ba(mktAway.toFixed(0),bh(mktAway),"#ef4444",x);
      h+='<text x="90" y="144" text-anchor="middle" fill="#94a3b8" font-size="11">иғң</text>';
      h+='<text x="150" y="144" text-anchor="middle" fill="#94a3b8" font-size="11">е№і</text>';
      h+='<text x="210" y="144" text-anchor="middle" fill="#94a3b8" font-size="11">иҙҹ</text>';
      h+='</svg></div></div></div>';
      // C: Vertical analysis column
      h+='<div class="exp-c">';
      h+='<div class="analysis-item"><div class="ai-head"><span class="ai-icon">&#8981;</span><span class="ai-label">О»е·®еҖј</span></div><div class="ai-body">'+(ld>=0?'+':'')+ld.toFixed(4)+'</div></div>';
      h+='<div class="analysis-item"><div class="ai-head"><span class="ai-icon" style="color:var(--cyan)">&#8505;&#65039;</span><span class="ai-label">S7иҜҙжҳҺ</span></div><div class="ai-body-muted">'+(s7Reason||(s7>0?'S7иҜ„еҲҶ: '+s7.toFixed(2):'ж— зү№ж®ҠеңәжҷҜ'))+'</div></div>';
      h+='<div class="analysis-item"><div class="ai-head"><span class="ai-icon" style="color:#fbbf24">&#128161;</span><span class="ai-label">иҜұзӣҳеҲҶжһҗ</span></div><div class="ai-body-muted">'+(trapTxt||'ж— ејӮеёёдҝЎеҸ·')+'</div></div>';
      h+='<div class="analysis-item"><div class="ai-head"><span class="ai-icon" style="color:#f59e0b">&#9888;&#65039;</span><span class="ai-label">йЈҺйҷ©жҸҗзӨә</span></div><div class="ai-body-muted">'+(riskTxt||'жЁЎеһӢдҝЎеҸ·жӯЈеёё')+'</div></div>';
      h+='</div></div>';
      // Match analysis - use backend narrative
      h+='<div class="exp-reasoning"><div class="reasoning-head"> жҜ”иөӣи§ЈиҜ»</div><div class="reasoning-body">';
      var preNarr = (__DATA.narratives||{})[mid] || '';
      if(preNarr){
        h += '<p>'+preNarr+'</p>';
      } else if(dir){
        var hPct = (phys.home_win||0)*100;
        var aPct = (phys.away_win||0)*100;
        h += '<p>ж–№еҗ‘'+dir+'пјҲдё»'+hPct.toFixed(0)+'%/е®ў'+aPct.toFixed(0)+'%пјү</p>';
      } else {
        h += '<p>жҡӮж— еҲҶжһҗж•°жҚ®</p>';
      }
      h += '</div></div>';
            // Odds trend chart            // Odds trend chart            // Odds trend chart
      h += '<div class="ana-exp-trend-wrap" data-home="' + home.replace(/"/g,"&quot;") + '" data-away="' + away.replace(/"/g,"&quot;") + '">';
      h += '<div class="aet-header">';
      h += '<span class="aet-title">рҹ“Ҳ иө”зҺҮиө°еҠҝ</span>';
      h += '<button class="aet-refresh" onclick="renderOddsTrend(this.closest(\'.ana-card\'))">вҹі</button>';
      h += '</div>';
      h += '<div class="aet-chart-area"><div class="aet-loading">еҠ иҪҪдёӯ...</div></div>';
      h += '</div>';
h+='</div></div>';} else {
      h += '<div class="ana-expanded" style="padding:20px;text-align:center;color:var(--t3);font-size:13px;">зӯүеҫ…йў„жөӢж•°жҚ®</div></div>';
      }
    }
    h += '</div>';
    h += '</div>';
  }
  el.innerHTML = h;
}


function toggleDateGroup(el){
  if(!el) return;
  var group = el.closest('.ana-date-group');
  if(!group) return;
  var body = group.querySelector('.ana-date-body');
  var arrow = group.querySelector('.ana-date-arrow');
  if(!body) return;
  var isHidden = body.style.display === 'none';
  body.style.display = isHidden ? '' : 'none';
  if(arrow) arrow.textContent = isHidden ? 'в–ј' : 'в–¶';
}
function renderFromWC(){
  var el = document.getElementById('analysisInner');
  if(!el) return;
  var h = '';
  var groups = {};
  for(var i = 0; i < WC_ANALYSIS_DATA.length; i++){
    var m = WC_ANALYSIS_DATA[i];
    if(!groups[m.d]) groups[m.d] = [];
    groups[m.d].push(m);
  }
  var dateKeys = Object.keys(groups);
  dateKeys.sort(function(a,b){
    var ap = a.replace('?','/').replace('?','');
    var bp = b.replace('?','/').replace('?','');
    var ad = new Date('2026/' + ap);
    var bd = new Date('2026/' + bp);
    return ad - bd;
  });
  for(var di = 0; di < dateKeys.length; di++){
    var dk = dateKeys[di];
    var ml = groups[dk];
    h += '<div class="ana-date-group">';
    h += '<div class="ana-date-label">&#x1F4C5; ' + dk + '<span class="adl-count">' + ml.length + ' &#x573A;</span></div>';
    for(var mi = 0; mi < ml.length; mi++){
      var m = ml[mi];
      var glStr = m.gl !== 0 ? (m.gl > 0 ? '+' + m.gl : '' + m.gl) : '0';
      var hasSp = (m.sh !== '-' && m.sh !== '');
      h += '<div class="ana-card" onclick="toggleAnaCard(this)" data-match="' + m.id + '">';
      h += '<div class="ana-card-top-row">';
      h += '<div class="ana-card-num">' + m.id + '</div>';
      h += '<div class="ana-card-time">' + m.t + '</div>';
      h += '<div class="ana-card-group">' + m.g + '&#x7EC4;</div>';
      h += '<div class="ana-card-teams"><span class="tname home">' + m.h + '</span><span class="vs">VS</span><span class="tname away">' + m.a + '</span></div>';
      h += '<div class="ana-card-odds">';
      if(hasSp){
        h += '<div class="odds-group"><span class="og-label">SP</span>';
        h += '<span class="og-item og-sp-h">' + m.sh + '</span>';
        h += '<span class="og-item og-sp-d">' + m.sd + '</span>';
        h += '<span class="og-item og-sp-a">' + m.sa + '</span></div>';
      } else {
        h += '<span class="odds-empty">&#x26A0;&#x65E0;SP</span>';
      }
      h += '</div>';
      h += '<div class="ana-card-odds"><div class="odds-group"><span class="hcp-line">&#x8BA9;' + glStr + '</span>';
      h += '<span class="og-item og-sp-h">' + m.gh + '</span>';
      h += '<span class="og-item og-sp-d">' + m.gd + '</span>';
      h += '<span class="og-item og-sp-a">' + m.ga + '</span></div></div>';
      h += '<div class="ana-card-expand">&#9660;</div></div>';
      h += '<div class="ana-expanded">';
      h += '<div class="ana-exp-odds-detail">';
      h += '<table class="ana-exp-odds-table">';
      h += '<tr><th></th><th>&#x4E3B;</th><th>&#x5E73;</th><th>&#x5BA2;</th></tr>';
      if(hasSp){
        h += '<tr><td><strong>&#x7ADE;&#x5F69;SP</strong></td><td class="val-h">' + m.sh + '</td><td class="val-d">' + m.sd + '</td><td class="val-a">' + m.sa + '</td></tr>';
      } else {
        h += '<tr><td><strong>&#x7ADE;&#x5F69;SP</strong></td><td colspan="3" style="color:#64748b;">&#x65E0;&#x6570;&#x636E;</td></tr>';
      }
      h += '<tr><td><strong>&#x8BA9;&#x7403;SP</strong></td><td class="val-h">' + m.gh + '</td><td class="val-d">' + m.gd + '</td><td class="val-a">' + m.ga + '</td></tr>';
      h += '</table><div class="ana-exp-detail-grid">';
      h += '<div class="ana-exp-detail-cell"><div class="dc-label">&#x1F4C5; &#x6BD4;&#x8D5B;&#x4FE1;&#x606F;</div><div class="dc-desc">' + m.id + ' | ' + m.d + ' ' + m.t + ' | ' + m.g + '&#x7EC4;</div><div class="dc-value" style="margin-top:4px;">' + m.h + ' vs ' + m.a + '</div></div>';
      h += '<div class="ana-exp-detail-cell"><div class="dc-label">&#x1F3B0; &#x8BA9;&#x7403;&#x5206;&#x6790;</div><div class="dc-desc">&#x8BA9;' + glStr + ' | &#x7ADE;&#x5F69;&#x8BA9;&#x7403;SP&#x5C0F;&#x5E45;&#x504F;&#x5411;</div></div>';
      h += '<div class="ana-exp-detail-cell"><div class="dc-label">&#x1F3AF; &#x80DC;&#x8D1F;&#x5206;&#x6790;</div>';
      if(hasSp){
        var shV = parseFloat(m.sh)||0, sdV = parseFloat(m.sd)||0, saV = parseFloat(m.sa)||0;
        var minSp = Math.min(shV, sdV, saV);
        var spHint = shV === minSp ? '&#x4E3B;&#x80DC;SP ' + m.sh : (saV === minSp ? '&#x5BA2;&#x80DC;SP ' + m.sa : '&#x5E73;&#x5C40;SP ' + m.sd);
        h += '<div class="dc-desc">' + spHint + ' &#x6700;&#x4F4E;&#xFF0C;&#x5E02;&#x573A;&#x504F;&#x5411;&#x660E;&#x663E;</div>';
      } else { h += '<div class="dc-desc" style="color:#64748b;">&#x65E0;&#x7ADE;&#x5F69;SP&#x6570;&#x636E;</div>'; }
      h += '</div><div class="ana-exp-detail-cell risk"><div class="dc-label">&#x26A0; &#x98CE;&#x63A7;</div><div class="dc-desc">&#x8D5B;&#x524D;&#x5206;&#x6790;&#x4EC5;&#x4F9B;&#x53C2;&#x8003;</div></div>';
      // D: Odds trend chart
      h += '<div class="ana-exp-trend-wrap" data-home="' + m.h.replace(/"/g,"&quot;") + '" data-away="' + m.a.replace(/"/g,"&quot;") + '">';
      h += '<div class="aet-header">';
      h += '<span class="aet-title">рҹ“Ҳ иө”зҺҮиө°еҠҝ</span>';
      h += '<button class="aet-refresh" onclick="renderOddsTrend(this.closest(\'.ana-card\'))">вҹі</button>';
      h += '</div>';
      h += '<div class="aet-chart-area"><div class="aet-loading">еҠ иҪҪдёӯ...</div></div>';
      h += '</div>';

      h += '</div></div></div>';
    }
    h += '</div>';
  }
  el.innerHTML = h;
}


function toggleAnaCard(el){
  if(!el.classList.contains("ana-card")) el = el.closest('.ana-card');
  if(!el) return;
  var wasExpanded = el.classList.contains("expanded");
  document.querySelectorAll(".ana-card.expanded").forEach(function(x){
    if(x !== el) x.classList.remove("expanded");
  });
  if(wasExpanded) el.classList.remove("expanded");
  else el.classList.add("expanded");
}

// ====== Odds trend chart ======
var __ODDS_HISTORY = null;
var __ODDS_HISTORY_BY_NAME = null;

function loadOddsHistory(cb){
  if(__ODDS_HISTORY){ if(cb) cb(__ODDS_HISTORY); return; }
  fetch('/api/odds/history').then(function(r){ return r.json(); }).then(function(d){
    __ODDS_HISTORY = d;
    __ODDS_HISTORY_BY_NAME = {};
    for(var k in d){
      var m = d[k];
      if(m.home && m.away) __ODDS_HISTORY_BY_NAME[m.home + '|' + m.away] = k;
    }
    if(cb) cb(d);
  }).catch(function(){});
}

function findMatchId(home, away){
  if(!__ODDS_HISTORY_BY_NAME) return null;
  return __ODDS_HISTORY_BY_NAME[home + '|' + away] || null;
}

function renderOddsTrend(cardEl){
  if(!cardEl || !cardEl.classList.contains('expanded')) return;
  var wrap = cardEl.querySelector('.ana-exp-trend-wrap');
  if(!wrap) return;
  var area = wrap.querySelector('.aet-chart-area');
  if(!area) return;
  var home = wrap.getAttribute('data-home') || '';
  var away = wrap.getAttribute('data-away') || '';
  loadOddsHistory(function(data){
    var mid = findMatchId(home, away);
    if(!mid || !data[mid]){
      area.innerHTML = '<div class="aet-empty">\u6682\u65e0\u8d54\u7387\u5386\u53f2\u6570\u636e</div>';
      return;
    }
    var md = data[mid];
    var tracks = md.tracks && md.tracks.hhad;
    if(!tracks || tracks.length < 2){
      area.innerHTML = '<div class="aet-empty">\u8d54\u7387\u5386\u53f2\u4e0d\u8db3\u4e24\u6761</div>';
      return;
    }
    var W = 640, H = 200, padL = 70, padR = 40, padT = 20, padB = 40;
    var cw = W - padL - padR, ch = H - padT - padB;
    var n = tracks.length;
    var allVals = [];
    for(var ti = 0; ti < n; ti++){
      allVals.push(tracks[ti].h); allVals.push(tracks[ti].d); allVals.push(tracks[ti].a);
    }
    var yMin = Math.min.apply(null, allVals) * 0.97;
    var yMax = Math.max.apply(null, allVals) * 1.03;
    var yRng = yMax - yMin;
    function xp(i){ return padL + cw * i / (n - 1); }
    function yp(v){ return padT + ch - ch * (v - yMin) / yRng; }
    var gl = md.goalLine || 0;
    var glStr = gl >= 0 ? '+' + gl : '' + gl;
    var hh = '';
    hh += '<div class="aet-chart-title">\u8ba9\u7403(' + glStr + ')\u8d54\u7387\u8d70\u52bf (' + n + '\u6b21\u53d8\u5316)</div>';
    hh += '<svg viewBox="0 0 ' + W + ' ' + H + '" class="aet-svg">';
    for(var gi = 0; gi < 5; gi++){
      var yv = yMin + yRng * gi / 4;
      var yy = yp(yv);
      hh += '<line x1="' + padL + '" y1="' + yy + '" x2="' + (padL+cw) + '" y2="' + yy + '" stroke="rgba(255,255,255,.04)" stroke-width="1"/>';
      hh += '<text x="' + (padL-6) + '" y="' + (yy+4) + '" fill="#5a6577" font-size="10" text-anchor="end">' + yv.toFixed(2) + '</text>';
    }
    for(var ti = 0; ti < n; ti++){
      var x = xp(ti);
      var label = tracks[ti].ts;
      if(label){
      var parts = label.split("T");
      if(parts.length === 2) label = parts[0].slice(5) + " " + parts[1].slice(0,5);
      else if(label.length > 10) label = label.slice(5, 16);
    }
      hh += '<text x="' + x + '" y="' + (padT+ch+18) + '" fill="#5a6577" font-size="9" text-anchor="end" transform="rotate(-30,' + x + ',' + (padT+ch+18) + ')">' + label + '</text>';
    }
    var series = [
      {key:'h', color:'#00e5ff', label:'\u4e3b\u80dc'},
      {key:'d', color:'#fbbf24', label:'\u5e73\u5c40'},
      {key:'a', color:'#ef5350', label:'\u5ba2\u80dc'}
    ];
    for(var si = 0; si < 3; si++){
      var sk = series[si].key, sc = series[si].color;
      var pts = '';
      for(var ti = 0; ti < n; ti++){
        var val = tracks[ti][sk];
        if(val === undefined) continue;
        pts += (pts ? ' ' : '') + xp(ti) + ',' + yp(val);
      }
      if(pts) hh += '<polyline points="' + pts + '" fill="none" stroke="' + sc + '" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" opacity="0.85"/>';
      for(var ti = 0; ti < n; ti++){
        var val = tracks[ti][sk];
        if(val === undefined) continue;
        var xd = xp(ti), yd = yp(val);
        hh += '<circle cx="' + xd + '" cy="' + yd + '" r="3" fill="' + sc + '" opacity="0.8"/>';
        hh += '<text x="' + xd + '" y="' + (yd-7) + '" fill="' + sc + '" font-size="9" text-anchor="middle" opacity="0.75">' + val.toFixed(2) + '</text>';
      }
    }
    hh += '</svg>';
    hh += '<div class="aet-legend">';
    for(var si = 0; si < 3; si++){
      hh += '<span class="aet-leg-item"><span class="aet-leg-dot" style="background:' + series[si].color + '"></span>' + series[si].label + '</span>';
    }
    hh += '<span class="aet-leg-item" style="margin-left:auto;color:#5a6577;font-size:11px;cursor:pointer" onclick="refreshOddsTrend(this.closest(\'.ana-card\'))">\u27f3 \u5237\u65b0</span>';
    hh += '</div>';
    area.innerHTML = hh;
  });
}

function refreshOddsTrend(cardEl){
  if(!cardEl) return;
  var area = cardEl.querySelector('.aet-chart-area');
  if(!area) return;
  area.innerHTML = '<div class="aet-loading">\u5237\u65b0\u4e2d...</div>';
  __ODDS_HISTORY = null;
  __ODDS_HISTORY_BY_NAME = null;
  fetch('/api/odds/refresh').then(function(){
    renderOddsTrend(cardEl);
  }).catch(function(){
    renderOddsTrend(cardEl);
  });
}

// Wrap toggleAnaCard to auto-render trend on expand
var __origToggleAnaCard = toggleAnaCard;
toggleAnaCard = function(el){
  if(!el.classList.contains('expanded')){
    if(!el.classList.contains('ana-card'))el=el.closest('.ana-card')||el;__origToggleAnaCard(el);
    setTimeout(function(){ renderOddsTrend(el); }, 300);
  } else {
    if(!el.classList.contains('ana-card'))el=el.closest('.ana-card')||el;__origToggleAnaCard(el);
  }
};

function __expandTargetMatch(){
  var tm = window.__TARGET_MATCH;
  if(!tm) return;
  delete window.__TARGET_MATCH;
  var cards = document.querySelectorAll(".ana-card");
  for(var i = 0; i < cards.length; i++){
    var c = cards[i];
    var home = c.querySelector(".tname.home");
    var away = c.querySelector(".tname.away");
    if(home && away && home.textContent === tm.h && away.textContent === tm.a){
      toggleAnaCard(c);
      setTimeout(function(){
        c.scrollIntoView({behavior:"smooth",block:"center"});
        c.classList.add("highlight");
        setTimeout(function(){ c.classList.remove("highlight"); }, 1500);
      }, 100);
      break;
    }
  }
}

function renderCalendarView(){
  var main = document.querySelector(".main");
  main.scrollTop = 0;
  document.querySelector(".sec-header h2").textContent = "рҹҸҶ 2026дё–з•ҢжқҜиөӣзЁӢ";
  var gs={};for(var xi=0;xi<WC_MATCHES.length;xi++)gs[WC_MATCHES[xi].g]=1;var gk=Object.keys(gs);document.getElementById("todaySub").textContent = WC_MATCHES.length+"еңәжҜ”иөӣ В· "+gk.length+"дёӘе°Ҹз»„";
  document.getElementById("todayMatches").style.display = "block";

  // Build match lookup by date
  var matchByDate = {};
  for(var i = 0; i < WC_MATCHES.length; i++){
    var m = WC_MATCHES[i];
    if(!matchByDate[m.d]) matchByDate[m.d] = [];
    matchByDate[m.d].push(m);
  }

  var now = new Date();
  var y = now.getFullYear();
  var m = now.getMonth();
  var d = now.getDate();
  var todayKey = y + "-" + pad2(m+1) + "-" + pad2(d);

  var calYear = 2026;
  var calMonth = 5; // June (0-indexed)

  function pad2(v){return v<10?"0"+v:""+v;}

  function buildHTML(year, month){
    var firstDay = new Date(year, month, 1);
    var startDow = firstDay.getDay();
    var startCol = startDow === 0 ? 6 : startDow - 1;
    var daysInMonth = new Date(year, month + 1, 0).getDate();
    var dayNames = ["е‘ЁдёҖ","е‘ЁдәҢ","е‘Ёдёү","е‘Ёеӣӣ","е‘Ёдә”","е‘Ёе…ӯ","е‘Ёж—Ҙ"];

    var h = '<div class="wc-calendar-wrap"><div class="wc-cal-grid">';
    for(var dw = 0; dw < 7; dw++){
      h += '<div class="wc-cal-day-head">' + dayNames[dw] + '</div>';
    }

    // Empty cells before first day
    for(var e = 0; e < startCol; e++){
      h += '<div class="wc-cal-day other-month"></div>';
    }

    // Day cells - with smart skip/placeholder logic
    // Find first and last match days
    var firstMatchDay = 0, lastMatchDay = 0;
    for(var d = 1; d <= daysInMonth; d++){
      var k = (month+1) + "\u6708" + d + "\u65e5";
      if(matchByDate[k] && matchByDate[k].length > 0){
        if(firstMatchDay === 0) firstMatchDay = d;
        lastMatchDay = d;
      }
    }
    // Calculate week boundaries around matches
    var firstWeekMon = firstMatchDay - ((startCol + firstMatchDay - 1) % 7);
    var lastWeekSun = lastMatchDay + (6 - ((startCol + lastMatchDay - 1) % 7));
    if(lastWeekSun > daysInMonth) lastWeekSun = daysInMonth;

    var cellsRendered = startCol;
    for(var day = 1; day <= daysInMonth; day++){
      var dateKey = (month+1) + "\u6708" + day + "\u65e5";
      var matches = matchByDate[dateKey] || [];
      var hasMatches = matches.length > 0;

      // Skip days in fully empty weeks before first match week
      if(!hasMatches && day < firstWeekMon) continue;
      // Skip days in fully empty weeks after last match week
      if(!hasMatches && day > lastWeekSun) continue;

      cellsRendered++;
      var isToday = (year + "-" + pad2(month+1) + "-" + pad2(day) === todayKey);

      var cls = "wc-cal-day";
      if(hasMatches) cls += " has-matches";
      if(isToday) cls += " today";

      h += '<div class="' + cls + '" onclick="showDayModal(' + day + ')" data-day="' + day + '">';
      h += '<div class="cday-num">' + day;
      if(isToday) h += '<span class="today-badge">\u4eca\u5929</span>';
      h += '</div>';

      if(hasMatches){
        var groups = {};
        for(var mi = 0; mi < matches.length; mi++) groups[matches[mi].g] = true;
        var gkeys = Object.keys(groups);
        h += '<div class="cday-badges">';
        for(var gi = 0; gi < Math.min(gkeys.length, 4); gi++){
          h += '<span class="cday-badge">' + gkeys[gi] + '\u7ec4</span>';
        }
        if(gkeys.length > 4) h += '<span class="cday-badge">+' + (gkeys.length-4) + '</span>';
        h += '</div>';

        var showCount = Math.min(matches.length, 6);
        for(var mi = 0; mi < showCount; mi++){
          var mt = matches[mi];
          h += '<div class="cday-match"><span class="cdm-time">' + mt.t.slice(0,5) + '</span>' + flagImg(mt.h) + mt.h.slice(0,4) + ' vs ' + flagImg(mt.a) + mt.a.slice(0,4) + '</div>';
        }
        if(matches.length > 6){
          h += '<div class="cday-more">+' + (matches.length - 6) + ' \u573a</div>';
        }
      }

      h += '</div>';
    }

    // Remaining empty cells
    var rem = (7 - cellsRendered % 7) % 7;
    for(var r = 0; r < rem; r++){
      h += '<div class="wc-cal-day other-month"></div>';
    }

    h += '</div></div>';
    return h;
  }

  document.getElementById("todayMatches").innerHTML = buildHTML(calYear, calMonth);
  document.getElementById("caltMonthLabel").textContent = (calMonth+1) + "\u6708 " + calYear;
  window.__CAL_YEAR = calYear;
  window.__CAL_MONTH = calMonth;
}

// Month navigation
function rebuildCalendar(year, month){
  var main = document.querySelector(".main");
  if(main) main.scrollTop = 0;
  var el = document.getElementById("todayMatches");
  if(!el) return;
  el.innerHTML = buildHTML(year, month);
  var ml = document.getElementById("caltMonthLabel"); if(ml) ml.textContent = (month+1) + "\u6708 " + year;
  var h2 = document.querySelector(".sec-header h2");
  if(h2) h2.textContent = "рҹҸҶ " + (month+1) + "жңҲдё–з•ҢжқҜиөӣзЁӢ";
}

function prevMonth(){
  var y = window.__CAL_YEAR || 2026;
  var m = window.__CAL_MONTH || 5;
  // Only June 2026 for now
}

function nextMonth(){
  var y = window.__CAL_YEAR || 2026;
  var m = window.__CAL_MONTH || 5;
}

// ====== Modal: \u65e5\u671f\u8be6\u60c5 ======
function showDayModal(day){
  var dateKey = "6\u6708" + day + "\u65e5";
  var matches = [];
  for(var i = 0; i < WC_MATCHES.length; i++){
    if(WC_MATCHES[i].d === dateKey) matches.push(WC_MATCHES[i]);
  }
  if(matches.length === 0) return;

  var overlay = document.createElement("div");
  overlay.className = "modal-overlay";
  overlay.onclick = function(e){ if(e.target === overlay) overlay.remove(); };

  var box = document.createElement("div");
  box.className = "modal-box";

  var h = '<div class="modal-head">';
  h += '<span class="modal-title">' + dateKey + ' \u8d5b\u7a0b\u8be6\u60c5 (' + matches.length + '\u573a)</span>';
  h += '<button class="modal-close" onclick="this.closest(\'.modal-overlay\').remove()">\u2716</button>';
  h += '</div>';
  h += '<div class="modal-body">';

  for(var i = 0; i < matches.length; i++){
    var m = matches[i];
    h += '<div class="modal-match">';
    h += '<div class="mm-row1">';
    h += '<span class="mm-time">' + m.t.slice(0,5) + '</span>';
    h += '<span class="mm-group">' + m.g + '\u7ec4</span>';
    h += '</div>';
    h += '<div class="mm-row2">';
    h += '<span class="mm-home">' + flagImg(m.h) + m.h + '</span>';
    h += '<span class="mm-vs">VS</span>';
    h += '<span class="mm-away">' + flagImg(m.a) + m.a + '</span>';
    h += '</div>';
    h += '<div class="mm-row3">';
    h += '<span class="mm-venue">\uD83C\uDF0D ' + m.v + '</span>';
    h += '</div>';
    h += '</div>';
  }

  h += '</div>'; // modal-body
  box.innerHTML = h;
  overlay.appendChild(box);
  document.body.appendChild(overlay);

  // ESC key to close
  var escHandler = function(e){
    if(e.key === "Escape"){ overlay.remove(); document.removeEventListener("keydown", escHandler); }
  };
  document.addEventListener("keydown", escHandler);
}

// Close modal on ESC (global)
document.addEventListener("keydown", function(e){
  if(e.key === "Escape"){
    var o = document.querySelector(".modal-overlay");
    if(o) o.remove();
  }
});
function toggleAccordion(id){var el=document.getElementById(id);if(el)el.classList.toggle('open');}
function openAccordion(id){var el=document.getElementById(id);if(el)el.classList.add('open');}
function getTagColor(t){t=(t||"").toLowerCase();if(t==="s")return"s";if(t==="a")return"a";if(t==="c"||t==="meltdown")return"c";return"b";}
function getDirBadge(d){var v=(d||"").toLowerCase();if(v.indexOf("\u80dc")>=0||v==="\u4e0a\u76d8"||v==="\u5927\u7403")return"<span class=\"mc-badge g\">"+d+"</span>";if(v.indexOf("\u8d1f")>=0||v==="\u4e0b\u76d8"||v==="\u5c0f\u7403")return"<span class=\"mc-badge r\">"+d+"</span>";if(v.indexOf("\u5e73")>=0||v==="\u8d70\u6c34")return"<span class=\"mc-badge b\">"+d+"</span>";return"<span class=\"mc-badge gray\">"+(d||"-")+"</span>";}

function getRatingClass(r){var v=(r||"").toLowerCase();if(v==="s")return"s";if(v==="a")return"a";if(v==="c"||v==="meltdown")return"c";if(v==="m")return"m";return"b";}
function getDirClass(d){var v=(d||"").toLowerCase();if(v.indexOf("иғң")>=0||v==="дёҠзӣҳ")return"win";if(v.indexOf("иҙҹ")>=0||v==="дёӢзӣҳ")return"lose";if(v.indexOf("е№і")>=0)return"draw";return"";}
function getHitTag(h){return h?"<span class=\"tag hit\">\u547d\u4e2d</span>":"<span class=\"tag miss\">\u672a\u4e2d</span>";}
function getRatingHTML(r,l){var n=r||"";var c=getTagColor(l);return"<span class=\"r-num\">"+n+"</span><span class=\"r-lvl "+c+"\">"+l.toUpperCase()+"</span>";}
function getResultClass(r){var v=(r||"").toLowerCase();if(v.indexOf("\u80dc")>=0||v.indexOf("\u8ba9\u80dc")>=0)return"lose";if(v.indexOf("\u8d1f")>=0||v.indexOf("\u8ba9\u8d1f")>=0)return"win";if(v.indexOf("\u5e73")>=0)return"draw";return"";}

function renderMatchCard(m,i,mcData,ddiData,aiData){
var t=m.time||m.match_time||"--:--";
var l=m.event||m.league||"";
var ho=m.home||m.home_team||"";
var aw=m.away||m.away_team||"";
var dir=m.direction||m.prediction||"";
var fs=m.fit_score||0;
var rat=m.rating||"";
var lv=getRatingClass(rat);
var timeDisplay=t&&t.length>=16?t.slice(5,16):t.length>=5?t:t;
var ld=m.lambda_diff!==undefined?m.lambda_diff:0;
var lambda_h=1.0,lambda_a=1.0,phys={},hcp={};
var tgList=(m.top2_total_goals&&m.top2_total_goals.length?m.top2_total_goals:mcData&&mcData.top2_total_goals?mcData.top2_total_goals:[]);
var hfList=(m.top2_half_full&&m.top2_half_full.length?m.top2_half_full:mcData&&mcData.top2_half_full?mcData.top2_half_full:[]);
var scList=(m.top3_scores&&m.top3_scores.length?m.top3_scores:mcData&&mcData.top3_scores?mcData.top3_scores:[]);
if(mcData){lambda_h=mcData.lambda_h_final||1.0;lambda_a=mcData.lambda_a_final||1.0;phys=mcData.physical||{};hcp=mcData.jc_handicap_prob||{};}
var pMarket={};
if(ddiData&&ddiData.p_market)pMarket=ddiData.p_market;
else if(ddiData&&ddiData.market)pMarket=ddiData.market;
var trapTxt="",riskTxt="",s7Reason="",s7Score=0;
if(aiData){trapTxt=aiData.trap_analysis||"";riskTxt=aiData.key_risk||"";s7Score=aiData.s7_score||0;s7Reason=aiData.s7_reason||"";}
if(!trapTxt&&m.warning)trapTxt=m.warning;
var dirCls=getDirClass(dir);
var hit=(m.hit===true);
var rt="rt-"+(lv||"c");
if(m.hit!==undefined){rt+=hit?" rt-hit":" rt-miss";}
var tgText=tgList.length>0?tgList.join(" / "):"--";
var hfText=hfList.length>0?hfList.join(" / "):"--";
var scText=scList.length>0?scList.join(" / "):"--";
var doi=(m.doi!==undefined?m.doi:(ddiData&&ddiData.doi!==undefined?ddiData.doi:0));
var maxLam=Math.max(lambda_h,lambda_a,1.5);

var h="";
h+='<div class="card '+rt+'" onclick="toggleCard(this)" data-mid="'+(m.match_id||m.id||i)+'">';
// Collapsed row: core info only, larger fonts
h+='<div class="match-row grid-layout-row">';
h+='<div class="grid-col-id">'+(m.match_id||m.id||"")+'</div>';
h+='<div class="grid-col-league"><span class="league-tag">'+(l||'')+'</span></div>';
h+='<div class="grid-col-time">'+timeDisplay+'</div>';
h+='<div class="grid-col-match"><div class="matchup-container"><span class="tname home">'+ho+'</span><span class="vs-badge">VS</span><span class="tname away">'+aw+'</span></div></div>';
h+='<div class="grid-col-dir">';
if(dir)h+='<span class="dir-badge '+dirCls+'">'+dir+'</span>';
h+='</div>';
h+='<div class="grid-col-score">';
h+='<div class="score-wrapper"><span class="num">'+(fs?fs.toFixed(1):"--")+'</span>';
if(rat)h+='<span class="grade '+lv+'">'+rat+'</span>';
h+='</div></div>';
h+='<div class="grid-col-expand">&#9660;</div>';
h+='</div>';

// Expanded content
h+='<div class="expanded-content">';
// Row 1: Prediction pills
h+='<div class="exp-pill-row">';
h+='<div class="exp-pill"><span class="pill-icon">&#9917;</span><span class="pill-label">жҖ»иҝӣзҗғ:</span><span class="pill-value">'+tgText+'</span></div>';
h+='<div class="exp-pill"><span class="pill-icon">&#128260;</span><span class="pill-label">еҚҠе…Ёеңә:</span><span class="pill-value">'+hfText+'</span></div>';
h+='<div class="exp-pill"><span class="pill-icon">&#127919;</span><span class="pill-label">жҜ”еҲҶ:</span><span class="pill-value">'+scText+'</span></div>';
h+='</div>';
