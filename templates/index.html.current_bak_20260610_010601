function brDrawConnectors(container){
  var oldSvg = container.querySelector('.br-svg');
  if(oldSvg) oldSvg.remove();
  var inner = container.querySelector('.br-inner');
  if(!inner) return;
  var cols = inner.querySelectorAll(':scope > .br-column');
  if(cols.length < 3) return;
  var SVG_NS = 'http://www.w3.org/2000/svg';
  var svg = document.createElementNS(SVG_NS, 'svg');
  svg.setAttribute('class', 'br-svg');
  svg.style.position = 'absolute';
  svg.style.top = '0';
  svg.style.left = '0';
  svg.style.width = '100%';
  svg.style.height = '100%';
  svg.style.pointerEvents = 'none';
  svg.style.overflow = 'visible';
  inner.style.position = 'relative';
  inner.appendChild(svg);
  function cc(card){
    var ir = inner.getBoundingClientRect();
    var cr = card.getBoundingClientRect();
    return {x: cr.left - ir.left + cr.width, y: cr.top - ir.top + cr.height/2};
  }
  function dl(cA, cB, nx){
    var a = cc(cA), b = cc(cB), n = cc(nx);
    var nr = nx.getBoundingClientRect();
    var ir = inner.getBoundingClientRect();
    var nxl = nr.left - ir.left;
    var my = (a.y + b.y) / 2;
    var mx = (a.x + nxl) / 2;
    function ap(d){
      var p = document.createElementNS(SVG_NS, 'path');
      p.setAttribute('d', d);
      p.setAttribute('stroke', 'rgba(0,229,255,.12)');
      p.setAttribute('stroke-width', '1.5');
      p.setAttribute('fill', 'none');
      svg.appendChild(p);
    }
    ap('M ' + a.x + ',' + a.y + ' L ' + mx + ',' + a.y + ' L ' + mx + ',' + b.y + ' L ' + b.x + ',' + b.y);
    ap('M ' + mx + ',' + my + ' L ' + nxl + ',' + my);
  }
  for(var ci = 0; ci < 3; ci++){
    if(ci + 1 >= cols.length) break;
    var ca = cols[ci].querySelectorAll(':scope > .br-card');
    var cb = cols[ci + 1].querySelectorAll(':scope > .br-card');
    var n = Math.min(Math.floor(ca.length / 2), cb.length);
    for(var pi = 0; pi < n; pi++) dl(ca[pi*2], ca[pi*2+1], cb[pi]);
  }
  var li = cols.length - 1;
  for(var ci = li; ci > li - 3; ci--){
    if(ci - 1 < 0) break;
    var ca = cols[ci].querySelectorAll(':scope > .br-card');
    var cb = cols[ci - 1].querySelectorAll(':scope > .br-card');
    var n = Math.min(Math.floor(ca.length / 2), cb.length);
    for(var pi = 0; pi < n; pi++) dl(ca[pi*2], ca[pi*2+1], cb[pi]);
  }
}

