  var h = '<div class="modal-head">';
  h += '<span class="modal-title">' + dateKey + ' \u8d5b\u7a0b\u8be6\u60c5 (' + matches.length + '\u573a)</span>';
  h += '<button class="modal-close" onclick="this.closest(\'.modal-overlay\').remove()">\u2716</button>';
  h += '</div>';
  h += '<div class="modal-body">';

  for(var i = 0; i < matches.length; i++){
    var m = matches[i];
    h += '<div class="modal-match">';
    h += '<div class="mm-row1">';
    h += '<span class="mm-time">' + m.t.slice(0,5) + '</span>';
    h += '<span class="mm-group">' + m.g + '\u7ec4</span>';
