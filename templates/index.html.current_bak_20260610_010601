﻿<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>V3.3.3-Core 分析系统</title>
<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{--bg:#080b14;--surface:#0c1021;--surface-2:#111629;--surface-h:#171d35;--t1:#e8edf5;--t2:#8b95a9;--t3:#5a6577;--green:#00e676;--red:#ef5350;--gold:#fbbf24;--amber:#fbbf24;--blue:#60a5fa;--cyan:#00e5ff;--purple:#7c3aed;--bd:rgba(0,229,255,.06);--bd-h:rgba(0,229,255,.14);--glow-cyan:0 0 12px rgba(0,229,255,.12);--glow-green:0 0 12px rgba(0,230,118,.12);--glow-amber:0 0 12px rgba(251,191,36,.12);--glow-gold:0 0 12px rgba(251,191,36,.15);--glow-purple:0 0 12px rgba(124,58,237,.12);--mono:"SF Mono","Cascadia Code","JetBrains Mono","Consolas",monospace;--sans:"Inter","SF Pro","Microsoft YaHei","PingFang SC","Noto Sans SC",sans-serif}
body{font-family:var(--sans);background:linear-gradient(rgba(26,26,32,0.12),rgba(26,26,32,0.12)),url('../static/bg1.png') center/cover no-repeat fixed;color:var(--t1);height:100vh;width:100vw;overflow:hidden;display:flex;-webkit-font-smoothing:antialiased;text-rendering:optimizeLegibility}
::-webkit-scrollbar{width:3px}
::-webkit-scrollbar-track{background:transparent}
::-webkit-scrollbar-thumb{background:rgba(0,229,255,.08);border-radius:2px}
.sd-wrap{width:250px;flex-shrink:0;position:relative;z-index:100;background:linear-gradient(180deg,rgba(12,16,33,.35) 0%,rgba(16,22,42,.30) 100%);border-right:1px solid rgba(0,229,255,.03);display:flex;flex-direction:column;overflow:hidden;overscroll-behavior:contain}
.sd-top{padding:20px 18px 16px;border-bottom:1px solid transparent;border-image:linear-gradient(90deg,rgba(0,229,255,.1),transparent 70%) 1;flex-shrink:0}
.sd-logo-row{display:flex;align-items:center;gap:10px}
.sd-title-group{display:flex;align-items:baseline;gap:8px;flex-wrap:nowrap;min-width:0}

.sd-title{font-size:22px;font-weight:700;color:var(--cyan);letter-spacing:1px;line-height:1.2;display:inline;white-space:nowrap}
.sd-sub{font-size:10px;font-weight:300;color:rgba(148,163,184,.4);letter-spacing:.3px;display:inline;white-space:nowrap;vertical-align:baseline;position:relative;top:-0px}
.sd-status{display:flex;align-items:center;gap:8px;margin-top:10px;font-size:12px;color:rgba(255,255,255,.7);padding:4px 0;-webkit-font-smoothing:antialiased;text-shadow:0 0 1px rgba(0,0,0,.5)}
.sd-status-dot{width:8px;height:8px;border-radius:50%;background:var(--green);flex-shrink:0;animation:pulse 2s infinite;box-shadow:0 0 6px rgba(0,230,118,.4)}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.4}}.sd-nav-item{display:flex;align-items:center;gap:10px;padding:10px 12px;margin:4px 8px;border-radius:6px;cursor:pointer;transition:all .15s;font-size:13px;color:var(--t2)}
.sd-nav-item:hover{background:rgba(0,229,255,.06);color:var(--t1)}
.sd-nav-item .sni-icon{font-size:16px;flex-shrink:0}
.sd-nav-item .sni-label{flex:1}
.sd-nav-item.active{background:rgba(0,229,255,.1);color:var(--cyan);border-left:3px solid var(--cyan);padding-left:9px}
.sd-nav-divider{height:1px;margin:4px 12px;background:linear-gradient(90deg,transparent,rgba(0,229,255,.08),transparent)}

@keyframes pulse-glow{0%{box-shadow:0 0 0 0 rgba(0,229,255,.4);border-color:rgba(0,229,255,.4)}70%{box-shadow:0 0 14px 4px rgba(0,229,255,.08);border-color:rgba(0,229,255,.8)}100%{box-shadow:0 0 0 0 rgba(0,229,255,.0);border-color:rgba(0,229,255,.4)}}
.sd-body{flex:1;min-height:0;overflow-y:scroll;overflow-x:hidden;padding:0 0 16px}

/* 侧边栏自定义滚动条 - 常驻显示、极细风格 */
.sd-body::-webkit-scrollbar {
  width: 4px;
}
.sd-body::-webkit-scrollbar-track {
  background: rgba(255,255,255,0.04);
}
.sd-body::-webkit-scrollbar-thumb {
  background: rgba(255, 255, 255, 0.15);
  border-radius: 10px;
  transition: background 0.2s ease;
}
.sd-body::-webkit-scrollbar-thumb:hover {
  background: rgba(255, 255, 255, 0.45);
}
.sd-wrap:hover .sd-body::-webkit-scrollbar-thumb {
  background: rgba(255, 255, 255, 0.25);
}
.sd-wrap:hover .sd-body::-webkit-scrollbar-thumb:hover {
  background: rgba(255, 255, 255, 0.55);
}
/* Firefox 兼容 */
.sd-body {
  scrollbar-width: thin;
  scrollbar-color: rgba(255, 255, 255, 0.15) transparent;
}
/* WC sidebar */
#accWCMain .acc-head{border-radius:6px;margin:4px 8px;white-space:nowrap}
#accWCMain.open>.acc-head .acc-label{color:var(--gold);text-shadow:0 0 12px rgba(251,191,36,.15)}
.wc-sub-item{display:flex;align-items:center;gap:10px;padding:9px 12px;margin:3px 8px;border-radius:6px;cursor:pointer;transition:all .15s;font-size:13px;color:var(--t2)}
.wc-sub-item:hover{background:rgba(251,191,36,.06);color:var(--t1)}
.wc-sub-item .wsi-icon{font-size:15px;flex-shrink:0}
.wc-sub-item .wsi-label{flex:1}
.wc-sub-item.active{background:rgba(251,191,36,.12);color:var(--gold);border-left:3px solid var(--gold);padding-left:9px}

/* View content containers for nav switching */
.view-content{display:block}
.sd-wc-badge{font-size:9px;color:var(--gold);background:rgba(251,191,36,.14);padding:1px 7px;border-radius:8px;letter-spacing:.3px;white-space:nowrap}
#accHistory,#accBacktest,#accDoc{opacity:.7;transition:opacity .2s}
#accHistory:hover,#accBacktest:hover,#accDoc:hover{opacity:1}

.tf{width:20px;height:20px;border-radius:50%;vertical-align:middle;margin-right:4px;object-fit:cover;flex-shrink:0}
/* WC group schedule */
.wc-date-group{margin-bottom:12px}
.wc-date-head{font-size:15px;font-weight:700;color:var(--gold);padding:12px 0 6px;border-bottom:1px solid rgba(251,191,36,.12);margin-bottom:8px;letter-spacing:.5px;text-shadow:0 0 8px rgba(251,191,36,.1)}
.wc-match-card{display:flex;align-items:center;gap:10px;padding:9px 14px;margin:4px 0;background:rgba(255,255,255,.02);border:1px solid rgba(255,255,255,.04);border-radius:6px;cursor:pointer;transition:all .15s;font-size:13px}
.wc-match-card:hover{background:rgba(251,191,36,.04);border-color:rgba(251,191,36,.1)}
.wc-m-time{font-family:var(--mono);font-size:12px;color:var(--t3);width:44px;flex-shrink:0;text-align:center}
.wc-m-group{font-size:10px;color:var(--gold);background:rgba(251,191,36,.1);padding:1px 5px;border-radius:3px;flex-shrink:0}
.wc-m-home{flex:1;text-align:right;font-weight:600;color:var(--t1)}
.wc-m-vs{color:var(--t3);font-size:11px;flex-shrink:0;width:20px;text-align:center}
.wc-m-away{flex:1;font-weight:600;color:var(--t1)}
.wc-m-venue{font-size:10px;color:var(--t3);flex-shrink:0;max-width:70px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}

.sd-footer{padding:10px 16px;font-size:9px;color:rgba(255,255,255,.6);text-align:center;letter-spacing:.5px;font-family:var(--mono);text-shadow:0 0 4px rgba(255,255,255,.05);flex-shrink:0}
.acc{border-bottom:1px solid transparent;border-image:linear-gradient(90deg,rgba(0,229,255,.07),transparent 70%) 1}
.acc-head{display:flex;align-items:center;gap:10px;padding:13px 16px;min-height:48px;cursor:pointer;user-select:none;transition:background .15s}
.acc-head:hover{background:rgba(0,229,255,.03)}
.acc-head .acc-arrow{font-size:11px;color:var(--t3);transition:transform .3s ease;flex-shrink:0;width:12px;text-align:center}
.acc.open .acc-arrow{transform:rotate(90deg)}
.acc-head .acc-icon{font-size:17px}
.acc-head .acc-label{font-size:15px;font-weight:600;color:var(--t2);letter-spacing:.5px;flex:1;min-width:0}
.acc-head .acc-badge{font-size:10px;color:var(--green);background:rgba(0,230,118,.1);padding:2px 8px;border-radius:8px;white-space:nowrap}
.acc-head .acc-count{font-size:12px;color:var(--t3);background:rgba(255,255,255,.06);padding:1px 5px;border-radius:4px;white-space:nowrap}
.acc.open .acc-head .acc-label{color:var(--t1)}
.acc-body{overflow:hidden;max-height:0;transition:max-height .35s ease}
.acc.open>.acc-body{max-height:900px}
.acc-body-inner{padding:4px 16px 12px}
.today-stats{display:flex;flex-direction:column;gap:6px;padding:4px 0}
.today-stat-row{display:flex;justify-content:space-between;align-items:center;padding:5px 8px;background:rgba(0,229,255,.02);border-radius:5px;font-size:11px;border:1px solid rgba(0,229,255,.03)}
.today-stat-row .tsl{color:var(--t3)}
.today-stat-row .tsv{color:var(--t1);font-weight:600;font-family:var(--mono);letter-spacing:.3px}
.today-stat-row .tsv.high{color:var(--green)}
.today-stat-row .tsv.med{color:var(--amber)}
.today-stat-row .tsv.low{color:var(--red)}
.today-divider{height:1px;background:var(--bd);margin:6px 0}
.today-date{font-size:14px;color:var(--green);font-weight:600;padding:2px 0;text-align:center;font-family:var(--mono);text-shadow:0 0 8px rgba(0,230,118,.2)}
.hist-date-item{display:flex;align-items:center;gap:6px;padding:10px 16px;min-height:40px;cursor:pointer;transition:all .2s;border-left:1px solid transparent;border-radius:0;margin:2px 0}
.hist-date-item:hover{background:rgba(0,229,255,.03)}
.hist-date-item.active{border-left-color:var(--green);background:rgba(0,230,118,.07)}
.hist-date-item .hd-date{font-size:14px;font-weight:600;color:var(--t1);flex:1;min-width:0}
.hist-date-item .hd-stats{font-size:11px;color:var(--t3);white-space:nowrap}
.hist-date-item.active .hd-date{color:#fff}
.hist-date-item .hd-arrow{font-size:10px;color:var(--t3);transition:transform .3s ease}
.hist-date-item.open .hd-arrow{transform:rotate(90deg)}
.hist-action{padding:4px 16px 8px 28px;display:none}
.hist-date-item.open+.hist-action{display:block}
.hist-action button{width:100%;padding:5px 10px;font-size:10px;color:var(--t2);background:rgba(0,230,118,.08);border:1px solid rgba(0,230,118,.15);border-radius:4px;cursor:pointer;transition:all .15s;font-family:var(--sans)}
.hist-action button:hover{background:rgba(0,230,118,.18);color:var(--green)}
.hist-empty{padding:16px 12px;font-size:12px;color:var(--t3);text-align:center}
.bt-item{padding:9px 12px;margin:5px 0;background:rgba(255,255,255,.02);border-radius:5px;cursor:pointer;transition:background .15s;border:1px solid transparent}
.bt-item:hover{background:rgba(255,255,255,.09);border-color:rgba(255,255,255,.12)}
.bt-item .bt-title{font-size:13px;font-weight:600;color:var(--t1);margin-bottom:2px}
.bt-item .bt-meta{font-size:11px;color:var(--t3);display:flex;gap:8px;flex-wrap:wrap}
.bt-item .bt-meta span{background:rgba(255,255,255,.04);padding:1px 5px;border-radius:3px}
.bt-detail{padding:10px;margin:3px 0 8px;background:var(--surface);border-radius:6px;font-size:11px;color:var(--t2);line-height:1.6;display:none;border:1px solid var(--bd)}
.bt-detail.show{display:block}
.bt-detail .bt-summ{color:var(--t1);margin-bottom:4px}
.bt-detail .bt-link{padding:5px 10px;font-size:11px;background:rgba(66,165,245,.12);color:var(--blue);border:none;border-radius:4px;cursor:pointer;font-family:var(--sans);transition:background .15s}
.doc-item{padding:9px 12px;margin:5px 0;background:rgba(255,255,255,.02);border-radius:5px;cursor:pointer;transition:background .15s}
.doc-item:hover{background:rgba(255,255,255,.09)}
.doc-item .doc-title{font-size:13px;font-weight:600;color:var(--t1)}
.doc-content{padding:10px;margin:3px 0 8px;background:var(--surface);border-radius:5px;display:none;border:1px solid var(--bd)}
.doc-content.show{display:block}
.doc-entry{padding:5px 0;font-size:12px;line-height:1.7}
.doc-entry .de-label{color:var(--green);font-weight:600;white-space:nowrap}
.doc-entry .de-value{color:var(--t2)}
.sd-loading{color:var(--t3);font-size:12px;padding:12px;text-align:center}
.sd-error{color:var(--red);font-size:12px;padding:12px;text-align:center}
.main{flex:1;min-width:0;padding:0 24px 60px;overflow-y:auto}
.sec-header{display:flex;align-items:baseline;gap:12px;padding:18px 0 10px}
.sec-header h2{font-size:16px;font-weight:700;color:var(--t1)}
.sec-header .sec-sub{font-size:12px;color:var(--t2);font-weight:500}
.sec-header .sec-bar{flex:1;height:1px;background:var(--bd)}
.sec-actions{display:flex;align-items:center;gap:8px;flex-shrink:0;margin-left:auto}
.sec-dropdown{position:relative;display:inline-block}
.sec-dropdown-btn{font-size:11px;color:var(--t2);background:rgba(12,16,33,.6);border:1px solid var(--bd);border-radius:5px;padding:4px 10px;cursor:pointer;font-family:var(--sans);white-space:nowrap;transition:all .15s;letter-spacing:.3px}
.sec-dropdown-btn:hover{background:rgba(30,38,70,.7);border-color:var(--bd-h);color:var(--t1)}
.sec-dropdown-menu{display:none;position:absolute;top:calc(100% + 6px);right:0;min-width:130px;background:rgba(12,16,33,.92);border:1px solid var(--bd-h);border-radius:8px;padding:4px;z-index:200;-webkit-backdrop-filter:blur(12px);backdrop-filter:blur(12px);box-shadow:0 4px 20px rgba(0,0,0,.4)}
.sec-dropdown-menu.show{display:block}
.sec-dropdown-item{padding:7px 12px;font-size:12px;color:var(--t2);cursor:pointer;border-radius:5px;transition:all .12s;white-space:nowrap}
.sec-dropdown-item:hover{background:rgba(0,229,255,.08);color:var(--t1)}
.sec-dropdown-item.active{color:var(--cyan);background:rgba(0,229,255,.06)}
.sec-dropdown-label{display:flex;align-items:center;gap:8px;padding:7px 12px;font-size:12px;color:var(--t2);cursor:pointer;border-radius:5px;transition:all .12s;white-space:nowrap}
.sec-dropdown-label:hover{background:rgba(0,229,255,.08);color:var(--t1)}
.sec-dropdown-label input[type=checkbox]{accent-color:var(--cyan);width:14px;height:14px;cursor:pointer}
@media(max-width:768px){
  .sec-actions{gap:4px}
  .sec-dropdown-btn{font-size:10px;padding:3px 7px}
}


.card:hover{background:rgba(35,44,76,.88);border-color:rgba(0,229,255,.12);box-shadow:0 2px 0 rgba(0,229,255,.1),0 6px 20px rgba(0,0,0,.3)}

.card.active{border-color:rgba(0,230,118,.25);box-shadow:0 0 0 1px rgba(0,230,118,.12),0 0 20px rgba(0,230,118,.04)}

.card.active 

.card.active 
.chart-wrap{position:relative;height:80px;display:flex;align-items:flex-end;padding:0 4px}
.chart-y-axis{position:absolute;left:0;top:0;bottom:0;width:100%;pointer-events:none}
.chart-y-axis line{stroke:rgba(255,255,255,.06);stroke-width:1;stroke-dasharray:3 3}
.chart-y-axis text{fill:var(--t3);font-size:8px;font-family:var(--mono)}
.chart-bar-group{display:flex;flex-direction:column;align-items:center;gap:4px;flex:1;max-width:60px}
.chart-bar{width:100%;max-width:36px;border-radius:4px 4px 0 0;min-height:4px;position:relative;transition:height .5s ease}
.chart-bar-label{font-size:9px;color:var(--t3);font-family:var(--mono);white-space:nowrap}
.chart-bar-val{font-size:9px;font-weight:600;font-family:var(--mono);position:absolute;top:-14px;left:50%;transform:translateX(-50%);white-space:nowrap}
.chart-bar.val-green .chart-bar-val{color:var(--green)}
.chart-bar.val-red .chart-bar-val{color:var(--red)}
.chart-bar.val-amber .chart-bar-val{color:var(--amber)}
.detail-grid-4{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:10px}
.detail-cell{background:var(--surface);border-radius:6px;padding:8px 10px;display:flex;flex-direction:column;gap:2px}
.detail-cell .dc-label{font-size:10px;color:var(--t3);font-weight:500;display:flex;align-items:center;gap:4px}
.detail-cell .dc-value{font-size:12px;color:var(--t1);line-height:1.4;overflow:hidden;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;word-break:break-word}
.detail-cell .dc-value strong{font-family:var(--mono);font-weight:800;color:#fff;font-size:14px}
.detail-cell.risk{background:rgba(239,83,80,.1);border:1px solid rgba(239,83,80,.15)}
.detail-cell.risk .dc-value{color:var(--red)}

.detail-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-top:12px}
.chart-box{background:var(--surface);border-radius:8px;padding:12px 12px 8px}
.chart-box .ch-title{font-size:11px;color:var(--t2);margin-bottom:6px;font-weight:600}

.table-wrap{background:var(--surface-2);border:1px solid var(--bd);border-radius:8px;overflow:hidden;margin-top:6px}
.table-top{display:flex;align-items:center;gap:14px;padding:10px 14px;background:var(--surface);border-bottom:1px solid var(--bd);flex-wrap:wrap}
.table-top .tt-item{font-size:11px;color:var(--t2)}
.table-top .tt-item b{color:var(--t1);font-weight:600}
.table-top .tt-item .hl{color:var(--green)}
.table-top .tt-item .hl2{color:var(--amber)}
.tt-spacer{flex:1}
table.y-table{width:100%;border-collapse:collapse;font-size:12px}
table.y-table thead th{padding:8px 10px;text-align:left;font-weight:600;color:#A0AEC0;background:rgba(255,255,255,.04);border-bottom:1px solid var(--bd);white-space:nowrap;font-size:11px}
table.y-table tbody td{padding:8px 10px;border-bottom:1px solid rgba(255,255,255,.015);color:var(--t2);white-space:nowrap}
table.y-table tbody tr:hover{background:rgba(255,255,255,.03)}
table.y-table tbody tr:last-child td{border-bottom:none}
td.c-result{font-weight:600}
td.c-result.win{color:var(--red)}
td.c-result.lose{color:var(--green)}
td.c-result.draw{color:var(--blue)}
td.c-status .tag{padding:2px 8px;border-radius:3px;font-size:10px;font-weight:600}
td.c-status .tag.hit{background:var(--red);color:#fff}
td.c-status .tag.miss{background:var(--t3);color:#fff}
td.c-rating .r-num{font-weight:700;color:var(--t1);font-family:var(--mono);text-shadow:0 0 6px rgba(160,200,255,.25)}
td.c-rating .r-lvl{font-size:10px;padding:1px 5px;border-radius:3px;font-weight:600;margin-left:4px}
td.c-rating .r-lvl.s{background:var(--green);color:#fff}
td.c-rating .r-lvl.a{background:var(--amber);color:#222}
td.c-rating .r-lvl.b{background:var(--t3);color:#fff}
.empty-state{text-align:center;padding:40px 20px;color:var(--t3);font-size:13px}

/* === Contact & Divider === */
.sd-divider{height:1px;margin:0 18px;flex-shrink:0;background:linear-gradient(90deg,rgba(0,229,255,.08),transparent 60%);}
.sd-contact{padding:0 16px 6px;display:flex;flex-direction:column;gap:6px;flex-shrink:0}
.sd-contact-btn{display:flex;align-items:center;justify-content:center;gap:8px;width:100%;padding:10px 16px;border-radius:8px;border:1px solid rgba(0,229,255,.25);background:rgba(0,229,255,.04);color:var(--cyan);font-size:13px;font-family:var(--sans);cursor:pointer;transition:all .3s;animation:pulse-glow 2s ease-in-out infinite}
.sd-contact-btn:hover{background:rgba(0,229,255,.12);border-color:rgba(0,229,255,.6);color:#fff;box-shadow:0 0 20px rgba(0,229,255,.25),inset 0 0 20px rgba(0,229,255,.05);animation:none}
.sd-contact-btn .cb-icon{font-size:16px}
.sd-contact-btn .cb-text{font-weight:500}

/* Today module highlight */



/* Active date stronger highlight */
.hist-date-item.active{border-left:3px solid var(--cyan);background:rgba(0,229,255,.02);box-shadow:inset 0 0 16px rgba(0,229,255,.06),3px 0 10px rgba(0,229,255,.04)}
.hist-date-item.active .hd-date{color:var(--green)}

/* Stronger active state for nav items */
.acc.open>.acc-head{background:linear-gradient(90deg,rgba(0,229,255,.04),transparent 50%)}

/* === Plan Items === */
.plan-item{display:flex;align-items:center;gap:10px;padding:11px 12px;cursor:pointer;transition:all .15s;border-radius:6px;margin:4px 0;text-decoration:none;border:1px solid transparent}
.plan-item:hover{background:rgba(0,229,255,.03);border-color:rgba(0,229,255,.08)}
.plan-item .plan-icon{font-size:15px;flex-shrink:0}
.plan-item .plan-name{font-size:13px;color:var(--t1);flex:1;font-weight:500}
.plan-item .plan-arrow{font-size:12px;color:var(--t3);transition:transform .2s}
.plan-item:hover .plan-arrow{transform:translateX(4px);color:var(--green)}

