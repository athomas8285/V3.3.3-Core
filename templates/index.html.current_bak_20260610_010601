.wc-cal-day.other-month{background:transparent;border-color:transparent;cursor:default;min-height:0}
.wc-cal-day.today{border-color:rgba(251,191,36,.35);background:rgba(251,191,36,.06);box-shadow:0 0 0 1px rgba(251,191,36,.15)}
.wc-cal-day.has-matches{background:rgba(255,255,255,.05)}
.wc-cal-day.has-matches:hover{background:rgba(251,191,36,.06)}

