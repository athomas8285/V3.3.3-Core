function updateCountdown(){
  var now = new Date();
  var kickoff = new Date(2026, 5, 12, 0, 0, 0);
  var diff = kickoff - now;
  if(diff <= 0){
    if(window.__CD_INTERVAL) clearInterval(window.__CD_INTERVAL);
    renderHomePage();
    return;
  }
  var totalSec = Math.floor(diff / 1000);
  var d = Math.floor(totalSec / 86400);
  var h = Math.floor((totalSec % 86400) / 3600);
  var m = Math.floor((totalSec % 3600) / 60);
  var s = totalSec % 60;
  var pad = function(v){return v<10?"0"+v:""+v;};
  var el = document.getElementById("hcdDays");
  if(el) el.textContent = pad(d);
  el = document.getElementById("hcdHours");
  if(el) el.textContent = pad(h);
  el = document.getElementById("hcdMins");
  if(el) el.textContent = pad(m);
  el = document.getElementById("hcdSecs");
  if(el) el.textContent = pad(s);
}

