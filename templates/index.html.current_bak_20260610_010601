// 渲染小组赛程
function renderCalendarView(){
  var main = document.querySelector(".main");
  main.scrollTop = 0;
  document.querySelector(".sec-header h2").textContent = "🏆 2026世界杯赛程";
  var gs={};for(var xi=0;xi<WC_MATCHES.length;xi++)gs[WC_MATCHES[xi].g]=1;var gk=Object.keys(gs);document.getElementById("todaySub").textContent = WC_MATCHES.length+"场比赛 · "+gk.length+"个小组";
  document.getElementById("todayMatches").style.display = "block";

  // Build match lookup by date
  var matchByDate = {};
  for(var i = 0; i < WC_MATCHES.length; i++){
    var m = WC_MATCHES[i];
    if(!matchByDate[m.d]) matchByDate[m.d] = [];
    matchByDate[m.d].push(m);
  }

  var now = new Date();
  var y = now.getFullYear();
  var m = now.getMonth();
  var d = now.getDate();
  var todayKey = y + "-" + pad2(m+1) + "-" + pad2(d);

  var calYear = 2026;
  var calMonth = 5; // June (0-indexed)

  function pad2(v){return v<10?"0"+v:""+v;}

  function buildHTML(year, month){
    var firstDay = new Date(year, month, 1);
    var startDow = firstDay.getDay();
    var startCol = startDow === 0 ? 6 : startDow - 1;
    var daysInMonth = new Date(year, month + 1, 0).getDate();
    var dayNames = ["周一","周二","周三","周四","周五","周六","周日"];

    var h = '<div class="wc-calendar-wrap"><div class="wc-cal-grid">';
    for(var dw = 0; dw < 7; dw++){
      h += '<div class="wc-cal-day-head">' + dayNames[dw] + '</div>';
    }

    // Empty cells before first day
    for(var e = 0; e < startCol; e++){
      h += '<div class="wc-cal-day other-month"></div>';
    }

    // Day cells
    for(var day = 1; day <= daysInMonth; day++){
      var dateKey = (month+1) + "\u6708" + day + "\u65e5";
      var matches = matchByDate[dateKey] || [];
      var isToday = (year + "-" + pad2(month+1) + "-" + pad2(day) === todayKey);
      var hasMatches = matches.length > 0;

      var cls = "wc-cal-day";
      if(hasMatches) cls += " has-matches";
      if(isToday) cls += " today";

      h += '<div class="' + cls + '" onclick="showDayModal(' + day + ')" data-day="' + day + '">';
      h += '<div class="cday-num">' + day;
      if(isToday) h += '<span class="today-badge">\u4eca\u5929</span>';
      h += '</div>';

      if(hasMatches){
        var groups = {};
        for(var mi = 0; mi < matches.length; mi++) groups[matches[mi].g] = true;
        var gkeys = Object.keys(groups);
        h += '<div class="cday-badges">';
        for(var gi = 0; gi < Math.min(gkeys.length, 4); gi++){
          h += '<span class="cday-badge">' + gkeys[gi] + '\u7ec4</span>';
        }
        if(gkeys.length > 4) h += '<span class="cday-badge">+' + (gkeys.length-4) + '</span>';
        h += '</div>';

        var showCount = Math.min(matches.length, 6);
        for(var mi = 0; mi < showCount; mi++){
          var mt = matches[mi];
          h += '<div class="cday-match"><span class="cdm-time">' + mt.t.slice(0,5) + '</span>' + flagImg(mt.h) + mt.h.slice(0,4) + ' vs ' + flagImg(mt.a) + mt.a.slice(0,4) + '</div>';
        }
        if(matches.length > 6){
          h += '<div class="cday-more">+' + (matches.length - 6) + ' \u573a</div>';
        }
      }

      h += '</div>';
    }

    // Remaining empty cells
    var totalCells = startCol + daysInMonth;
    var rem = (7 - totalCells % 7) % 7;
    for(var r = 0; r < rem; r++){
      h += '<div class="wc-cal-day other-month"></div>';
    }

    h += '</div></div>';
    return h;
  }

  document.getElementById("todayMatches").innerHTML = buildHTML(calYear, calMonth);
  document.getElementById("caltMonthLabel").textContent = (calMonth+1) + "\u6708 " + calYear;
  window.__CAL_YEAR = calYear;
  window.__CAL_MONTH = calMonth;
}

