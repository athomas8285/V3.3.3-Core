    <div class="table-wrap" id="yesterdayTableWrap">
      <div class="table-top" id="yesterdayTableTop"></div>
      <div style="overflow-x:auto"><table class="y-table" id="yesterdayTable"><tbody id="yesterdayTableBody"></tbody></table></div>
    </div>
