<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>V3.3.3-Core 分析系统</title>
<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{--bg:#1a1a20;--surface:#1e1e24;--surface-2:#25252b;--surface-h:#2d2d35;--t1:#e8e8ed;--t2:#999;--t3:#666;--green:#00e676;--red:#ef5350;--amber:#ffd54f;--blue:#42a5f5;--bd:#2e2e36;--bd-h:#3a3a44;--mono:"SF Mono","Cascadia Code","Consolas",monospace;--sans:"Inter","Microsoft YaHei","PingFang SC","Noto Sans SC",sans-serif}
body{font-family:var(--sans);background:var(--bg);color:var(--t1);min-height:100vh;display:flex;-webkit-font-smoothing:antialiased}
::-webkit-scrollbar{width:5px}
::-webkit-scrollbar-track{background:transparent}
::-webkit-scrollbar-thumb{background:var(--bd-h);border-radius:3px}
.sd-wrap{width:250px;flex-shrink:0;position:sticky;top:0;height:100vh;overflow-y:auto;background:var(--surface);border-right:1px solid var(--bd);display:flex;flex-direction:column}
.sd-top{padding:20px 18px 16px;border-bottom:1px solid var(--bd);flex-shrink:0}
.sd-logo-row{display:flex;align-items:center;gap:8px}
.sd-home{display:flex;align-items:center;justify-content:center;width:26px;height:26px;border-radius:6px;cursor:pointer;transition:background .2s;flex-shrink:0;position:relative}
.sd-home:hover{background:rgba(0,230,118,.12)}
.sd-home:hover::after{content:attr(title);position:absolute;left:36px;top:50%;transform:translateY(-50%);background:var(--surface-2);color:var(--t2);font-size:11px;padding:3px 8px;border-radius:4px;white-space:nowrap;border:1px solid var(--bd);z-index:10;font-weight:400}
.sd-title{font-size:22px;font-weight:700;color:var(--green);letter-spacing:1px;line-height:1.2}
.sd-sub{font-size:11px;color:var(--t3);letter-spacing:1px;margin-top:4px}
.sd-status{display:flex;align-items:center;gap:8px;margin-top:10px;font-size:12px;color:var(--t2);padding:4px 0}
.sd-status-dot{width:8px;height:8px;border-radius:50%;background:var(--green);flex-shrink:0;animation:pulse 2s infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.4}}
.sd-body{flex:1;overflow-y:auto;padding:0 0 8px}
.sd-footer{padding:10px 16px;border-top:1px solid var(--bd);font-size:11px;color:var(--t3);text-align:center;flex-shrink:0}
.acc{border-bottom:1px solid var(--bd)}
.acc-head{display:flex;align-items:center;gap:10px;padding:13px 16px;min-height:48px;cursor:pointer;user-select:none;transition:background .15s}
.acc-head:hover{background:rgba(255,255,255,.07)}
.acc-head .acc-arrow{font-size:11px;color:var(--t3);transition:transform .3s ease;flex-shrink:0;width:12px;text-align:center}
.acc.open .acc-arrow{transform:rotate(90deg)}
.acc-head .acc-icon{font-size:17px}
.acc-head .acc-label{font-size:15px;font-weight:600;color:var(--t2);letter-spacing:.5px;flex:1;min-width:0}
.acc-head .acc-badge{font-size:10px;color:var(--green);background:rgba(0,230,118,.1);padding:2px 8px;border-radius:8px;white-space:nowrap}
.acc-head .acc-count{font-size:12px;color:var(--t3);background:rgba(255,255,255,.06);padding:1px 5px;border-radius:4px;white-space:nowrap}
.acc.open .acc-head .acc-label{color:var(--t1)}
.acc-body{overflow:hidden;max-height:0;transition:max-height .35s ease}
.acc.open>.acc-body{max-height:900px}
.acc-body-inner{padding:4px 16px 12px}
.today-stats{display:flex;flex-direction:column;gap:6px;padding:4px 0}
.today-stat-row{display:flex;justify-content:space-between;align-items:center;padding:5px 8px;background:rgba(255,255,255,.03);border-radius:5px;font-size:11px}
.today-stat-row .tsl{color:var(--t3)}
.today-stat-row .tsv{color:var(--t1);font-weight:600;font-family:var(--mono)}
.today-stat-row .tsv.high{color:var(--green)}
.today-stat-row .tsv.med{color:var(--amber)}
.today-stat-row .tsv.low{color:var(--red)}
.today-divider{height:1px;background:var(--bd);margin:6px 0}
.today-date{font-size:15px;color:var(--green);font-weight:600;padding:2px 0;text-align:center}
.hist-date-item{display:flex;align-items:center;gap:6px;padding:10px 16px;min-height:40px;cursor:pointer;transition:all .2s;border-left:3px solid transparent;border-radius:0 4px 4px 0;margin:2px 0}
.hist-date-item:hover{background:rgba(255,255,255,.08)}
.hist-date-item.active{border-left-color:var(--green);background:rgba(0,230,118,.07)}
.hist-date-item .hd-date{font-size:14px;font-weight:600;color:var(--t1);flex:1;min-width:0}
.hist-date-item .hd-stats{font-size:11px;color:var(--t3);white-space:nowrap}
.hist-date-item.active .hd-date{color:#fff}
.hist-date-item .hd-arrow{font-size:10px;color:var(--t3);transition:transform .3s ease}
.hist-date-item.open .hd-arrow{transform:rotate(90deg)}
.hist-action{padding:4px 16px 8px 28px;display:none}
.hist-date-item.open+.hist-action{display:block}
.hist-action button{width:100%;padding:5px 10px;font-size:10px;color:var(--t2);background:rgba(0,230,118,.08);border:1px solid rgba(0,230,118,.15);border-radius:4px;cursor:pointer;transition:all .15s;font-family:var(--sans)}
.hist-action button:hover{background:rgba(0,230,118,.18);color:var(--green)}
.hist-empty{padding:16px 12px;font-size:12px;color:var(--t3);text-align:center}
.bt-item{padding:9px 12px;margin:5px 0;background:rgba(255,255,255,.02);border-radius:5px;cursor:pointer;transition:background .15s;border:1px solid transparent}
.bt-item:hover{background:rgba(255,255,255,.09);border-color:rgba(255,255,255,.12)}
.bt-item .bt-title{font-size:13px;font-weight:600;color:var(--t1);margin-bottom:2px}
.bt-item .bt-meta{font-size:11px;color:var(--t3);display:flex;gap:8px;flex-wrap:wrap}
.bt-item .bt-meta span{background:rgba(255,255,255,.04);padding:1px 5px;border-radius:3px}
.bt-detail{padding:10px;margin:3px 0 8px;background:var(--surface);border-radius:6px;font-size:11px;color:var(--t2);line-height:1.6;display:none;border:1px solid var(--bd)}
.bt-detail.show{display:block}
.bt-detail .bt-summ{color:var(--t1);margin-bottom:4px}
.bt-detail .bt-link{padding:5px 10px;font-size:11px;background:rgba(66,165,245,.12);color:var(--blue);border:none;border-radius:4px;cursor:pointer;font-family:var(--sans);transition:background .15s}
.doc-item{padding:9px 12px;margin:5px 0;background:rgba(255,255,255,.02);border-radius:5px;cursor:pointer;transition:background .15s}
.doc-item:hover{background:rgba(255,255,255,.09)}
.doc-item .doc-title{font-size:13px;font-weight:600;color:var(--t1)}
.doc-content{padding:10px;margin:3px 0 8px;background:var(--surface);border-radius:5px;display:none;border:1px solid var(--bd)}
.doc-content.show{display:block}
.doc-entry{padding:5px 0;font-size:12px;line-height:1.7}
.doc-entry .de-label{color:var(--green);font-weight:600;white-space:nowrap}
.doc-entry .de-value{color:var(--t2)}
.sd-loading{color:var(--t3);font-size:12px;padding:12px;text-align:center}
.sd-error{color:var(--red);font-size:12px;padding:12px;text-align:center}
.main{flex:1;min-width:0;max-width:1000px;margin:0 auto;padding:0 20px 60px}
.sec-header{display:flex;align-items:baseline;gap:12px;padding:18px 0 10px}
.sec-header h2{font-size:16px;font-weight:700;color:var(--t1)}
.sec-header .sec-sub{font-size:12px;color:var(--t2);font-weight:500}
.sec-header .sec-bar{flex:1;height:1px;background:var(--bd)}
.match-card{background:var(--surface-2);border:1px solid var(--bd);border-radius:10px;margin-bottom:12px;overflow:hidden;transition:border-color .25s,box-shadow .25s;position:relative}
.match-card:hover{border-color:var(--bd-h);box-shadow:0 0 0 1px rgba(0,230,118,.08)}
.mc-header{display:flex;align-items:center;padding:12px 16px;gap:12px}
.mc-left{display:flex;align-items:center;gap:10px;flex:1;min-width:0}
.mc-time{font-family:var(--mono);font-size:12px;color:var(--t2);white-space:nowrap;font-weight:500}
.mc-league{font-size:10px;color:var(--t3);background:rgba(255,255,255,.06);padding:2px 9px;border-radius:10px;white-space:nowrap;letter-spacing:.3px;font-weight:500}
.mc-teams{font-size:15px;font-weight:700;color:var(--t1);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.mc-vs{color:var(--t3);font-size:11px;font-weight:400;margin:0 4px}



.mc-right{display:flex;align-items:center;gap:8px;flex-shrink:0}












.match-card.active{border-color:rgba(0,230,118,.25);box-shadow:0 0 0 1px rgba(0,230,118,.12),0 0 20px rgba(0,230,118,.04)}
.mc-teams-wrap{display:flex;flex-direction:column;gap:2px;min-width:0}
.mc-bar-wrap{flex:1;min-width:80px;max-width:140px;height:6px;margin:0 6px;position:relative;border-radius:3px;overflow:hidden;background:var(--surface)}
.mc-bar-fill{height:100%;border-radius:3px;transition:width .5s ease}
.mc-score{font-size:24px;font-weight:800;font-family:var(--mono);color:var(--t1);line-height:1;min-width:44px;text-align:center}
.mc-rating-badge{font-size:13px;font-weight:700;padding:4px 8px;border-radius:5px;min-width:28px;text-align:center;line-height:1}
.mc-rating-badge.s{background:var(--green);color:#fff}
.mc-rating-badge.a{background:var(--blue);color:#fff}
.mc-rating-badge.b{background:var(--amber);color:#222}
.mc-rating-badge.c{background:var(--red);color:#fff}
.mc-rating-badge.m{background:var(--t3);color:#fff}
.mc-dir-badge{font-size:11px;font-weight:600;padding:3px 8px;border-radius:4px;line-height:1;background:rgba(255,255,255,.06);color:var(--t1)}
.mc-dir-badge.win{background:rgba(0,230,118,.15);color:var(--green)}
.mc-dir-badge.lose{background:rgba(239,83,80,.15);color:var(--red)}
.mc-dir-badge.draw{background:rgba(66,165,245,.15);color:var(--blue)}
.mc-expand-btn{color:var(--t3);font-size:10px;cursor:pointer;padding:4px;border-radius:4px;transition:transform .3s,background .15s;display:flex;align-items:center;justify-content:center;width:20px;height:20px;flex-shrink:0}
.mc-expand-btn:hover{background:rgba(255,255,255,.08)}
.match-card.active .mc-expand-btn{transform:rotate(180deg)}
.mc-predictions{display:flex;flex-direction:row;gap:8px;margin:10px 18px 0;flex-wrap:nowrap}
.mc-pred-item{display:flex;align-items:center;gap:6px;padding:5px 10px;border-radius:20px;background:rgba(255,255,255,.04);border:1px solid var(--bd);white-space:nowrap;flex:0 1 auto}
.mc-pred-icon{font-size:13px;line-height:1;flex-shrink:0}
.mc-pred-label{font-size:10px;color:var(--t3);font-weight:500;letter-spacing:.3px;flex-shrink:0}
.mc-pred-value{font-size:12px;font-weight:700;color:var(--green);line-height:1;margin-left:2px}
.mc-detail{display:none;padding:0 18px 16px}
.match-card.active .mc-detail{display:block}
.chart-wrap{position:relative;height:80px;display:flex;align-items:flex-end;padding:0 4px}
.chart-y-axis{position:absolute;left:0;top:0;bottom:0;width:100%;pointer-events:none}
.chart-y-axis line{stroke:rgba(255,255,255,.06);stroke-width:1;stroke-dasharray:3 3}
.chart-y-axis text{fill:var(--t3);font-size:8px;font-family:var(--mono)}
.chart-bar-group{display:flex;flex-direction:column;align-items:center;gap:4px;flex:1;max-width:60px}
.chart-bar{width:100%;max-width:36px;border-radius:4px 4px 0 0;min-height:4px;position:relative;transition:height .5s ease}
.chart-bar-label{font-size:9px;color:var(--t3);font-family:var(--mono);white-space:nowrap}
.chart-bar-val{font-size:9px;font-weight:600;font-family:var(--mono);position:absolute;top:-14px;left:50%;transform:translateX(-50%);white-space:nowrap}
.chart-bar.val-green .chart-bar-val{color:var(--green)}
.chart-bar.val-red .chart-bar-val{color:var(--red)}
.chart-bar.val-amber .chart-bar-val{color:var(--amber)}
.detail-grid-4{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:10px}
.detail-cell{background:var(--surface);border-radius:6px;padding:8px 10px;display:flex;flex-direction:column;gap:2px}
.detail-cell .dc-label{font-size:10px;color:var(--t3);font-weight:500;display:flex;align-items:center;gap:4px}
.detail-cell .dc-value{font-size:12px;color:var(--t1);line-height:1.4;overflow:hidden;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;word-break:break-word}
.detail-cell .dc-value strong{font-family:var(--mono);font-weight:800;color:#fff;font-size:14px}
.detail-cell.risk{background:rgba(239,83,80,.1);border:1px solid rgba(239,83,80,.15)}
.detail-cell.risk .dc-value{color:var(--red)}




.detail-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-top:12px}
.chart-box{background:var(--surface);border-radius:8px;padding:12px 12px 8px}
.chart-box .ch-title{font-size:11px;color:var(--t2);margin-bottom:6px;font-weight:600}










.table-wrap{background:var(--surface-2);border:1px solid var(--bd);border-radius:8px;overflow:hidden;margin-top:6px}
.table-top{display:flex;align-items:center;gap:14px;padding:10px 14px;background:var(--surface);border-bottom:1px solid var(--bd);flex-wrap:wrap}
.table-top .tt-item{font-size:11px;color:var(--t2)}
.table-top .tt-item b{color:var(--t1);font-weight:600}
.table-top .tt-item .hl{color:var(--green)}
.table-top .tt-item .hl2{color:var(--amber)}
.tt-spacer{flex:1}
table.y-table{width:100%;border-collapse:collapse;font-size:12px}
table.y-table thead th{padding:8px 10px;text-align:left;font-weight:600;color:var(--t3);background:var(--surface);border-bottom:1px solid var(--bd);white-space:nowrap}
table.y-table tbody td{padding:8px 10px;border-bottom:1px solid rgba(255,255,255,.04);color:var(--t2);white-space:nowrap}
table.y-table tbody tr:hover{background:rgba(255,255,255,.03)}
table.y-table tbody tr:last-child td{border-bottom:none}
td.c-result{font-weight:600}
td.c-result.win{color:var(--red)}
td.c-result.lose{color:var(--green)}
td.c-result.draw{color:var(--blue)}
td.c-status .tag{padding:2px 8px;border-radius:3px;font-size:10px;font-weight:600}
td.c-status .tag.hit{background:var(--red);color:#fff}
td.c-status .tag.miss{background:var(--t3);color:#fff}
td.c-rating .r-num{font-weight:700;color:var(--t1);font-family:var(--mono)}
td.c-rating .r-lvl{font-size:10px;padding:1px 5px;border-radius:3px;font-weight:600;margin-left:4px}
td.c-rating .r-lvl.s{background:var(--green);color:#fff}
td.c-rating .r-lvl.a{background:var(--amber);color:#222}
td.c-rating .r-lvl.b{background:var(--t3);color:#fff}
.empty-state{text-align:center;padding:40px 20px;color:var(--t3);font-size:13px}

/* === Contact & Divider === */
.sd-divider{height:1px;background:var(--bd);margin:16px 18px 12px;flex-shrink:0}
.sd-contact{padding:6px 18px 12px;display:flex;flex-direction:column;gap:6px;flex-shrink:0}
.sd-contact-btn{display:flex;align-items:center;justify-content:center;gap:8px;width:100%;padding:10px 16px;border-radius:8px;border:1px solid var(--bd);background:rgba(255,255,255,.03);color:var(--t2);font-size:13px;font-family:var(--sans);cursor:pointer;transition:all .2s}
.sd-contact-btn:hover{background:rgba(66,165,245,.12);border-color:rgba(66,165,245,.25);color:var(--blue)}
.sd-contact-btn .cb-icon{font-size:16px}
.sd-contact-btn .cb-text{font-weight:500}

/* Today module highlight */
#accToday.open>.acc-head{background:rgba(0,230,118,.06)}
#accToday.open>.acc-head .acc-label{color:var(--green)}

/* Active date stronger highlight */
.hist-date-item.active{border-left-color:var(--green);background:rgba(0,230,118,.12)}
.hist-date-item.active .hd-date{color:var(--green)}

/* Stronger active state for nav items */
.acc.open>.acc-head{background:rgba(255,255,255,.04)}


/* === Plan Items === */
.plan-item{display:flex;align-items:center;gap:10px;padding:11px 12px;cursor:pointer;transition:all .15s;border-radius:6px;margin:4px 0;text-decoration:none}
.plan-item:hover{background:rgba(255,255,255,.09)}
.plan-item .plan-icon{font-size:15px;flex-shrink:0}
.plan-item .plan-name{font-size:13px;color:var(--t1);flex:1;font-weight:500}
.plan-item .plan-arrow{font-size:12px;color:var(--t3);transition:transform .2s}
.plan-item:hover .plan-arrow{transform:translateX(4px);color:var(--green)}

@media(max-width:768px){
  .sd-wrap{width:60px}
  .sd-title,.sd-sub,.sd-status,..plan-item,.acc .acc-label,.acc .acc-badge,.acc .acc-count,.hist-date-item .hd-date,.hist-date-item .hd-stats,.today-stat-row,.bt-item .bt-title,.bt-item .bt-meta,.doc-item .doc-title,.sd-contact,.sd-footer{display:none}
  .sd-wrap .acc-body{max-height:0!important}
  .sd-wrap:hover{width:250px;position:fixed;z-index:100;box-shadow:4px 0 20px rgba(0,0,0,.4)}
  .sd-wrap:hover .sd-title,.sd-wrap:hover .sd-sub,.sd-wrap:hover .sd-status,.sd-wrap:hover .acc .acc-label,.sd-wrap:hover .acc .acc-badge,.sd-wrap:hover .acc .acc-count,.sd-wrap:hover .plan-item,.sd-wrap:hover .hist-date-item .hd-date,.sd-wrap:hover .hist-date-item .hd-stats,.sd-wrap:hover .today-stat-row,.sd-wrap:hover .bt-item .bt-title,.sd-wrap:hover .bt-item .bt-meta,.sd-wrap:hover .doc-item .doc-title,.sd-wrap:hover .sd-footer{display:flex;display:block}
  .sd-wrap:hover .acc-body{max-height:900px!important}
  .main{padding:0 10px 40px}
  .mc-header{flex-wrap:wrap;gap:8px}
.mc-bar-wrap{min-width:50px;max-width:80px}
  .mc-predictions{flex-wrap:wrap}
  .detail-grid{grid-template-columns:1fr}
.detail-grid-4{grid-template-columns:1fr}
  table.y-table{font-size:11px}
  table.y-table thead th,table.y-table tbody td{padding:6px 6px}
}
</style>
</head>
<body>
<div class="sd-wrap">
  <div class="sd-top">
    <div class="sd-logo-row">
      <div>
        <div class="sd-title">V3.3.3-Core</div>
        <div class="sd-sub">分析系统</div>
      </div>
    </div>
    <div class="sd-status">
      <span class="sd-status-dot db-connected"></span>
      <span>系统运行中</span>
      <span style="color:var(--t3);margin-left:auto;font-size:9px">v3.3.3</span>
    </div>
  </div>
  <div class="sd-body">
<div class="acc open" id="accToday" class="active-section">
      <div class="acc-head" onclick="toggleAccordion('accToday')">
        <span class="acc-arrow">▶</span>
        <span class="acc-icon">📊</span>
        <span class="acc-label">今日概览</span>
        <span class="acc-badge" style="background:rgba(0,230,118,.15);color:var(--green)">实时</span>
        <span class="acc-count" id="todayMatchCount">-</span>
      </div>
      <div class="acc-body">
        <div class="acc-body-inner">
          <div class="today-date" id="todayDateLabel">加载中...</div>
          <div class="today-stats" id="todayStats">
            <div class="sd-loading">加载中...</div>
          </div>
        </div>
      </div>
    </div>
    <div class="acc" id="accHistory">
      <div class="acc-head" onclick="toggleAccordion('accHistory')">
        <span class="acc-arrow">▶</span>
        <span class="acc-icon">📅</span>
        <span class="acc-label">历史预测数据</span>
        <span class="acc-badge" style="background:rgba(0,230,118,.15);color:var(--green)">实战</span>
      </div>
      <div class="acc-body">
        <div class="acc-body-inner" style="padding:8px 16px 12px">
          <div style="margin-bottom:10px">
            <input type="text" id="historySearch" placeholder="搜索日期 (YYYY-MM-DD)" style="width:100%;padding:7px 10px;font-size:11px;font-family:var(--sans);background:var(--bg);border:1px solid var(--bd);border-radius:5px;color:var(--t1);outline:none;transition:border-color .15s" oninput="filterHistoryDates(this.value)">
          </div>
          <div id="historyListContainer">
            <div class="sd-loading">加载中...</div>
          </div>
          <div id="historyLoadMore" style="display:none;text-align:center;padding:8px 0">
            <button onclick="loadMoreHistory()" style="width:100%;padding:6px 10px;font-size:11px;color:var(--t2);background:rgba(255,255,255,.04);border:1px solid var(--bd);border-radius:5px;cursor:pointer;font-family:var(--sans);transition:all .15s">加载更多 ↓</button>
          </div>
        </div>
      </div>
    </div>
    <div class="acc" id="accBacktest">
      <div class="acc-head" onclick="toggleAccordion('accBacktest')">
        <span class="acc-arrow">▶</span>
        <span class="acc-icon">🧪</span>
        <span class="acc-label">历史比赛回测</span>
